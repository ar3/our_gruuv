- toggle_link_class = local_assigns.fetch(:toggle_link_class)
- menu_class = local_assigns.fetch(:menu_class, 'dropdown-menu dropdown-menu-end')
- person_label = local_assigns.fetch(:person_label)
- show_gsd_in_toggle = local_assigns.fetch(:show_gsd_in_toggle, false)

%a{class: toggle_link_class, href: "#", role: "button", "data-bs-toggle": "dropdown", "aria-expanded": "false", "aria-label": "#{person_label} menu"}
  - if impersonating?
    %i.bi.bi-exclamation-triangle.text-warning.flex-shrink-0
  - profile_url = current_person.canonical_profile_image_url(teammate: current_company_teammate)
  - if profile_url.present?
    = image_tag profile_url, class: 'rounded-circle flex-shrink-0 header-user-avatar', alt: '', width: 28, height: 28, style: 'object-fit: cover; width: 28px; height: 28px;'
  - else
    %i.bi.bi-person-circle.flex-shrink-0.header-user-icon
  %span.header-user-name.d-none.d-sm-inline.text-truncate
    = person_label
  - if show_gsd_in_toggle && current_organization && current_company_teammate
    - pending_count = pending_get_shit_done_count(current_company_teammate)
    - if pending_count > 0
      = link_to organization_get_shit_done_path(current_organization), class: "badge bg-danger rounded-pill ms-2 text-decoration-none flex-shrink-0", title: "#{company_label_for('get_shit_done', 'Get Shit Done')} (#{pending_count} items)" do
        = pending_count
%ul{class: menu_class}
  - has_multiple_organizations = current_person.present? && current_person.available_organizations.count > 1
  - if impersonating?
    %li
      = button_to impersonation_path(1), method: :delete, class: "dropdown-item text-danger", form: { style: "display: inline;" } do
        %i.bi.bi-person-x.me-2
        Stop Impersonation
    %li
      %hr.dropdown-divider
  - if current_organization
    %li
      = link_to organization_company_teammate_path(current_organization, current_company_teammate), class: "dropdown-item" do
        %i.bi.bi-person-circle.me-2
        My Profile
  - else
    %li
      = link_to public_person_path(current_person), class: "dropdown-item" do
        %i.bi.bi-person-circle.me-2
        My Profile
  - if current_organization
    - one_on_one_link_record = current_company_teammate&.one_on_one_link || OneOnOneLink.new(teammate: current_company_teammate)
    - if current_company_teammate && policy(one_on_one_link_record).show?
      %li
        = link_to organization_company_teammate_one_on_one_link_path(current_organization, current_company_teammate), class: "dropdown-item" do
          %i.bi.bi-link-45deg.me-2
          My 1:1
    %li
      = link_to my_growth_experiences_organization_company_teammate_path(current_organization, current_company_teammate), class: "dropdown-item" do
        %i.bi.bi-person-badge.me-2
        My Growth
    %li
      = link_to organization_start_here_path(current_organization), class: "dropdown-item" do
        %i.bi.bi-house-door.me-2
        My Dashboard
  %li
    %hr.dropdown-divider
  - if current_organization
    - if current_company_teammate&.has_direct_reports?
      %li
        = link_to organization_employees_path(current_organization, manager_teammate_id: current_company_teammate&.id, view: 'managers_view', spotlight: 'manager_lite'), class: "dropdown-item" do
          %i.bi.bi-people-fill.me-2
          My Employees
    %li
      = link_to organization_employees_path(current_organization, spotlight: 'teammate_tenures'), class: "dropdown-item" do
        %i.bi.bi-people.me-2
        All Teammates
    %li
      %hr.dropdown-divider
    %li
      = link_to organization_observations_path(current_organization, privacy: %w[public_to_company public_to_world], spotlight: 'most_observed', view: 'wall'), class: "dropdown-item" do
        %i.bi.bi-gift.me-2
        = "#{current_organization.display_name} Kudos"
    %li
      = link_to celebrate_milestones_organization_path(current_organization), class: "dropdown-item" do
        %i.bi.bi-trophy.me-2
        Celebrate Milestones
  %li
    %hr.dropdown-divider
  - if has_multiple_organizations
    %li
      = link_to switch_organizations_path, class: "dropdown-item" do
        %i.bi.bi-arrow-left-right.me-2
        Switch Organizations
  %li
    = link_to interest_submissions_path, class: "dropdown-item" do
      %i.bi.bi-lightbulb.me-2
      Help Improve OG
  - if current_person&.og_admin?
    %li
      = link_to organizations_path, class: "dropdown-item" do
        %i.bi.bi-buildings.me-2
        Manage Organizations
    %li
      = link_to interest_submissions_path, class: "dropdown-item" do
        %i.bi.bi-inboxes.me-2
        Interest Submissions
  %li
    %hr.dropdown-divider
  %li
    = button_to logout_path, method: :delete, class: "dropdown-item", form: { style: "display: inline;" } do
      %i.bi.bi-box-arrow-right.me-2
      Logout
