- check_ins_count = @check_ins_awaiting_input.size
= render 'shared/section_header',
         title: clarity_check_ins_awaiting_your_input_label,
         icon: 'bi-clipboard-check',
         description: clarity_check_ins_awaiting_input_description,
         collapsible: true,
         collapse_target: 'checkInsAwaitingInputSection',
         status_indicator: :warning

-# Summary view (shown when collapsed) — warning alert style
%div{class: "alert mb-4 collapse-summary #{status_indicator_alert_class(:warning)}", "data-bs-toggle" => "collapse", "data-bs-target" => "#checkInsAwaitingInputSection", "aria-expanded" => "false", "aria-controls" => "checkInsAwaitingInputSection", style: "cursor: pointer;"}
  %p.mb-0
    %i{class: "#{status_indicator_icon(:warning)} #{status_indicator_badge_class(:warning)} me-2"}
    = clarity_check_ins_awaiting_input_summary(count: check_ins_count)

-# Collapsible content
.collapse#checkInsAwaitingInputSection
  .card.mb-4
    .card-body
      - if @check_ins_awaiting_input.any?
        .table-responsive
          %table.table.table-hover
            %thead
              %tr
                %th{style: 'width: 2rem;'}
                %th Details
                %th Your Role
                %th Action
            %tbody
              - check_ins_awaiting_input_by_employee(@check_ins_awaiting_input).each do |employee_teammate, group_check_ins|
                %tr.table-secondary
                  %td{colspan: 4}
                    %span.fw-semibold.text-secondary-emphasis
                      = check_ins_awaiting_input_group_header(group_check_ins, employee_teammate, @teammate)
                - group_check_ins.each do |check_in|
                  - is_employee_role = (check_in.company_teammate == @teammate)
                  %tr
                    %td.text-muted
                      %i.bi.bi-arrow-return-right
                    %td
                      = render 'shared/check_ins/counterparty_completion_detail', check_in: check_in
                    %td
                      - if is_employee_role
                        %span.badge.bg-warning.text-dark
                          %i.bi-person.me-1
                          Complete as Employee
                      - else
                        %span.badge.bg-warning.text-dark
                          %i.bi-person-badge.me-1
                          Complete as Manager
                    %td
                      = link_to "Review",
                                get_shit_done_check_in_review_path(current_organization, check_in),
                                class: "btn btn-primary btn-sm"
      - else
        %p.text-muted.mb-0= no_clarity_check_ins_awaiting_your_input_label
