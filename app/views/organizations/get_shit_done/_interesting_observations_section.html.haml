-# locals: observations, title, icon, description, collapse_id, summary
- observations = local_assigns.fetch(:observations)
- title = local_assigns.fetch(:title)
- icon = local_assigns.fetch(:icon)
- description = local_assigns.fetch(:description)
- collapse_id = local_assigns.fetch(:collapse_id)
- summary = local_assigns.fetch(:summary)

= render 'shared/section_header',
         title: title,
         icon: icon,
         description: description,
         collapsible: true,
         collapse_target: collapse_id,
         status_indicator: :info

%div{class: "alert mb-4 collapse-summary #{status_indicator_alert_class(:info)}", "data-bs-toggle" => "collapse", "data-bs-target" => "##{collapse_id}", "aria-expanded" => "false", "aria-controls" => collapse_id, style: "cursor: pointer;"}
  %p.mb-0
    %i{class: "#{status_indicator_icon(:info)} #{status_indicator_badge_class(:info)} me-2"}
    = summary

.collapse{id: collapse_id}
  .card.mb-4
    .card-body
      .table-responsive
        %table.table.table-hover
          %thead
            %tr
              %th Observation
              %th Observer
              %th About
              %th Published
              %th Action
          %tbody
            - observations.each do |observation|
              %tr
                %td
                  = truncate(observation.story.to_s, length: 120)
                %td
                  = observation.observer.casual_name
                %td
                  %small.text-muted= observation.observed_teammates.map { |tm| tm.person.casual_name }.join(', ')
                %td
                  %small.text-muted= "#{time_ago_in_words(observation.published_at)} ago"
                %td
                  = link_to 'View', organization_observation_path(organization, observation), class: 'btn btn-outline-primary btn-sm'
