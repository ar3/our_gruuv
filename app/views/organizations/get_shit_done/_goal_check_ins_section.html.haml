- goals_count = @goals_needing_check_in.count
= render 'shared/section_header', 
         title: 'Goal Check-ins', 
         icon: 'bi-bullseye', 
         description: 'Goals needing check-in updates',
         collapsible: true,
         collapse_target: 'goalCheckInsSection',
         status_indicator: :warning

-# Summary view (shown when collapsed) — warning alert style
%div{class: "alert mb-4 collapse-summary #{status_indicator_alert_class(:warning)}", "data-bs-toggle" => "collapse", "data-bs-target" => "#goalCheckInsSection", "aria-expanded" => "false", "aria-controls" => "goalCheckInsSection", style: "cursor: pointer;"}
  %p.mb-0
    %i{class: "#{status_indicator_icon(:warning)} #{status_indicator_badge_class(:warning)} me-2"}
    = pluralize(goals_count, 'goal') + ' needing check-in'

-# Collapsible content
.collapse#goalCheckInsSection
  .card.mb-4
    .card-body
      - if @goals_needing_check_in.any?
        .table-responsive
          %table.table.table-hover
            %thead
              %tr
                %th Goal
                %th Last Check-in
                %th Action
            %tbody
              - @goals_needing_check_in.each do |goal|
                - last_check_in = goal.goal_check_ins.recent.first
                %tr
                  %td
                    %strong= goal.title
                    %br
                    %small.text-muted= goal.goal_type.humanize
                  %td
                    - if last_check_in
                      %strong= "#{last_check_in.confidence_percentage}%"
                      %br
                      %small.text-muted= last_check_in.check_in_week_start.strftime('%b %d, %Y')
                    - else
                      %span.text-muted No check-in yet
                  %td
                    = link_to "Check In", 
                              weekly_update_organization_goal_path(organization, goal),
                              class: "btn btn-primary btn-sm"
      - else
        %p.text-muted.mb-0 All goals are up to date.

