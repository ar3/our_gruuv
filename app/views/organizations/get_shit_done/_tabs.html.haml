-# locals: active_tab (:get_shit_done or :something_interesting), interesting_count
- active_tab = local_assigns.fetch(:active_tab)
- interesting_count = local_assigns.fetch(:interesting_count, 0)

%ul.nav.nav-tabs.mb-4
  %li.nav-item
    = link_to company_label_for('get_shit_done', 'Get Shit Done'),
      organization_get_shit_done_path(organization),
      class: "nav-link #{'active' if active_tab == :get_shit_done}",
      aria: { current: (active_tab == :get_shit_done ? 'page' : nil) }
  %li.nav-item
    = link_to something_interesting_organization_get_shit_done_path(organization),
      class: "nav-link d-inline-flex align-items-center #{'active' if active_tab == :something_interesting}",
      aria: { current: (active_tab == :something_interesting ? 'page' : nil) } do
      %span Something Interesting
      - if interesting_count.positive?
        %span.badge.rounded-pill.text-bg-info.ms-2= interesting_count
