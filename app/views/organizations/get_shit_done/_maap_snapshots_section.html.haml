- snapshots_count = @maap_snapshots.count
= render 'shared/section_header', 
         title: clarity_check_ins_awaiting_acknowledgement_label,
         icon: 'bi-clipboard-check',
         description: clarity_check_ins_awaiting_acknowledgement_description,
         collapsible: true,
         collapse_target: 'maapSnapshotsSection',
         status_indicator: :warning

-# Summary view (shown when collapsed) — warning alert style
%div{class: "alert mb-4 collapse-summary #{status_indicator_alert_class(:warning)}", "data-bs-toggle" => "collapse", "data-bs-target" => "#maapSnapshotsSection", "aria-expanded" => "false", "aria-controls" => "maapSnapshotsSection", style: "cursor: pointer;"}
  %p.mb-0
    %i{class: "#{status_indicator_icon(:warning)} #{status_indicator_badge_class(:warning)} me-2"}
    = clarity_check_ins_awaiting_acknowledgement_summary(count: snapshots_count)

-# Collapsible content
.collapse#maapSnapshotsSection
  .card.mb-4
    .card-body
      - if @maap_snapshots.any?
        .table-responsive
          %table.table.table-hover
            %thead
              %tr
                %th Change Type
                %th Reason
                %th Effective Date
                %th Action
            %tbody
              - @maap_snapshots.each do |snapshot|
                %tr
                  %td
                    %strong= snapshot.change_type.humanize
                  %td
                    %small= truncate(snapshot.reason, length: 50)
                  %td
                    %small= snapshot.effective_date&.strftime('%b %d, %Y')
                  %td
                    = link_to "Acknowledge", 
                              audit_organization_employee_path(organization, @teammate),
                              class: "btn btn-primary btn-sm"

        = render 'shared/acknowledgement_explanation_callout',
                 markdown_text: acknowledgement_explanation_markdown(organization),
                 direction: :up
      - else
        %p.text-muted.mb-0 No check-ins awaiting acknowledgement.

