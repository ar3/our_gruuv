- content_for :title, "Aspirations - #{@teammate.person.display_name}"

- content_for :head do
  :css
    .aspiration-check-in-toggle .details-expanded { display: none; }
    .aspiration-check-in-toggle[aria-expanded="true"] .details-expanded { display: inline; }
    .aspiration-check-in-toggle[aria-expanded="true"] .details-collapsed { display: none; }

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: clarity_hub_label, url: hub_organization_company_teammate_check_ins_path(@organization, @teammate) }, { label: @aspiration.name, url: nil }])

- nav_title = "#{@aspiration.name} Check-In"
- research_sublinks = [{ id: "research-all-check-ins", label: "All check-ins", icon: "bi-list-check" }, { id: "research-observations", label: "Observations", icon: "bi-eye" }, { id: "research-goals", label: "Linked goals", icon: "bi-bullseye" }]
- nav_links = single_item_check_in_section_nav_links(check_in_type: :aspiration, research_sublinks: research_sublinks)
- initial_section = single_item_check_in_nav_initial_section(open_check_in: @open_check_in)

.row.mb-3
  .col-12
    = render "shared/single_item_check_in/header_switcher"

= render layout: "shared/single_item_check_in/page_wrapper", locals: { nav_title: nav_title, nav_links: nav_links, initial_section: initial_section } do
  %section#define.mb-5
    .card
      .card-header
        .d-flex.align-items-center.gap-2
          %h2.mb-0.h5= @aspiration.name
          = link_to organization_aspiration_path(@organization, @aspiration), target: "_blank", rel: "noopener", class: "text-muted text-decoration-none", title: "Open aspiration page in new tab", "aria-label" => "Open aspiration page in new tab" do
            %i.bi.bi-box-arrow-up-right
      .card-body
        - if @aspiration.description.present?
          .markdown-content.mb-0= render_markdown(@aspiration.description)
        - else
          %p.text-muted.mb-0 No description available.

  = render "shared/single_item_check_in/check_in_section",
      open_check_in: @open_check_in,
      start_check_in_path: start_check_in_organization_teammate_aspiration_path(@organization, @teammate, @aspiration),
      object_name: @aspiration.name do
    = render layout: "shared/single_item_check_in/crystal_clear_collapsible_form_wrapper", locals: { teammate: @teammate, object_name: @aspiration.name, open_check_in: @open_check_in, latest_finalized: @latest_finalized } do
      - is_complete = (current_person == @teammate.person ? @open_check_in.employee_completed? : @open_check_in.manager_completed?)
      = render "shared/single_item_check_in/perspective_context",
        check_in: @open_check_in,
        teammate: @teammate,
        object_name: @aspiration.name,
        is_complete: is_complete
      = form_with url: organization_company_teammate_check_ins_path(@organization, @teammate), method: :patch, scope: :check_ins, local: true,
        data: { controller: "check-in-autosave",
                check_in_autosave_debounce_ms_value: 2500,
                action: "input->check-in-autosave#markDirty change->check-in-autosave#markDirty submit->check-in-autosave#handleSubmit" } do |form|
        = render "shared/check_in_autosave_status"
        = form.hidden_field :current_url, value: organization_teammate_aspiration_path(@organization, @teammate, @aspiration), id: nil
        = form.hidden_field :current_type, value: "aspiration", id: nil
        = form.hidden_field :current_id, value: @aspiration.id, id: nil
        = form.fields_for :aspiration_check_ins, @open_check_in, index: @open_check_in.id do |af|
          - if current_person == @teammate.person
            .row
              .col-md-6
                .mb-3
                  %label.form-label My Rating
                  = af.select :employee_rating, aspiration_rating_options, { include_blank: 'Select rating', selected: @open_check_in.employee_rating }, { class: "form-select" }
              .col-md-6
                .mb-3
                  %label.form-label Private Notes
                  = af.text_area :employee_private_notes, rows: 3, class: "form-control", placeholder: "Notes..."
          - if current_person != @teammate.person
            .row
              .col-md-6
                .mb-3
                  %label.form-label Manager Rating
                  = af.select :manager_rating, aspiration_rating_options, { include_blank: 'Select rating', selected: @open_check_in.manager_rating }, { class: "form-select" }
              .col-md-6
                .mb-3
                  %label.form-label Manager Notes
                  = af.text_area :manager_private_notes, rows: 3, class: "form-control", placeholder: "Notes..."
          = af.hidden_field :aspiration_id, value: @aspiration.id
          .row
            = render "shared/single_item_check_in/form_save_actions",
              form: form,
              fields_builder: af,
              check_in: @open_check_in,
              teammate: @teammate,
              organization: @organization,
              is_complete: is_complete,
              next_requires_check_in: @single_item_next_requires_check_in,
              next_item: @single_item_next_item,
              next_url: @single_item_next_url,
              show_check_in_status_done: @single_item_show_check_in_status_done

  = render "organizations/teammates/aspirations/research_sections"
