- content_for :title, "Aspirations - #{@teammate.person.display_name}"

- content_for :head do
  :css
    .aspiration-check-in-toggle .details-expanded { display: none; }
    .aspiration-check-in-toggle[aria-expanded="true"] .details-expanded { display: inline; }
    .aspiration-check-in-toggle[aria-expanded="true"] .details-collapsed { display: none; }

- content_for :go_back_link do
  = link_to organization_company_teammate_check_ins_path(@organization, @teammate), class: "go-back-link" do
    %i.bi.bi-arrow-left.me-2
    Back to Check-ins

.row.mb-3
  .col-12
    = render "shared/single_item_check_in/header_switcher"

.row.justify-content-center
  .col-lg-12
    / Aspiration Details Section
    .card.mb-4
      .card-header
        %h2.mb-0 #{@aspiration.name}
      .card-body
        - if @aspiration.description.present?
          .markdown-content.mb-0= render_markdown(@aspiration.description)

    / Open check-in form (above All Check-ins)
    - if @open_check_in
      .card.mb-4
        .card-header
          %h5.mb-0 Current Check-in
        .card-body
          = form_with url: organization_company_teammate_check_ins_path(@organization, @teammate), method: :patch, scope: :check_ins, local: true do |form|
            = form.hidden_field :current_url, value: organization_teammate_aspiration_path(@organization, @teammate, @aspiration), id: nil
            = form.hidden_field :current_type, value: "aspiration", id: nil
            = form.hidden_field :current_id, value: @aspiration.id, id: nil
            = form.fields_for :aspiration_check_ins, @open_check_in, index: @open_check_in.id do |af|
              - if current_person == @teammate.person
                .row
                  .col-md-6
                    .mb-3
                      %label.form-label My Rating
                      = af.select :employee_rating, aspiration_rating_options, { include_blank: 'Select rating', selected: @open_check_in.employee_rating }, { class: "form-select" }
                  .col-md-6
                    .mb-3
                      %label.form-label Private Notes
                      = af.text_area :employee_private_notes, rows: 3, class: "form-control", placeholder: "Notes..."
              - if current_person != @teammate.person
                .row
                  .col-md-6
                    .mb-3
                      %label.form-label Manager Rating
                      = af.select :manager_rating, aspiration_rating_options, { include_blank: 'Select rating', selected: @open_check_in.manager_rating }, { class: "form-select" }
                  .col-md-6
                    .mb-3
                      %label.form-label Manager Notes
                      = af.text_area :manager_private_notes, rows: 3, class: "form-control", placeholder: "Notes..."
              = af.hidden_field :aspiration_id, value: @aspiration.id
              .row
                .col-12
                  .mb-3
                    - is_complete = (current_person == @teammate.person ? @open_check_in.employee_completed? : @open_check_in.manager_completed?)
                    .form-check
                      = af.radio_button :status, 'draft', checked: !is_complete, class: 'form-check-input'
                      = af.label :status_draft, 'Draft', class: 'form-check-label'
                    .form-check
                      = af.radio_button :status, 'complete', checked: is_complete, class: 'form-check-input'
                      = af.label :status_complete, 'Ready for review', class: 'form-check-label'
                .col-12.mt-3
                  .d-flex.flex-wrap.gap-2
                    = form.submit "Save and stay here", name: "save_and_stay", class: "btn btn-primary"
                    - if @single_item_next_requires_check_in && @single_item_next_url.present?
                      = form.submit "Save and move to next", name: "save_and_go_to_next", class: "btn btn-outline-primary"
                    = link_to "Cancel", organization_company_teammate_check_ins_path(@organization, @teammate), class: "btn btn-outline-secondary"
                  .d-flex.flex-wrap.gap-2.mt-2
                    - if @single_item_next_requires_check_in && @single_item_next_url.present?
                      = form.submit "Save and go to Bulk Check-in", name: "save_and_go_to_bulk_check_in", class: "btn btn-sm btn-link text-secondary text-decoration-none p-0"
                    = form.submit "Save and go to Review Check-ins", name: "save_and_go_to_review_check_ins", class: "btn btn-sm btn-link text-secondary text-decoration-none p-0"

    / Check-in History Table
    .card.mb-4
      .card-header
        %h5.mb-0 All Check-ins
        %small.text-muted Complete history of check-ins for this aspiration
      .card-body
        - if @check_ins.any?
          .table-responsive
            %table.table.table-hover
              %thead.table-light
                %tr
                  %th Started
                  %th Employee Completion
                  %th Manager Completion
                  %th Finalization
                  %th Status
                  %th Actions
              %tbody
                - latest_finalized_at = @latest_finalized&.official_check_in_completed_at
                - @check_ins.each do |check_in|
                  - both_complete = check_in.employee_completed? && check_in.manager_completed?
                  - open_both_incomplete = check_in.open? && !both_complete
                  %tr{class: check_in.officially_completed? ? 'table-success' : check_in.ready_for_finalization? ? 'table-warning' : ''}
                    %td
                      Started: #{check_in.check_in_started_on.strftime('%B %d, %Y')}
                      %br
                      - if check_in.officially_completed?
                        Reviewed: #{format_time_in_user_timezone(check_in.official_check_in_completed_at, format: '%B %d, %Y')}
                    %td
                      - if check_in.employee_completed?
                        - if !both_complete
                          %span.badge.bg-success.me-1 ✓ Complete
                          %br
                        - if both_complete
                          %small.text-muted= aspiration_rating_display(check_in.employee_rating)
                        - else
                          %small.text-muted Waiting for #{aspiration_check_in_waiting_for_name(check_in, @teammate)}
                        %br
                        %small.text-muted= format_time_in_user_timezone(check_in.employee_completed_at, format: '%m/%d/%Y %I:%M %p')
                      - else
                        %span.badge.bg-warning Pending
                    %td
                      - if check_in.manager_completed?
                        - if !both_complete
                          %span.badge.bg-success.me-1 ✓ Complete
                          %br
                        - if both_complete
                          %small.text-muted= aspiration_rating_display(check_in.manager_rating)
                          %br
                        %small.text-muted= format_time_in_user_timezone(check_in.manager_completed_at, format: '%m/%d/%Y %I:%M %p')
                        - if check_in.manager_completed_by_teammate
                          %br
                          %small.text-muted by #{check_in.manager_completed_by_teammate.person.display_name}
                        - if !both_complete
                          %br
                          %small.text-muted Waiting for #{aspiration_check_in_waiting_for_name(check_in, @teammate)}
                      - else
                        %span.badge.bg-warning Pending
                    %td
                      - if check_in.officially_completed?
                        %small.text-muted= aspiration_rating_display(check_in.official_rating)
                        %br
                        %small.text-muted= format_time_in_user_timezone(check_in.official_check_in_completed_at, format: '%m/%d/%Y %I:%M %p')
                        - if check_in.finalized_by_teammate
                          %br
                          %small.text-muted by #{check_in.finalized_by_teammate.person.display_name}
                      - elsif check_in.ready_for_finalization?
                        %span.badge.bg-warning Ready for Finalization
                      - else
                        %span.badge.bg-secondary In Progress
                    - if open_both_incomplete
                      %td{colspan: 2}= aspiration_check_in_status_label(check_in, latest_finalized_at, @teammate)
                    - else
                      %td
                        = aspiration_check_in_status_label(check_in, latest_finalized_at, @teammate)
                      %td
                        - if both_complete && check_in.officially_completed?
                          %a.btn.btn-sm.btn-outline-primary.aspiration-check-in-toggle{"aria-expanded" => "false", "aria-controls" => "check_in_details_#{check_in.id}", "data-bs-toggle" => "collapse", "data-bs-target" => "#check_in_details_#{check_in.id}", href: "#check_in_details_#{check_in.id}", role: "button"}
                            %span.details-collapsed
                              %i.bi.bi-chevron-down.me-1
                              Show details
                            %span.details-expanded
                              %i.bi.bi-chevron-up.me-1
                              Hide details
                        - elsif check_in.ready_for_finalization?
                          = link_to "Review", organization_company_teammate_finalization_path(@organization, @teammate), class: "btn btn-sm btn-warning"
                        - else
                          = link_to "Continue", organization_company_teammate_check_ins_path(@organization, @teammate), class: "btn btn-sm btn-primary"
                  - if both_complete && check_in.officially_completed?
                    %tr.collapse{id: "check_in_details_#{check_in.id}"}
                      %td.text-muted.small{colspan: 6, style: "background: var(--bs-table-bg);"}
                        = render "shared/check_in_finalized_sentences", check_in: check_in, employee_name: @teammate.person.casual_name, sentence_type: :aspiration
        - else
          .alert.alert-info.text-center
            %h6.mb-2
              %i.bi.bi-info-circle.me-2
              No Check-ins Found
            %p.mb-0 No check-ins have been created for this aspiration yet.
            = link_to "Start First Check-in", organization_company_teammate_check_ins_path(@organization, @teammate), class: "btn btn-primary btn-sm mt-2"


    = render "shared/single_item_check_in/current_period_observations"


