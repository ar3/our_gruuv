-# Locals: organization, teammate, assignment_title, employee_name (optional)
- organization = local_assigns.fetch(:organization)
- teammate = local_assigns.fetch(:teammate)
- assignment_title = local_assigns.fetch(:assignment_title)
- employee_name = local_assigns[:employee_name].presence || teammate.person.casual_name

.alert.alert-light.border.mb-0
  %h3.fw-semibold.mb-2 Goal of this page
  %p.mb-3
    Complete a clarity check-in for
    %strong= assignment_title
    —how #{employee_name} is doing on this assignment and how its energy fits the full role.

  %h3.fw-semibold.mb-2 Context
  = render 'shared/maap/definition'
  = render 'shared/check_ins/three_step_clarity_flow', organization: organization, teammate: teammate, employee_name: employee_name

  %h3.fw-semibold.mb-2 Specifics of this page
  %h5.fw-semibold.mb-2 One assignment at a time
  %p.mb-2
    Still Step One (
    = link_to 'Reflect Apart', organization_company_teammate_check_ins_path(organization, teammate)
    ). Use assignment details and research for context, then check in in
    %strong Your check-in
    (energy bars show role-wide split; link below the bars opens bulk check-in for several assignments).
  %h5.fw-semibold.mb-2 Sections on this page
  %ul.mb-0
    %li
      %strong Assignment details
      — outcomes, abilities, links.
    %li
      %strong Your check-in
      — ratings, energy reflection, notes.
    %li
      %strong Research
      — tenure, history, observations.
