%section#research.mb-5
  %h2.h4.mb-4 Context for your rating

  - if @check_ins.present?
    %section#research-prior-check-ins.mb-4
      = render "shared/single_item_check_in/prior_check_ins_table", check_ins: @check_ins, sentence_type: :position, employee_name: @teammate.person.casual_name

  %section#research-observations.mb-4
    = render "shared/single_item_check_in/current_period_observations"

  %section#research-assignment-ratings.mb-4
    .card
      .card-header
        %h5.mb-0 Research: Latest Finalized Assignment Ratings
      .card-body
        = render 'organizations/company_teammates/my_growth/experiences_summary',
          summary: @my_growth_experiences_summary,
          teammate: @teammate,
          organization: @organization,
          chart_id_prefix: 'position-check-in-experiences',
          show_divider: false
        %p.text-muted.mb-0.mt-3
          In order to have this up-to-date, finalize all assignment check-ins and come back to this page.

        .mt-3
          = render 'shared/og_tips/callout',
            tip_id: 'og-tip-position-assignment-energy-ratings',
            title: 'OG pro tip',
            tone: :loud,
            expanded: true,
            collapsible: false,
            body: og_tip_position_assignment_energy_rating_body(summary: @my_growth_experiences_summary)
