- content_for :title, "Edit eligibility defaults — minor #{@minor} — #{@organization.display_name}"
- content_for :header, "Edit eligibility defaults (minor #{@minor})"

- content_for :go_back_link do
  = link_to organization_position_eligibility_defaults_path(@organization), class: "go-back-link" do
    %i.bi.bi-arrow-left.me-2
    Back to summary

.card
  .card-header
    %h5.mb-0 Organization: #{@organization.display_name} — minor #{@minor}
  .card-body
    = render 'organizations/positions/eligibility_requirements_form',
      eligibility: @eligibility_data,
      minimum_mileage_from_assignments: @minimum_mileage_from_assignments,
      mileage_id_suffix: @mileage_id_suffix,
      form_url: update_minor_organization_position_eligibility_defaults_path(@organization, minor: @minor),
      cancel_path: organization_position_eligibility_defaults_path(@organization),
      http_method: :patch,
      submit_label: 'Save defaults'
