- content_for :title, "Position eligibility defaults — #{@organization.display_name}"
- content_for :header, "Position eligibility defaults"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Position eligibility defaults", url: nil }])

- can_maap = policy(@organization).manage_maap?

.card.mb-4
  .card-body
    %p.text-muted.mb-0
      Defaults apply by title minor level (1, 2, or 3). Positions inherit unless they override.

- @minor_rows.each do |row|
  .row.mb-4
    .col-lg-8
      = render 'organizations/position_eligibility_defaults/minor_requirement_summary_card',
        header_title: PositionEligibilityMinorLevels.card_header_title(row[:minor]),
        header_caption: PositionEligibilityMinorLevels.header_caption_within_title(row[:minor]),
        requirement: row[:requirement],
        missing_text: 'Not linked'
    .col-lg-4
      .d-grid.gap-2
        - if can_maap
          = link_to edit_minor_organization_position_eligibility_defaults_path(@organization, minor: row[:minor]), class: 'btn btn-primary' do
            %i.bi.bi-pencil.me-1
            Edit
        - else
          .d-flex.align-items-center.gap-2
            .flex-grow-1
              = link_to edit_minor_organization_position_eligibility_defaults_path(@organization, minor: row[:minor]), class: 'btn btn-secondary w-100 disabled', tabindex: -1, aria: { disabled: true } do
                %i.bi.bi-pencil.me-1
                Edit
            %i.bi.bi-exclamation-triangle.text-warning{ data: { bs_toggle: 'tooltip', bs_placement: 'left' }, title: 'Requires MAAP management permission (can_manage_maap).' }
