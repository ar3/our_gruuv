- content_for :title, "Job Description - #{@position.display_name}"

- content_for :header do
  %h1.mb-0= @position.display_name

- content_for :header_action do
  = render 'view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Positions", url: organization_positions_path(@organization) }, { label: "#{@position.display_name} — job description", url: nil }])

= render 'job_description_summary', position: @position

= render 'job_description_required_assignments', position: @position, organization: @position.company

= render 'job_description_suggested_assignments', position: @position, organization: @position.company

= render 'job_description_direct_milestones', position: @position, organization: @position.company

= render 'job_description_no_assignments', position: @position, organization: @position.company

= render 'job_description_footer'
