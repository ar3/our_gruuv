- content_for :title, @position.display_name

- content_for :header do
  %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
    = render 'position_switcher', position: @position, organization: @organization, positions_by_department: @positions_by_department

- content_for :header_action do
  = render 'view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Positions", url: organization_positions_path(@organization) }, { label: @position.title.display_name, url: organization_title_path(@organization, @position.title) }, { label: @position.position_level.level, url: nil }])

- if @position.archived?
  .alert.alert-warning.alert-dismissible.fade.show.mb-4{ role: "alert" }
    %h5.alert-heading
      %i.bi.bi-archive.me-2
      Archived as of #{l(@position.deleted_at, format: :long)}
    %p.mb-0 This position is archived. It no longer appears in lists or selectors but remains viewable and its data is preserved.

.row.justify-content-center
  .col-12
    = render 'show_content'
