- content_for :title, "Manage Eligibility Requirements for #{@position.display_name}"
- content_for :header, "Manage Eligibility Requirements for #{@position.display_name}"

- content_for :go_back_link do
  = link_to organization_position_path(@organization, @position), class: "go-back-link" do
    %i.bi.bi-arrow-left.me-2
    Back to Position

.card
  .card-header
    %h5.mb-0
      %i.bi.bi-check2-circle.me-2
      Eligibility Requirements Configuration
    %p.mb-0.text-muted
      Configure eligibility requirements for this position. Leave fields blank to remove requirements.
    - if @eligibility_config_source.present?
      %p.mb-0.mt-2
        %span.text-muted Effective defaults are currently from:
        %span.fw-semibold= @eligibility_config_source.to_s.humanize
  .card-body
    = render 'organizations/positions/eligibility_requirements_form',
      eligibility: @eligibility_data || {},
      minimum_mileage_from_assignments: @minimum_mileage_from_assignments,
      mileage_id_suffix: '',
      form_url: update_eligibility_organization_position_path(@organization, @position),
      cancel_path: organization_position_path(@organization, @position),
      http_method: :patch,
      submit_label: 'Save Eligibility Requirements'
