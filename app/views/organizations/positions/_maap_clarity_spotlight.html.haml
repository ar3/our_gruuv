- run = @position_clarity_run
.card.border.mb-4
  .card-header.bg-light
    %h6.mb-0.text-uppercase.text-muted
      %i.bi.bi-stars.me-2
      MAAP clarity signal
  .card-body.py-3
    - if run.blank?
      %p.small.mb-0.text-muted
        %i.bi.bi-dash-circle.me-1
        No clarity review yet.
        - if policy(@position).run_clarity?
          = link_to 'Run review', maap_clarity_organization_position_path(@organization, @position), class: 'ms-1 text-decoration-none'
    - elsif run.status.in?(%w[pending processing])
      %p.small.mb-0
        %span.badge.text-bg-secondary.me-1
          %i.bi.bi-hourglass-split.me-1
          In progress
        %span.text-muted Review running…
        = link_to 'Open', maap_clarity_organization_position_path(@organization, @position), class: 'ms-1 small text-decoration-none'
    - elsif run.status == 'failed'
      %p.small.mb-0
        %span.badge.text-bg-danger.me-1 Failed
        %span.text-muted.truncate.d-inline-block.align-bottom{ style: 'max-width: 12rem;', title: run.error_message }= run.error_message.presence || 'Error'
        = link_to 'Details', maap_clarity_organization_position_path(@organization, @position), class: 'ms-1 small text-decoration-none'
    - else
      - case run.clarity_rating
      - when 'green'
        %p.small.mb-0
          %span.badge.text-bg-success Green
          %span.text-muted — strongest clarity
      - when 'yellow'
        %p.small.mb-0
          %span.badge.text-bg-warning.text-dark Yellow
          %span.text-muted — needs attention
      - when 'red'
        %p.small.mb-0
          %span.badge.text-bg-danger Red
          %span.text-muted — weakest clarity
      - else
        %p.small.mb-0
          %span.badge.text-bg-secondary Unknown
          %span.text-muted — no parsed signal
      - if run.updated_at
        %p.small.text-muted.mb-0.mt-1
          As of #{l(run.updated_at, format: :short)}
      %p.small.mb-0
        = link_to maap_clarity_organization_position_path(@organization, @position), class: 'text-decoration-none' do
          %i.bi.bi-stars.me-1
          View full clarity review
