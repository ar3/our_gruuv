- content_for :title, @ability.name

- content_for :header do
  = render 'shared/header', 
    header_name: content_tag(:i, '', class: 'bi bi-lightning me-2') + @ability.name,
    header_quick_action_url: edit_organization_ability_path(@organization, @ability),
    header_quick_action_content: content_tag(:i, '', class: 'bi bi-pencil me-2'),
    header_quick_action_is_enabled: policy(@ability).update?,
    header_quick_action_disabled_tooltip: "You need MAAP management permissions for this organization to edit abilities"
      
- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Abilities", url: organization_abilities_path(@organization) }, { label: @ability.name, url: nil }])

- content_for :header_action do
  = render 'mode_switcher'

- if @ability.archived?
  .alert.alert-warning.alert-dismissible.fade.show.mb-4{ role: "alert" }
    %h5.alert-heading
      %i.bi.bi-archive.me-2
      Archived as of #{l(@ability.deleted_at, format: :long)}
    %p.mb-0 This ability is archived. It no longer appears in lists or selectors but remains viewable and its data (milestones, ratings, etc.) is preserved.

.row
  .col-md-8
    .card.mb-4{ role: "region", "aria-labelledby": "ability-details" }
      .card-header
        %h5.mb-0{ id: "ability-details" }
          %i.bi.bi-info-circle.me-2
          Ability Details
      .card-body
        %dl.row
          %dt.col-sm-3 Name:
          %dd.col-sm-9= @ability.name
          %dt.col-sm-3 Department:
          %dd.col-sm-9
            - if @ability.department
              = link_to @ability.department.display_name, organization_department_path(@organization, @ability.department), class: "text-decoration-none"
            - else
              %em.text-muted Company-level
          %dt.col-sm-3 Description:
          %dd.col-sm-9
            - if @ability.description.present?
              .markdown-content= render_markdown(@ability.description)
            - else
              %em.text-muted No description provided

    .card.mb-4{ role: "region", "aria-labelledby": "milestone-descriptions" }
      .card-header
        %h5.mb-0{ id: "milestone-descriptions" }
          %i.bi.bi-list-ol.me-2
          Milestone Descriptions
      .card-body
        - (1..5).each do |level|
          - description = @ability.send("milestone_#{level}_description")
          - if description.present?
            .mb-3
              %h6.text-primary Milestone #{level}
              .markdown-content.markdown-content--bordered= render_markdown(description)
        - if (1..5).all? { |level| @ability.send("milestone_#{level}_description").blank? }
          %em.text-muted No milestone descriptions provided

  .col-md-4
    - created_name, created_at = ability_audit_created_meta(@ability)
    - updated_name, updated_at = ability_audit_last_updated_meta(@ability)
    .card.mb-4
      .card-header
        %h6.mb-0
          %i.bi.bi-star.me-2
          Spotlight
      .card-body
        .mb-3
          .d-flex.justify-content-between
            %span Version:
            %strong= @ability.semantic_version

        .mb-3
          %h6.text-muted.small.mb-2 Interesting Tidbits
          - if @ability.description.present?
            %p.small
              %i.bi.bi-check-circle.text-success.me-1
              Has detailed description
          - else
            %p.small
              %i.bi.bi-exclamation-circle.text-warning.me-1
              Missing description
          
          - milestone_count = (1..5).count { |level| @ability.send("milestone_#{level}_description").present? }
          %p.small
            %i.bi.bi-list-ol.text-info.me-1
            #{milestone_count} of 5 milestones defined
          
          %p.small
            = link_to organization_ability_path(@organization, @ability, anchor: 'assignments-requiring-this-ability'), class: 'text-decoration-underline text-body' do
              - if @ability.is_required_by_assignments?
                - ac = @ability.required_by_assignments_count
                %i.bi.bi-clipboard-check.text-primary.me-1
                Required by #{ac} #{'assignment'.pluralize(ac)}
              - else
                %i.bi.bi-clipboard.text-muted.me-1
                Not required by any assignments
          %p.small
            = link_to organization_ability_path(@organization, @ability, anchor: 'positions-requiring-this-ability'), class: 'text-decoration-underline text-body' do
              - if @ability.is_required_by_positions?
                - pc = @ability.required_by_positions_count
                %i.bi.bi-briefcase.text-primary.me-1
                Required by #{pc} #{'position'.pluralize(pc)}
              - else
                %i.bi.bi-briefcase.text-muted.me-1
                Not required by any positions
          %p.small
            = link_to organization_ability_path(@organization, @ability, anchor: 'teammate-milestones-for-this-ability'), class: 'text-decoration-underline text-body' do
              - if @teammate_milestone_rows.any?
                - tc = @teammate_milestone_rows.size
                %i.bi.bi-people.text-success.me-1
                - if tc == 1
                  1 person has earned a milestone for this ability
                - else
                  #{tc} people have earned milestones for this ability
              - else
                %i.bi.bi-person.text-muted.me-1
                No milestone attainments yet

        .mb-3
          %h6.text-muted.small.mb-2 MAAP clarity signal
          - run = @ability_clarity_run
          - if run.blank?
            %p.small.mb-0.text-muted
              %i.bi.bi-dash-circle.me-1
              No clarity review yet.
              - if policy(@ability).run_clarity?
                = link_to 'Run review', maap_clarity_organization_ability_path(@organization, @ability), class: 'ms-1 text-decoration-none'
          - elsif run.status.in?(%w[pending processing])
            %p.small.mb-0
              %span.badge.text-bg-secondary.me-1
                %i.bi.bi-hourglass-split.me-1
                In progress
              %span.text-muted Review running…
              = link_to 'Open', maap_clarity_organization_ability_path(@organization, @ability), class: 'ms-1 small text-decoration-none'
          - elsif run.status == 'failed'
            %p.small.mb-0
              %span.badge.text-bg-danger.me-1 Failed
              %span.text-muted.truncate.d-inline-block.align-bottom{ style: 'max-width: 12rem;', title: run.error_message }= run.error_message.presence || 'Error'
              = link_to 'Details', maap_clarity_organization_ability_path(@organization, @ability), class: 'ms-1 small text-decoration-none'
          - else
            - case run.clarity_rating
            - when 'green'
              %p.small.mb-0
                %span.badge.text-bg-success Green
                %span.text-muted — strongest clarity
            - when 'yellow'
              %p.small.mb-0
                %span.badge.text-bg-warning.text-dark Yellow
                %span.text-muted — needs attention
            - when 'red'
              %p.small.mb-0
                %span.badge.text-bg-danger Red
                %span.text-muted — weakest clarity
            - else
              %p.small.mb-0
                %span.badge.text-bg-secondary Unknown
                %span.text-muted — no parsed signal
            - if run.updated_at
              %p.small.text-muted.mb-0.mt-1
                As of #{l(run.updated_at, format: :short)}
            %p.small.mb-0
              = link_to maap_clarity_organization_ability_path(@organization, @ability), class: 'text-decoration-none' do
                %i.bi.bi-stars.me-1
                View full clarity review

        %hr.mt-3.mb-2
        %small.text-muted.d-block
          Created by #{created_name} on #{format_time_in_user_timezone(created_at)}
          %br
          Last updated by #{updated_name} on #{format_time_in_user_timezone(updated_at)}
          %br
          = link_to organization_paper_trail_path(@organization, item_type: 'Ability', item_id: @ability.id), class: 'text-decoration-none' do
            %i.bi.bi-clock-history.me-1
            View full change history

    .card.mb-4
      .card-header
        %h6.mb-0
          %i.bi.bi-lightning-charge.me-2
          Actions
      .card-body

        / Edit mode
        - if policy(@ability).update?
          = link_to edit_organization_ability_path(@organization, @ability), class: "btn btn-outline-primary btn-sm w-100 mb-2" do
            %i.bi.bi-pencil.me-2
            Edit mode
        - else
          .d-flex.align-items-center.gap-2.mb-2
            .flex-grow-1
              %button.btn.btn-outline-secondary.btn-sm.w-100.disabled{type: "button", disabled: true}
                %i.bi.bi-pencil.me-2
                Edit mode
            %i.bi.bi-exclamation-triangle.text-warning{data: {bs_toggle: "tooltip", bs_title: "You need MAAP management permissions for this organization to edit abilities"}}

        / Public MAAP version
        = link_to organization_public_maap_ability_path(@organization, @ability), class: "btn btn-outline-primary btn-sm w-100 mb-2" do
          %i.bi.bi-globe.me-2
          Public version

        / MAAP clarity review (LLM)
        - if policy(@ability).run_clarity?
          = link_to maap_clarity_organization_ability_path(@organization, @ability), class: "btn btn-outline-primary btn-sm w-100 mb-2" do
            %i.bi.bi-stars.me-2
            Clarity review
        - else
          .d-flex.align-items-center.gap-2.mb-2
            .flex-grow-1
              %button.btn.btn-outline-secondary.btn-sm.w-100.disabled{type: "button", disabled: true}
                %i.bi.bi-stars.me-2
                Clarity review
            %i.bi.bi-exclamation-triangle.text-warning{data: {bs_toggle: "tooltip", bs_title: "You need MAAP management permissions to run clarity review"}}

        / Manage assignment milestones
        - if policy(@ability).update?
          = link_to organization_ability_assignment_milestones_path(@organization, @ability), class: "btn btn-outline-primary btn-sm w-100 mb-2" do
            %i.bi.bi-link-45deg.me-2
            Manage assignment milestones
        - else
          .d-flex.align-items-center.gap-2.mb-2
            .flex-grow-1
              %button.btn.btn-outline-secondary.btn-sm.w-100.disabled{type: "button", disabled: true}
                %i.bi.bi-link-45deg.me-2
                Manage assignment milestones
            %i.bi.bi-exclamation-triangle.text-warning{data: {bs_toggle: "tooltip", bs_title: "You need MAAP management permissions to manage assignment milestones"}}

        / Archive or restore
        - if @ability.archived?
          - if policy(@ability).restore?
            = link_to restore_organization_ability_path(@organization, @ability), class: "btn btn-outline-primary btn-sm w-100", data: { turbo_method: :patch, turbo_confirm: "Restore this ability? It will appear in lists and selectors again." } do
              %i.bi.bi-arrow-counterclockwise.me-2
              Restore ability
          - else
            .d-flex.align-items-center.gap-2
              .flex-grow-1
                %button.btn.btn-outline-secondary.btn-sm.w-100.disabled{type: "button", disabled: true}
                  %i.bi.bi-arrow-counterclockwise.me-2
                  Restore ability
              %i.bi.bi-exclamation-triangle.text-warning{data: {bs_toggle: "tooltip", bs_title: "You need MAAP management permissions to restore this ability"}}
        - elsif policy(@ability).archive?
          = link_to archive_organization_ability_path(@organization, @ability), class: "btn btn-outline-primary btn-sm w-100" do
            %i.bi.bi-archive.me-2
            Archive ability
        - else
          .d-flex.align-items-center.gap-2
            .flex-grow-1
              %button.btn.btn-outline-secondary.btn-sm.w-100.disabled{type: "button", disabled: true}
                %i.bi.bi-archive.me-2
                Archive ability
            %i.bi.bi-exclamation-triangle.text-warning{data: {bs_toggle: "tooltip", bs_title: "You need MAAP management permissions to archive this ability"}}

    / Comments Section
    = render 'shared/comment_summary', commentable: @ability, organization: @organization


.row
  .col-12

    .card.mb-4{ role: "region", "aria-labelledby": "assignments-heading", id: "assignments-requiring-this-ability" }
      .card-header
        %h5.mb-0{ id: "assignments-heading" }
          %i.bi.bi-clipboard-check.me-2
          Assignments Requiring This Ability
      .card-body
        - @ability.required_by_assignments.each_with_index do |assignment_ability, index|
          - if index > 0
            %hr
          .mb-3
            = link_to organization_assignment_path(assignment_ability.assignment.company, assignment_ability.assignment), class: "text-decoration-none" do
              %h6.mb-1= assignment_ability.assignment.title
            %p.mb-0.text-muted.small
              Required milestone level: #{milestone_level_display(assignment_ability.milestone_level)} (M#{assignment_ability.milestone_level})

    .card.mb-4{ role: "region", "aria-labelledby": "positions-heading", id: "positions-requiring-this-ability" }
      .card-header
        %h5.mb-0{ id: "positions-heading" }
          %i.bi.bi-briefcase.me-2
          Positions Requiring This Ability
      .card-body
        - if @ability.required_by_positions.any?
          - @ability.required_by_positions.each_with_index do |position_ability, index|
            - if index > 0
              %hr
            .mb-3
              = link_to organization_position_path(position_ability.position.company, position_ability.position), class: "text-decoration-none" do
                %h6.mb-1= position_ability.position.display_name
              %p.mb-0.text-muted.small
                Required milestone level: #{milestone_level_display(position_ability.milestone_level)} (M#{position_ability.milestone_level})
        - else
          .alert.alert-info.mb-0{ role: "alert" }
            %i.bi.bi-info-circle.me-2
            No positions require this ability.

    .card.mb-4{ role: "region", "aria-labelledby": "teammate-milestones-heading", id: "teammate-milestones-for-this-ability" }
      .card-header
        %h5.mb-0{ id: "teammate-milestones-heading" }
          %i.bi.bi-people.me-2
          Teammates with milestone attainments
      .card-body
        - if @teammate_milestone_rows.any?
          .table-responsive
            %table.table.table-hover.mb-0
              %thead
                %tr
                  %th Teammate
                  %th Milestone
                  %th.text-nowrap Attained
              %tbody
                - @teammate_milestone_rows.each do |tm|
                  - ct = tm.company_teammate
                  - lvl = tm.milestone_level
                  %tr
                    %td
                      = link_to internal_organization_company_teammate_path(ct.organization, ct), class: "text-decoration-none fw-semibold" do
                        = ct.person.casual_name
                    %td
                      #{milestone_level_display(lvl)} (M#{lvl})
                    %td.text-muted.small= l(tm.attained_at, format: :long)
        - else
          .alert.alert-info.mb-0{ role: "alert" }
            %i.bi.bi-info-circle.me-2
            No teammates have earned a milestone for this ability yet.
            = link_to "Celebrate milestones", celebrate_milestones_organization_path(@organization), class: "alert-link fw-semibold ms-1"
.row.mt-2
  .col-12
    = render "shared/public_kudos_for_rateable_card",
      organization: @organization,
      public_kudos: @public_kudos_for_rateable,
      rateable_display_name: @public_kudos_rateable_display_name,
      all_kudos_url: @public_kudos_all_kudos_observations_url,
      all_types_url: @public_kudos_all_types_observations_url

= render "organizations/shared/teammate_lens_catalog_cta",
    organization: @organization,
    associable: @ability,
    viewing_person: current_person
