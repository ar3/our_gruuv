- content_for :header do
  %h1 Eligibility Requirements

- content_for :go_back_link do
  = link_to "Back to Eligibility Selection", organization_eligibility_requirements_path(@organization), class: "btn btn-outline-secondary btn-sm"

%style
  :plain
    .eligibility-section-header .collapse-detail-label { display: none !important; }
    .eligibility-section-header .expand-detail-label { display: inline-flex !important; }
    .eligibility-section-header[aria-expanded="true"] .expand-detail-label { display: none !important; }
    .eligibility-section-header[aria-expanded="true"] .collapse-detail-label { display: inline-flex !important; }

.row.mb-4
  .col-12
    %h2.mb-0
      In order for
      = link_to (@teammate.person.casual_name.presence || "this teammate"), internal_organization_company_teammate_path(@organization, @teammate), class: "text-decoration-none"
      to be eligible for consideration of
      = link_to @position.display_name, organization_position_path(@organization, @position), class: "text-decoration-none"
      …

.row.mb-4
  .col-12
    - overall_class = @eligibility_report[:overall_eligible] ? "bg-success" : "bg-warning"
    .alert.text-dark{class: overall_class}
      %strong Overall Eligibility:
      = @eligibility_report[:overall_eligible] ? "Meeting requirements" : "Working to meet requirements"

.row.mb-4
  .col-12
    .card
      .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section1Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
        %h3.mb-0 (1) Your managerial hierarchy must be advocates…
        .d-flex.align-items-center.small.text-muted
          %span.expand-detail-label.d-inline-flex.align-items-center
            Expand for details
            %i.bi.bi-chevron-down.ms-1
          %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
            Show less detail
            %i.bi.bi-chevron-up.ms-1
      .card-body.collapse.py-2{ id: "section1Body" }
        .alert.alert-info.mb-0
          OurGruuv tries to make eligibility as clear as possible. However, we can never remove the human and subjective aspect of navigating seat changes within an organization. If your managerial hierarchy is not an advocate of yours, there should be a conversation and a clear understanding of why that is.
      .card-footer.bg-info.bg-opacity-10.py-2
        Clarity between
        - @managerial_hierarchy_for_display.each_with_index do |entry, idx|
          - ct = entry[:company_teammate]
          - next unless ct
          - name = ct.person.casual_name.presence || ct.person.display_name
          = link_to name, internal_organization_company_teammate_path(@organization, ct), class: "text-decoration-none"
          - if idx < @managerial_hierarchy_for_display.size - 1
            %span.me-1 ,

.row.mb-4
  .col-12
    .card
      .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section2Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
        %h3.mb-0 (2) There has to be a business need…
        .d-flex.align-items-center.small.text-muted
          %span.expand-detail-label.d-inline-flex.align-items-center
            Expand for details
            %i.bi.bi-chevron-down.ms-1
          %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
            Show less detail
            %i.bi.bi-chevron-up.ms-1
      .card-body.collapse.py-2{ id: "section2Body" }
        .alert.alert-info.mb-0
          We check whether the position has a seat that is either open or filled by you. If not, there is no business need for someone to take on that position, and you should talk to your manager about other title-growth paths. There are other ways to grow: Experience (taking on Assignments that help with your professional goals) and Acknowledgement of Skills/Knowledge (by demonstrating and then getting certified in Milestones).
        - if @seats_for_position.any?
          %p.small.fw-semibold.mt-3.mb-1 Open or filled seats associated with this position
          %ul.small.mb-0
            - @seats_for_position.each do |seat|
              %li= "#{seat.display_name} — #{seat.state}"
        - else
          %p.small.text-muted.mb-0 No open or filled seats are currently associated with this position's title.
      .card-footer.py-2{class: @business_need_eligible ? "bg-info bg-opacity-10" : "bg-warning bg-opacity-25"}
        - if @business_need_eligible
          Eligible
        - else
          Not eligible / no business need defined

.row.mb-4
  .col-12
    - company_asp_check = @eligibility_report[:checks].find { |c| c[:key] == :company_aspirational_values_check_in_requirements }
    - title_asp_check = @eligibility_report[:checks].find { |c| c[:key] == :title_department_aspirational_values_check_in_requirements }
    - company_asp_result = @company_aspirational_values_eligibility_result
    - title_asp_result = @title_department_aspirational_values_eligibility_result
    - asp_combined_eligible = company_asp_result&.summary&.overall_eligible && title_asp_result&.summary&.overall_eligible
    - asp_combined_maybe = [company_asp_result, title_asp_result].compact.any? { |r| r.summary&.meet_display_status == CheckInRequirementsEligibility::DisplayStatus::MAYBE_OK || r.summary&.exceed_display_status == CheckInRequirementsEligibility::DisplayStatus::MAYBE_OK }
    - asp_footer_bg = asp_combined_eligible ? "bg-success bg-opacity-25" : (asp_combined_maybe ? "bg-info bg-opacity-25" : "bg-warning bg-opacity-25")
    .card
      .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section3Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
        %h3.mb-0 (3) You must exemplify our Aspirational Values…
        .d-flex.align-items-center.small.text-muted
          %span.expand-detail-label.d-inline-flex.align-items-center
            Expand for details
            %i.bi.bi-chevron-down.ms-1
          %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
            Show less detail
            %i.bi.bi-chevron-up.ms-1
      .card-body.collapse.py-2{ id: "section3Body" }
        = render "organizations/eligibility_requirements/check_in_requirements_section",
          section_title: "Company Aspirational Values Check-In Requirements",
          requirement_sentence: (company_asp_check && company_asp_check[:details].present?) ? format_aspirational_values_requirement(company_asp_check[:details]) : nil,
          rows: @aspirational_values_table_rows.select { |r| r[:section] == 'company' }.map { |r| { name: r[:aspiration].name, id: r[:aspiration].id } },
          monthly_status_by_id: @aspirational_values_monthly_status,
          eligibility_result: company_asp_result,
          show_totals_in_body: false
        %div.mt-4
          = render "organizations/eligibility_requirements/check_in_requirements_section",
            section_title: "Title/Department Aspirational Values Check-In Requirements",
            requirement_sentence: (title_asp_check && title_asp_check[:details].present?) ? format_aspirational_values_requirement(title_asp_check[:details]) : nil,
            rows: @aspirational_values_table_rows.select { |r| r[:section] == 'title_department' }.map { |r| { name: r[:aspiration].name, id: r[:aspiration].id } },
            monthly_status_by_id: @aspirational_values_monthly_status,
            eligibility_result: title_asp_result,
            show_totals_in_body: false
      = render "organizations/eligibility_requirements/check_in_requirements_totals_footer",
        eligibility_result: company_asp_result,
        footer_bg_class: asp_footer_bg

.row.mb-4
  .col-12
    - required_check = @eligibility_report[:checks].find { |c| c[:key] == :required_assignment_check_in_requirements }
    .card
      .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section4Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
        %h3.mb-0 (4) You must pass criteria for Required Assignments…
        .d-flex.align-items-center.small.text-muted
          %span.expand-detail-label.d-inline-flex.align-items-center
            Expand for details
            %i.bi.bi-chevron-down.ms-1
          %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
            Show less detail
            %i.bi.bi-chevron-up.ms-1
      .card-body.collapse.py-2{ id: "section4Body" }
        = render "organizations/eligibility_requirements/check_in_requirements_section",
          section_title: "Required Assignment Check-In Requirements",
          requirement_sentence: (required_check && required_check[:details].present?) ? format_assignments_requirement(required_check[:details]) : nil,
          rows: @required_assignments.map { |a| { name: a.title, id: a.id } },
          monthly_status_by_id: @required_assignments_monthly_status,
          eligibility_result: @required_assignments_eligibility_result,
          show_totals_in_body: false
      = render "organizations/eligibility_requirements/check_in_requirements_totals_footer",
        eligibility_result: @required_assignments_eligibility_result

- if @unique_assignments.present?
  .row.mb-4
    .col-12
      - unique_check = @eligibility_report[:checks].find { |c| c[:key] == :unique_to_you_assignment_check_in_requirements }
      .card
        .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section5Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
          %h3.mb-0 (5) You must pass criteria for Unique-to-You Assignments (if there are any)…
          .d-flex.align-items-center.small.text-muted
            %span.expand-detail-label.d-inline-flex.align-items-center
              Expand for details
              %i.bi.bi-chevron-down.ms-1
            %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
              Show less detail
              %i.bi.bi-chevron-up.ms-1
        .card-body.collapse.py-2{ id: "section5Body" }
          = render "organizations/eligibility_requirements/check_in_requirements_section",
            section_title: "Unique-to-You Assignment Check-In Requirements",
            requirement_sentence: (unique_check && unique_check[:details].present?) ? format_assignments_requirement(unique_check[:details], assignment_label: "unique-to-you assignments") : nil,
            rows: @unique_assignments.map { |a| { name: a.title, id: a.id } },
            monthly_status_by_id: @unique_assignments_monthly_status || {},
            eligibility_result: @unique_assignments_eligibility_result,
            show_totals_in_body: false
        = render "organizations/eligibility_requirements/check_in_requirements_totals_footer",
          eligibility_result: @unique_assignments_eligibility_result

.row.mb-4
  .col-12
    - milestones_check = @eligibility_report[:checks].find { |c| c[:key] == :milestone_requirements }
    - milestone_passed = milestones_check.present? && milestones_check[:status] == :passed
    .card
      .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section6Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
        %h3.mb-0 (6) You must pass criteria for Required Milestones…
        .d-flex.align-items-center.small.text-muted
          %span.expand-detail-label.d-inline-flex.align-items-center
            Expand for details
            %i.bi.bi-chevron-down.ms-1
          %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
            Show less detail
            %i.bi.bi-chevron-up.ms-1
      .card-body.collapse.py-2{ id: "section6Body" }
        - if @milestone_table_rows.present?
          - casual_name = @teammate.person.casual_name.presence || "Teammate"
          %table.table.table-sm{ style: "table-layout: fixed; width: 100%;" }
            %thead
              %tr
                %th{ style: "width: 40%;" } Requirement
                %th{ style: "width: 30%;" }= "#{casual_name}'s earned Milestones"
                %th{ style: "width: 30%;" }
            %tbody
              - @milestone_table_rows.each do |row|
                %tr
                  %td
                    = link_to row[:ability].name, organization_ability_path(organization, row[:ability]), class: "text-decoration-none fw-semibold"
                    - row[:requirement_lines].each do |line|
                      %div.small.text-muted.mt-1
                        = "#{line[:source_name]} requires #{milestone_level_display(line[:milestone_level])} #{row[:ability].name} (Milestone #{line[:milestone_level]})."
                  %td
                    %span.d-inline-flex.gap-1.align-items-center{ role: "img", "aria-label": "Milestone levels 1–5: filled = earned" }
                      - (1..5).each do |level|
                        - filled = row[:attained_levels].include?(level)
                        - circle_class = filled ? "bg-success" : ""
                        - circle_style = filled ? "width: 20px; height: 20px; min-width: 20px;" : "width: 20px; height: 20px; min-width: 20px; background-color: #e9ecef;"
                        - tooltip_text = "#{milestone_level_display(level)} #{row[:ability].name} (Milestone #{level})#{filled ? ' · earned' : ''}"
                        %span.rounded-circle.d-inline-flex.align-items-center.justify-content-center{ class: circle_class, style: circle_style, data: { bs_toggle: "tooltip", bs_title: tooltip_text } }
                          - if filled
                            %i.bi.bi-check.text-white{ style: "font-size: 10px; line-height: 1;" }
                    - if row[:teammate_milestone]
                      %div.small.text-muted.mt-1
                        = "#{milestone_level_display(row[:teammate_milestone].milestone_level)} (Milestone #{row[:teammate_milestone].milestone_level})"
                        = " · "
                        = row[:teammate_milestone].attained_at.strftime("%B %d, %Y")
                    - elsif row[:attained_levels].empty?
                      %div.small.text-muted.mt-1 —
                  %td.align-middle
                    - if row[:passed]
                      %span.btn.btn-outline-success.btn-sm{ style: "pointer-events: none;" }
                        %i.bi.bi-check-circle-fill.me-1
                        Pass 🎉
                    - else
                      %span.btn.btn-outline-warning.btn-sm{ style: "pointer-events: none;" }
                        %i.bi.bi-tools.me-1
                        Working to meet
        - else
          %p.text-muted.mb-0 No milestone requirements configured for this position.
      .card-footer.fw-semibold.small.py-2{class: milestone_passed ? "bg-success bg-opacity-25" : "bg-warning bg-opacity-25"}
        .d-flex.align-items-center.justify-content-between.flex-wrap.gap-2
          - if @milestone_table_rows.present?
            - total_abilities = @milestone_table_rows.size
            - earned_count = @milestone_table_rows.count { |r| r[:passed] }
            - casual_name = @teammate.person.casual_name.presence || "Teammate"
            .me-2
              #{total_abilities} total Milestones needed across #{total_abilities} Abilities… and #{casual_name} has earned #{earned_count} of the requisite Milestones
          .align-middle
            - if milestone_passed
              %i.bi.bi-star-fill.text-success.fs-4.align-middle
              %span.ms-1 Meeting eligibility
            - else
              %i.bi.bi-tools.fs-4.align-middle
              %span.ms-1 Working to meet eligibility

- mileage_check = @eligibility_report[:checks].find { |check| check[:key] == :mileage_requirements }
- if mileage_check.present? && mileage_check[:status] != :not_configured
  .row.mb-4
    .col-12
      - earned = @mileage_earned_addends
      - required = @mileage_required_addends
      - minimum_miles = mileage_check.dig(:details, :minimum_mileage_points).to_i
      - required_total = required[:total]
      - remainder_miles = [minimum_miles - required_total, 0].max
      - mileage_passed = mileage_check[:status] == :passed
      .card
        .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section7Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
          %h3.mb-0 (7) You must meet the required Milestone Mileage…
          .d-flex.align-items-center.small.text-muted
            %span.expand-detail-label.d-inline-flex.align-items-center
              Expand for details
              %i.bi.bi-chevron-down.ms-1
            %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
              Show less detail
              %i.bi.bi-chevron-up.ms-1
        .card-body.collapse.py-2{ id: "section7Body" }
          %style
            .mileage-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
          .row.gy-2
            .col-6.mileage-column
              %p.small.text-muted.mb-2.fw-semibold= "What #{@teammate.person.casual_name.presence || 'teammate'} has earned"
              .d-flex.flex-column.gap-1.w-100
                - if earned[:addends].any?
                  - earned[:addends].each do |a|
                    = render partial: "organizations/eligibility_requirements/mileage_card",
                      locals: { display_label: "#{milestone_level_display(a[:level])} #{a[:ability_name]} – Milestone #{a[:level]}", points: a[:points], is_total: false }
                - else
                  .mileage-card.d-flex.align-items-center.px-2.py-1{ style: "min-height: 4rem; border: 1px solid #e9ecef; border-radius: 2px;" }
                    .small.text-muted No milestones earned yet
            .col-6.mileage-column.border-start.border-4{ style: "border-color: #dee2e6 !important;" }
              %p.small.text-muted.mb-2.fw-semibold What you need for this position
              .d-flex.flex-column.gap-1.w-100
                - if required[:addends].any?
                  - required[:addends].each do |a|
                    = render partial: "organizations/eligibility_requirements/mileage_card",
                      locals: { display_label: "#{milestone_level_display(a[:level])} #{a[:ability_name]} – Milestone #{a[:level]}", points: a[:points], is_total: false }
                - if remainder_miles.positive?
                  = render partial: "organizations/eligibility_requirements/mileage_card",
                    locals: { display_label: "Unique to you Abilities that you will specialize in", points: remainder_miles, is_total: false }
          %hr.my-2{ style: "border-width: 5px;" }
          .row.mt-3.gy-2 
            .col-6.mileage-column
              .d-flex.flex-column.gap-1.w-100
                = render partial: "organizations/eligibility_requirements/mileage_card",
                  locals: { display_label: "Total", points: earned[:total], is_total: true }

            .col-6.mileage-column.border-start.border-4{ style: "border-color: #dee2e6 !important;" }
              .d-flex.flex-column.gap-1.w-100
                = render partial: "organizations/eligibility_requirements/mileage_card",
                  locals: { display_label: "Total", points: minimum_miles, is_total: true }
                      
          
        .card-footer.fw-semibold.small.py-2{class: mileage_passed ? "bg-success bg-opacity-25" : "bg-warning bg-opacity-25"}
          .d-flex.align-items-center.justify-content-between.flex-wrap.gap-2
            .me-2
              Total: #{earned[:total]} Milestone Miles earned vs #{minimum_miles} required
            .align-middle
              - if mileage_passed
                %i.bi.bi-check-circle-fill.text-success.fs-4.align-middle
                %span.ms-1 Meeting requirements
              - else
                %i.bi.bi-tools.fs-4.align-middle
                %span.ms-1 Working to meet requirements
- else
  .row.mb-4
    .col-12
      .card
        .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section7Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
          %h3.mb-0 (7) You must meet the required Milestone Mileage…
          .d-flex.align-items-center.small.text-muted
            %span.expand-detail-label.d-inline-flex.align-items-center
              Expand for details
              %i.bi.bi-chevron-down.ms-1
            %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
              Show less detail
              %i.bi.bi-chevron-up.ms-1
        .card-body.collapse.py-2{ id: "section7Body" }
          %p.text-muted.mb-0 Milestone mileage is not configured for this position.
        .card-footer.py-2.bg-secondary.bg-opacity-10
          Not configured

- if @position_check_in_eligibility_result
  .row.mb-4
    .col-12
      .card
        .card-header.eligibility-section-header.d-flex.align-items-center.justify-content-between.py-2{ "data-bs-toggle": "collapse", "data-bs-target": "#section8Body", role: "button", tabindex: "0", style: "cursor: pointer;" }
          %h3.mb-0 (8) You must meet the Required Overall position ratings…
          .d-flex.align-items-center.small.text-muted
            %span.expand-detail-label.d-inline-flex.align-items-center
              Expand for details
              %i.bi.bi-chevron-down.ms-1
            %span.collapse-detail-label.d-inline-flex.align-items-center{ style: "display: none;" }
              Show less detail
              %i.bi.bi-chevron-up.ms-1
        .card-body.collapse.py-2{ id: "section8Body" }
          = render "organizations/eligibility_requirements/check_in_requirements_section",
            section_title: "Position check-ins (past 12 months)",
            requirement_sentence: nil,
            rows: [{ name: "Overall position rating", id: :position }],
            monthly_status_by_id: @position_check_in_monthly_status_by_row_id || {},
            eligibility_result: @position_check_in_eligibility_result,
            show_totals_in_body: false
        = render "organizations/eligibility_requirements/check_in_requirements_totals_footer",
          eligibility_result: @position_check_in_eligibility_result

.row
  .col-12
    = render "shared/eligibility_requirements_summary", eligibility_requirements_sentences: @eligibility_requirements_sentences, ability_milestone_requirements: @ability_milestone_requirements
