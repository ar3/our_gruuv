- content_for :title, insights_clarity_check_ins_progress_label

- chart_title_period = @chart_title_period

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-clipboard-check.me-2
      = insights_clarity_check_ins_progress_label

= render 'timeframe_selector',
  timeframe: @timeframe,
  path_for: ->(**opts) { organization_insights_check_ins_progress_path(@organization, **opts.merge(sort: params[:sort]).compact) },
  show_custom: true,
  custom_from: @insights_custom_from,
  custom_to: @insights_custom_to,
  form_hidden_fields: { sort: params[:sort] }.compact,
  wrapper_class: 'mb-4'

.container-fluid
  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-primary.text-white
          %h4.mb-0
            %i.bi.bi-bar-chart-steps.me-2
            Check-ins interacted with by week (#{chart_title_period})
        .card-body
          %p.small.text-muted.mb-3
            Each check-in is counted once per week in the rightmost category that occurred that week: Finalized &gt; Both completed &gt; Manager only &gt; Employee only.
          #check-ins-progress-chart{style: "height: 400px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-secondary.text-white
          %h4.mb-0
            %i.bi.bi-building.me-2
            Check-ins by department (#{chart_title_period})
        .card-body
          %p.small.text-muted.mb-3
            Same check-ins as above (employee completed, manager completed, both, or finalized), grouped by the department of the person the check-in is about.
          #check-ins-by-department-chart{style: "height: 400px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-success.text-white
          %h4.mb-0
            %i.bi.bi-trophy.me-2
            Department leaderboard
        .card-body
          %p.small.text-muted.mb-3
            Aggregated Gruuv Health Required Clarity by department (% healthy across direct-report items).
          - if @department_health_rows.any?
            .d-flex.align-items-center.mb-3
              %span.me-2.fw-medium Sort by
              .btn-group{role: "group"}
                = link_to "Name", organization_insights_check_ins_progress_path(@organization, timeframe: params[:timeframe], sort: "name"), class: "btn btn-sm #{@sort_by == 'name' ? 'btn-primary' : 'btn-outline-primary'}"
                = link_to "% healthy", organization_insights_check_ins_progress_path(@organization, timeframe: params[:timeframe], sort: "completion_rate"), class: "btn btn-sm #{@sort_by == 'completion_rate' ? 'btn-primary' : 'btn-outline-primary'}"
            .table-responsive
              %table.table.table-hover.table-layout-fixed
                %colgroup
                  %col{style: "width: 25%"}
                  %col{style: "width: 25%"}
                  %col{style: "width: 35%"}
                  %col{style: "width: 15%"}
                %thead
                  %tr
                    %th Department
                    %th Aspirations
                    %th Assignments
                    %th Position
                %tbody
                  - @department_health_rows.each do |row|
                    - segments_asp = check_ins_health_engagement_stacked_bar_segments(row[:aspiration_status_counts])
                    - segments_assign = check_ins_health_engagement_stacked_bar_segments(row[:assignment_status_counts])
                    - segments_pos = check_ins_health_engagement_stacked_bar_segments(row[:position_status_counts])
                    %tr
                      %td
                        - if row[:department].present?
                          = link_to row[:department_name], organization_department_path(@organization, row[:department]), class: "text-decoration-none fw-bold"
                        - else
                          %span.fw-bold= row[:department_name]
                        %br
                        %small.text-muted
                          #{row[:employee_count]} employee#{'s' if row[:employee_count] != 1}
                          · #{row[:completion_rate]}% healthy
                      %td
                        - if segments_asp.any?
                          - total = segments_asp.sum { |s| s[:count] }
                          .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 80px;"}
                            - segments_asp.each do |seg|
                              .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_ins_health_engagement_segment_tooltip(seg, total, "aspirations")}
                        - else
                          %span.text-muted No aspirations
                      %td
                        - if segments_assign.any?
                          - total = segments_assign.sum { |s| s[:count] }
                          .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 80px;"}
                            - segments_assign.each do |seg|
                              .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_ins_health_engagement_segment_tooltip(seg, total, "assignments")}
                        - else
                          %span.text-muted No assignments
                      %td
                        - if segments_pos.any?
                          - total = segments_pos.sum { |s| s[:count] }
                          .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 60px;"}
                            - segments_pos.each do |seg|
                              .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_ins_health_engagement_segment_tooltip(seg, total, "position")}
                        - else
                          %span.text-muted —
          - else
            .alert.alert-info
              %h6.mb-2
                %i.bi.bi-info-circle.me-2
                No department data
              %p.mb-0
                There are no active employees in scope, or no check-in health data is available yet.

:javascript
  (function() {
    var chartData = #{@check_ins_progress_chart_data.to_json};
    var chartTitle = #{chart_title_period.to_json};

    function initializeChart() {
      if (typeof Highcharts === 'undefined') return;
      var el = document.getElementById('check-ins-progress-chart');
      if (!el) return;
      Highcharts.chart('check-ins-progress-chart', {
        chart: { type: 'column' },
        title: { text: 'Check-ins by progress stage (' + chartTitle + ')' },
        accessibility: { enabled: false },
        xAxis: {
          categories: chartData.categories,
          title: { text: 'Week of' }
        },
        yAxis: {
          min: 0,
          title: { text: 'Number of check-ins' },
          stackLabels: { enabled: true }
        },
        plotOptions: {
          column: {
            stacking: 'normal',
            dataLabels: { enabled: false }
          }
        },
        series: chartData.series
      });
    }

    var attempts = 0;
    function waitForHighcharts() {
      if (typeof Highcharts !== 'undefined') {
        initializeChart();
      } else if (attempts < 100) {
        attempts++;
        setTimeout(waitForHighcharts, 100);
      } else {
        var script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/highcharts/11.3.0/highcharts.js';
        script.onload = initializeChart;
        document.head.appendChild(script);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForHighcharts);
    } else {
      waitForHighcharts();
    }
    window.addEventListener('load', function() {
      if (typeof Highcharts !== 'undefined') initializeChart();
    });
  })();

  (function() {
    var chartData = #{@check_ins_progress_by_department_chart_data.to_json};
    var chartTitle = #{chart_title_period.to_json};

    function initializeDeptChart() {
      if (typeof Highcharts === 'undefined') return;
      var el = document.getElementById('check-ins-by-department-chart');
      if (!el) return;
      Highcharts.chart('check-ins-by-department-chart', {
        chart: { type: 'column' },
        title: { text: 'Check-ins by department (' + chartTitle + ')' },
        accessibility: { enabled: false },
        xAxis: {
          categories: chartData.categories,
          title: { text: 'Week of' }
        },
        yAxis: {
          min: 0,
          title: { text: 'Number of check-ins' },
          stackLabels: { enabled: true }
        },
        plotOptions: {
          column: {
            stacking: 'normal',
            dataLabels: { enabled: false }
          }
        },
        series: chartData.series
      });
    }

    var attempts = 0;
    function waitForHighchartsDept() {
      if (typeof Highcharts !== 'undefined') {
        initializeDeptChart();
      } else if (attempts < 100) {
        attempts++;
        setTimeout(waitForHighchartsDept, 100);
      } else {
        var script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/highcharts/11.3.0/highcharts.js';
        script.onload = initializeDeptChart;
        document.head.appendChild(script);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForHighchartsDept);
    } else {
      waitForHighchartsDept();
    }
    window.addEventListener('load', function() {
      if (typeof Highcharts !== 'undefined') initializeDeptChart();
    });
  })();
