- content_for :title, "Insights: OG Scorecard"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Insights", url: organization_insights_path(@organization) }, { label: "OG Scorecard", url: nil }])

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-bar-chart-line.me-2
      Insights: OG Scorecard
      %span.d-inline-flex.align-items-center.ms-2{"data-bs-toggle" => "tooltip", "data-bs-placement" => "top", "data-bs-title" => "Weekly metrics and targets. Click for definitions and how to read this table."}
        %button.btn.btn-link.p-0.text-body{type: "button", "data-bs-toggle" => "collapse", "data-bs-target" => "#ogScorecardPageInfo", "aria-expanded" => "false", "aria-controls" => "ogScorecardPageInfo", "aria-label" => "Show page explanation"}
          %i.bi.bi-info-circle.fs-1.lh-1.align-middle{style: "text-shadow: 0 1px 3px rgba(0,0,0,0.25);"}

.collapse.mb-4#ogScorecardPageInfo
  .alert.alert-info.mb-0
    %h5.fw-semibold.mb-2 Ultimate goal
    %p.mb-2
      Give leaders a single place to scan how the organization is doing week over week on core metrics, with configurable yellow/green targets and color-coded weekly cells.

    %h5.fw-semibold.mb-2 How weeks and averages work
    %ul.mb-2
      %li
        %strong Week columns
        read left to right from newest to oldest; each week is Monday through Sunday, labeled by that Monday.
      %li
        %strong Last 6-week average
        is the mean of the six most recent weeks in the selected range (leftmost columns), or all weeks if fewer than six.
      %li
        Use the switch to show or hide Yellow/Green threshold columns and “More or less is better” in the table.
      %li
        Weekly cells are shaded
        %span.badge.bg-success
        green,
        %span.badge.bg-warning
        yellow, or
        %span.badge.bg-danger
        red when both thresholds are set; otherwise neutral gray until you configure them (accordion at bottom).

    %h5.fw-semibold.mb-2 Filters
    %ul.mb-2
      %li
        %strong Department
        and
        %strong Those managed by
        narrow every metric to teammates matching your selections (using current position title department and manager assignment).
      %li
        Leave all checkboxes unchecked to see the full company. Select multiple options within a group to include any match; both groups together require a teammate to match both.

    %h5.fw-semibold.mb-2 Metric definitions
    %ul.mb-2
      %li
        %strong Status vs activity:
        Within each section,
        %strong Activity
        rows are velocity (what happened this week / all-time / rolling windows).
        %strong Gruuv Health
        rows are population status counts (Healthy / Warning / Needs Attention) using the same rules as each teammate’s
        = link_to "My One Thing Overview", organization_employees_path(@organization, view: "managers_view", spotlight: "manager_lite")
        drill-down (open a teammate → My One Thing → Overview).
      %li
        %strong Active teammates:
        teammates with a hire date still employed at the end of that week (Sunday).
      %li
        %strong Observations:
        Activity rows count unique teammates who published or were named in a non-journal OGO during that Mon–Sun week (this week), or who had ever done so on or before that Sunday while employed that week (all-time).
        Gruuv Health
        %strong Healthy OGOs Given / Received
        is the 30-day Healthy window (last published ≤ 30 days as of that Sunday); Warning and Needs Attention complete the trio.
      %li
        %strong= "#{I18n.t('terminology.og_scorecard_clarity_check_ins_label')}:"
        = I18n.t('terminology.og_scorecard_clarity_check_ins_help')
      %li
        %strong= "#{I18n.t('terminology.og_scorecard_ability_milestones_label')}:"
        = I18n.t('terminology.og_scorecard_ability_milestones_help')
      %li
        %strong= "#{I18n.t('terminology.og_scorecard_goals_label')}:"
        = I18n.t('terminology.og_scorecard_goals_help')

.og-scorecard-toolbar.mb-4
  .d-flex.flex-wrap.align-items-center.gap-3
    .og-scorecard-timeframe
      .btn-group.flex-wrap{role: "group"}
        - btn_class = ->(key) { "btn btn-sm #{@timeframe == key ? 'btn-primary' : 'btn-outline-primary'}" }
        = link_to "Last 90 days", og_scorecard_path_with_filters(timeframe: '90_days'), class: btn_class.call(:'90_days')
        = link_to "Last Year", og_scorecard_path_with_filters(timeframe: 'year'), class: btn_class.call(:year)
        = link_to "All-Time", og_scorecard_path_with_filters(timeframe: 'all_time'), class: btn_class.call(:all_time)
        = link_to "Custom", og_scorecard_path_with_filters(**{ timeframe: 'custom', from: @insights_custom_from, to: @insights_custom_to }.compact), class: btn_class.call(:custom)
    = render 'og_scorecard_filter_toggle',
      selected_department_ids: @og_scorecard_selected_department_ids,
      selected_manager_ids: @og_scorecard_selected_manager_ids,
      departments: @og_scorecard_departments,
      manager_options: @og_scorecard_manager_options
  - if @timeframe == :custom
    = form_tag og_scorecard_path_with_filters(), method: :get, class: "row g-2 align-items-end mt-2" do
      = hidden_field_tag :timeframe, 'custom'
      - og_scorecard_filter_params.each do |name, value|
        - Array(value).each do |item|
          = hidden_field_tag "#{name}[]", item
      .col-sm-auto
        = label_tag :from, "From", class: "form-label small mb-0 d-block"
        = date_field_tag :from, @insights_custom_from, class: "form-control form-control-sm", required: true
      .col-sm-auto
        = label_tag :to, "To", class: "form-label small mb-0 d-block"
        = date_field_tag :to, @insights_custom_to, class: "form-control form-control-sm", required: true
      .col-sm-auto
        = submit_tag "Apply range", class: "btn btn-sm btn-primary"
  = render 'og_scorecard_filters',
    selected_department_ids: @og_scorecard_selected_department_ids,
    selected_manager_ids: @og_scorecard_selected_manager_ids,
    departments: @og_scorecard_departments,
    manager_options: @og_scorecard_manager_options,
    timeframe: @timeframe,
    custom_from: @insights_custom_from,
    custom_to: @insights_custom_to

%p.text-muted.small.mb-2
  Period: #{@chart_title_period}

- if @gruuv_health_backfill_enqueued
  .alert.alert-info.mb-3{role: "alert"}
    %i.bi.bi-hourglass-split.me-2
    Some Gruuv Health counts are still being calculated in the background. Refresh this page in a minute or so for complete weekly counts.

.og-scorecard-scope.og-scorecard--thresholds-hidden{data: { controller: 'og-scorecard-thresholds' }}
  .form-check.form-switch.mb-3
    %input#og_scorecard_show_thresholds.form-check-input{type: 'checkbox', role: 'switch', data: { 'og-scorecard-thresholds-target': 'toggle', action: 'change->og-scorecard-thresholds#thresholdsToggled' }}
    %label.form-check-label{for: 'og_scorecard_show_thresholds'}
      Show Yellow / Green thresholds and “More or less is better” in the table

  .table-responsive.border.rounded.shadow-sm
    %table.table.table-sm.table-bordered.align-middle.mb-0.og-scorecard-table
      %thead.table-light
        %tr
          = render 'og_scorecard_header_cells'
      %tbody
        - @scorecard[:groups].each do |group|
          - unless group[:title] == 'Teammates'
            %tr.table-light.og-scorecard-repeat-header
              = render 'og_scorecard_header_cells'
          %tr.table-secondary
            %td.sticky-col.fw-semibold= group[:title]
            %td{colspan: 4 + @week_labels.size}
          - group[:rows].each do |row|
            - if row[:separator]
              %tr.og-scorecard-separator
                %td.sticky-col
                  - if row[:label].present?
                    %span.og-scorecard-subsection-label= row[:label]
                %td{colspan: 4 + @week_labels.size}
            - else
              %tr
                %td.sticky-col
                  %span.og-scorecard-metric-cell
                    - if row[:gruuv_status].present?
                      = og_scorecard_gruuv_status_icon(row[:gruuv_status], row[:gruuv_category])
                    = row[:label]
                %td.text-end= row[:six_week_avg].nil? ? "—" : row[:six_week_avg]
                %td.text-end.og-scorecard-th-col= row[:yellow_display].presence || "—"
                %td.text-end.og-scorecard-th-col= row[:green_display].presence || "—"
                %td.og-scorecard-th-col= og_scorecard_direction_label(row[:direction])
                - row[:weekly_values].reverse.zip(row[:weekly_cell_statuses].reverse).each do |v, status|
                  %td.text-end{class: og_scorecard_weekly_cell_class(status)}= v

  = render 'og_scorecard_threshold_configuration',
    organization: @organization,
    can_configure: @can_configure_thresholds,
    metric_registry_groups: @metric_registry_groups,
    thresholds_by_key: @thresholds_by_key,
    timeframe: @timeframe,
    custom_from: @insights_custom_from,
    custom_to: @insights_custom_to,
    selected_department_ids: @og_scorecard_selected_department_ids,
    selected_manager_ids: @og_scorecard_selected_manager_ids
