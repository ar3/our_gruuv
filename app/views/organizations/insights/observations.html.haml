- content_for :title, "Insights: Observations"

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-bar-chart-line.me-2
      Insights: Observations

= render 'timeframe_selector',
  timeframe: @timeframe,
  path_for: ->(**opts) { organization_insights_observations_path(@organization, **opts) },
  show_custom: true,
  custom_from: @insights_custom_from,
  custom_to: @insights_custom_to,
  wrapper_class: 'mb-3'

- s = @observations_insights_summary
.border-bottom.py-2.mb-3.small.text-muted
  In this timeframe: There were #{number_with_delimiter(s[:stories_count])} observation-based stories told by #{number_with_delimiter(s[:unique_observer_teammates])} unique teammates, observing #{number_with_delimiter(s[:unique_observee_teammates])} unique teammates. Rating #{number_with_delimiter(s[:unique_aspirations_rated])} unique Aspirational Values, #{number_with_delimiter(s[:unique_assignments_rated])} unique assignments, and #{number_with_delimiter(s[:unique_abilities_rated])} unique Abilities.

.container-fluid
  / Stacked bar chart by privacy level
  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-primary.text-white
          %h4.mb-0
            %i.bi.bi-eye.me-2
            Observations by Week (#{@insights_chart_period_label})
        .card-body
          #observations-by-privacy-chart{style: "height: 400px;"}
          %hr.my-4
          %p.small.text-muted.mb-2
            Total observations in this period by privacy level (same categories as the chart above).
          #observations-by-privacy-pie-chart{style: "height: 380px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-secondary.text-white
          %h4.mb-0
            %i.bi.bi-person-check.me-2
            Observations by observer's department (#{@insights_chart_period_label})
        .card-body
          %p.small.text-muted.mb-3
            Published observations grouped by the department of the person who wrote the observation (the observer).
          #observations-by-observer-department-chart{style: "height: 400px;"}
          %hr.my-4
          %p.small.text-muted.mb-2
            Total observations in this period by observer department (same categories as the chart above).
          #observations-by-observer-department-pie-chart{style: "height: 380px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-info.text-white
          %h4.mb-0
            %i.bi.bi-building.me-2
            Observations by observee's department (#{@insights_chart_period_label})
        .card-body
          %p.small.text-muted.mb-3
            Published observations grouped by the department of the person the observation is about (first observee when multiple).
          #observations-by-department-chart{style: "height: 400px;"}
          %hr.my-4
          %p.small.text-muted.mb-2
            Total observations in this period by observee department (same categories as the chart above).
          #observations-by-observee-department-pie-chart{style: "height: 380px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-warning.text-dark
          %h4.mb-0
            %i.bi.bi-emoji-smile.me-2
            Published observations feelings (#{@insights_chart_period_label})
        .card-body
          %p.small.text-muted.mb-3
            Distribution of all primary and secondary feelings set on published observations in this timeframe.
          #observations-feelings-pie-chart{style: "height: 420px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-success.text-white
          %h4.mb-0
            %i.bi.bi-pie-chart.me-2
            Published observations ratings distribution (#{@insights_chart_period_label})
        .card-body
          %p.small.text-muted.mb-3
            Distribution of all ratings given on published observations in this timeframe.
          #observations-ratings-pie-chart{style: "height: 420px;"}

  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-light
          %h4.mb-0
            %i.bi.bi-table.me-2
            Ratings Ratio Health Check (#{@insights_chart_period_label})
        .card-body
          %p.small.text-muted.mb-3
            Healthy target for Kudos : Constructive is about 5:1; other rows use a 3:1 target.
          .table-responsive
            %table.table.table-hover.align-middle
              %thead
                %tr
                  %th Ratio
                  %th Healthy Target
                  %th This Org (Timeframe)
                  %th Why it matters
              %tbody
                - @observations_rating_health_ratios.each do |row|
                  - popover_html = safe_join([content_tag(:div, row[:popover_line_1]), content_tag(:div, row[:popover_line_2])]).html_safe
                  %tr
                    %td= row[:name]
                    %td= row[:healthy_ratio]
                    %td
                      %span.d-inline-block.border-bottom.border-dotted{"data-bs-toggle" => "popover", "data-bs-trigger" => "hover focus", "data-bs-placement" => "top", "data-bs-html" => "true", "data-bs-content" => popover_html, style: "cursor: help;", tabindex: "0"}= row[:display_ratio]
                    %td
                      - org_name = @organization.display_name
                      - if row[:kudos_constructive_band].present?
                        - case row[:kudos_constructive_band]
                        - when :above_seven
                          .alert.alert-warning.mb-0.small
                            %p.mb-2
                              This is an indication that #{org_name} is likely not putting constructive feedback in OG. Which is understandable as giving constructive feedback is one of the hardest things you can do. Documenting it in a system like this can create anxiety. However, a few things to consider
                            %ul.mb-0.ps-3
                              %li.mb-1 Does this feedback help people get better? Being Kind is being Clear… is it kind to withhold feedback that could help?
                              %li.mb-1 Can an organization have high talent density without having high truth density?
                              %li.mb-0 Culture: OG cultures strive to ensure that no one wonders where they stand… and everyone knows how to get better… and a healthy mix of kudos and constructive style feedback is a prime indication of that
                        - when :healthy
                          .alert.alert-success.mb-0.small
                            #{org_name} has a healthy ratio of Kudos vs Constructive feedback… which is a great indication that this is a culture that celebrates clarity and ensuring everyone knows where they stand and how to improve. 🎉 Well Done 🎉
                        - when :below_three
                          .alert.alert-warning.mb-0.small
                            This ratio is an indication that #{org_name} has a culture of constructive feedback which is good, but it should also be balanced with a healthy dose of kudos as well. Folks need to know, not just what not to do, but what success looks like.
                        - when :no_data
                          %p.small.text-muted.mb-0 Not enough observation ratings in this timeframe to assess this ratio.
                      - elsif row[:solid_exceptional_band].present?
                        - case row[:solid_exceptional_band]
                        - when :above_five
                          .alert.alert-warning.mb-0.small
                            %p.mb-0
                              #{org_name} should consider when truly
                              %strong exceptional
                              performance deserves the top rating. Exceptional should be rare—but not
                              %em this
                              rare. If Solid dominates this heavily, highlight the most extreme positive outcomes so standout impact stays visible and ratings don’t all collapse into “good enough.”
                        - when :below_one
                          .alert.alert-warning.mb-0.small
                            %p.mb-0
                              This pattern suggests a potential
                              %strong calibration
                              issue: Exceptional may be used too often relative to Solid, which makes it harder for people to tell strong work from truly stand-out work.
                        - when :healthy
                          .alert.alert-success.mb-0.small
                            #{org_name} has a healthy balance between Solid and Exceptional—enough differentiation without over-using the top bucket. 🎉 Well done 🎉
                        - when :no_data
                          %p.small.text-muted.mb-0 Not enough observation ratings in this timeframe to assess this ratio.
                      - elsif row[:misaligned_concerning_band].present?
                        - case row[:misaligned_concerning_band]
                        - when :above_five
                          .alert.alert-warning.mb-0.small
                            %p.mb-0
                              #{org_name} should consider when the most serious gaps deserve a
                              %strong Concerning
                              rating. Concerning should be rare—but not
                              %em this
                              rare. If Misaligned dominates this heavily, ensure the most extreme issues are still called out so serious problems aren’t only ever labeled as “soft” misalignment.
                        - when :below_one
                          .alert.alert-warning.mb-0.small
                            %p.mb-0
                              This pattern suggests a potential
                              %strong calibration
                              issue: Concerning may be used too often relative to Misaligned, which blurs the line between “needs correction” and “serious cause for attention.”
                        - when :healthy
                          .alert.alert-success.mb-0.small
                            #{org_name} has a healthy balance between Misaligned and Concerning—clear enough escalation for the worst cases without over-labeling everyday gaps. 🎉 Well done 🎉
                        - when :no_data
                          %p.small.text-muted.mb-0 Not enough observation ratings in this timeframe to assess this ratio.
                      - else
                        = row[:details]

  %hr.my-5

  / Observations Kudos vs Feedback table
  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-success.text-white
          %h4.mb-0
            %i.bi.bi-heart.me-2
            Observations Kudos vs Feedback
        .card-body
          .table-responsive
            %table.table.table-hover
              %thead
                %tr
                  %th Employee
                  %th Department
                  %th.text-end Total
                  %th.text-end Kudos
                  %th.text-end Feedback
                  %th.text-end Mixed / Other
              %tbody
                - @observer_teammates.sort_by { |ct| -(@total_published_unarchived_by_observer[ct.person_id] || 0) }.each do |teammate|
                  - buckets = @kudos_feedback_mixed_by_observer[teammate.person_id] || {}
                  - dept = teammate.active_employment_tenure&.position&.title&.department
                  %tr
                    %td
                      Employee on... 
                      /= teammate.person.display_name
                    %td= dept&.name.presence || '—'
                    %td.text-end= @total_published_unarchived_by_observer[teammate.person_id].to_i
                    %td.text-end= buckets[:kudos].to_i
                    %td.text-end= buckets[:feedback].to_i
                    %td.text-end= buckets[:mixed].to_i

  %hr.my-5

  / Observations Sharing table (by privacy level)
  .row.mb-4
    .col-12
      .card.border-0.shadow-sm
        .card-header.bg-info.text-white
          %h4.mb-0
            %i.bi.bi-shield-lock.me-2
            Observations Sharing
        .card-body
          .table-responsive
            %table.table.table-hover
              %thead
                %tr
                  %th Employee
                  %th Department
                  %th.text-end Total
                  - @privacy_levels.each do |privacy|
                    %th.text-end= privacy.to_s.humanize.titleize
              %tbody
                - @observer_teammates.sort_by { |ct| -(@total_published_unarchived_by_observer[ct.person_id] || 0) }.each do |teammate|
                  - counts = @privacy_counts_by_observer[teammate.person_id] || {}
                  - dept = teammate.active_employment_tenure&.position&.title&.department
                  %tr
                    %td
                      Employee on... 
                      /= teammate.person.display_name
                    %td= dept&.name.presence || '—'
                    %td.text-end= @total_published_unarchived_by_observer[teammate.person_id].to_i
                    - @privacy_levels.each do |privacy|
                      %td.text-end= counts[privacy].to_i

:javascript
  (function() {
    var chartData = #{@observations_chart_data.to_json};
    var chartTitle = #{@insights_chart_period_label.to_json};

    function initializeChart() {
      if (typeof Highcharts === 'undefined') return;
      var el = document.getElementById('observations-by-privacy-chart');
      if (!el) return;
      Highcharts.chart('observations-by-privacy-chart', {
        chart: { type: 'column' },
        title: { text: 'Published observations by privacy level (' + chartTitle + ')' },
        accessibility: { enabled: false },
        xAxis: {
          categories: chartData.categories,
          title: { text: 'Week of' }
        },
        yAxis: {
          min: 0,
          title: { text: 'Number of observations' },
          stackLabels: { enabled: true }
        },
        plotOptions: {
          column: {
            stacking: 'normal',
            dataLabels: { enabled: false }
          }
        },
        series: chartData.series
      });
    }

    var attempts = 0;
    function waitForHighcharts() {
      if (typeof Highcharts !== 'undefined') {
        initializeChart();
      } else if (attempts < 100) {
        attempts++;
        setTimeout(waitForHighcharts, 100);
      } else {
        var script = document.createElement('script');
        script.src = 'https://cdnjs.cloudflare.com/ajax/libs/highcharts/11.3.0/highcharts.js';
        script.onload = initializeChart;
        document.head.appendChild(script);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', waitForHighcharts);
    } else {
      waitForHighcharts();
    }
    window.addEventListener('load', function() {
      if (typeof Highcharts !== 'undefined') initializeChart();
    });
  })();

