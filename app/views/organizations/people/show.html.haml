- content_for :title, @person == @current_person ? "My Profile" : @person.display_name

- content_for :header do
  %h1.mb-0{id: "person-title"}
  - if @person == @current_person
    My Profile
  - else
    = @person.display_name
        
- content_for :header_action do
  = render 'people/view_switcher'

- content_for :go_back_link do
  - profile_crumb = @person == @current_person ? "My profile" : @person.display_name
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Teammates", url: organization_employees_path(organization) }, { label: profile_crumb, url: nil }])

/ About Me Section
.row
  .col-12
    = render 'people/show/about_me'

/ Security & Permissions Section
.row
  .col-12  
    = render 'people/show/identities'

/ Organization Permissions Section
.row
  .col-12
    = render 'people/show/permissions'

/ Page Visits Section
.row.mb-4
  .col-12
    = render 'people/show/page_visits'

= render 'people/show/footer'
