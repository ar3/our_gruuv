- goal = node[:goal]
- children = node[:children] || []
- direct_children_count = node[:direct_children_count] || 0
- total_descendants_count = node[:total_descendants_count] || 0
- has_children = children.any?
- node_id = "goal-node-#{goal.id}"
- children_id = "goal-children-#{goal.id}"
- most_recent_check_in = node[:most_recent_check_in]
- current_week_check_in = node[:current_week_check_in]
- can_check_in = node[:can_check_in]
- hide_check_in = local_assigns.fetch(:hide_check_in, false)
- current_week_start = Date.current.beginning_of_week(:monday)
- teammate_owned_goal = goal.owner_type == 'CompanyTeammate' && goal.owner_id.present?
- viewer_is_goal_owner = current_company_teammate.present? && goal.owner_id == current_company_teammate.id
- show_note_win_cta_for_viewer = teammate_owned_goal && !viewer_is_goal_owner
- compact = hide_check_in

- card_style = compact ? "width: 100%; position: relative; overflow: hidden;" : "width: 100%; max-width: 820px; position: relative;"

.tree-node{id: node_id, style: "margin-left: #{depth * 40}px; margin-bottom: #{compact ? 6 : 10}px;"}
  .d-flex.align-items-start{class: ('w-100' if compact)}
    - if depth > 0
      %i.bi.bi-arrow-return-right.me-2.flex-shrink-0{style: "color: #999; margin-top: #{compact ? 8 : 12}px;"}
    .card.flex-grow-1.min-w-0{style: card_style, class: goal_warning_class(goal)}
      .card-body{class: (compact ? 'py-1 px-2 overflow-hidden' : 'p-2')}
        .d-flex.align-items-center.min-w-0
          .flex-shrink-0.me-2
            = goal_owner_image(goal, size: (compact ? 40 : 48))
          .flex-grow-1.min-w-0.overflow-hidden
            - if compact
              / Compact: full-width card, title truncates with ellipsis
              .d-flex.align-items-center.gap-2.min-w-0
                - if has_children
                  %button.btn.btn-sm.btn-link.p-0.toggle-children.flex-shrink-0{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "##{children_id}", "aria-expanded": "true", "aria-controls": children_id, style: "text-decoration: none; color: #666; min-width: 16px; line-height: 1;"}
                    %i.bi.bi-chevron-up.toggle-icon
                  %span.badge.bg-light.text-dark.flex-shrink-0{style: "font-size: 0.7rem;"}
                    - if direct_children_count == total_descendants_count
                      #{pluralize(direct_children_count, 'sub-goal')}
                    - else
                      #{direct_children_count}/#{total_descendants_count}
                = link_to goal.title, organization_goal_path(@organization, goal), class: "text-decoration-none fw-bold text-truncate min-w-0 flex-grow-1", title: goal.title
                - if goal.should_show_warning?
                  %i.bi.bi-exclamation-triangle.text-warning.flex-shrink-0{"data-bs-toggle" => "tooltip", "data-bs-title" => goal_warning_message(goal)}
              .d-flex.align-items-center.justify-content-between.gap-2.min-w-0{style: "line-height: 1.2;"}
                .small.text-muted.text-truncate.min-w-0
                  - if most_recent_check_in.present?
                    = render 'organizations/goals/goal_check_in_sentence', check_in: most_recent_check_in, goal: goal, short: true, use_casual_name: true
                    = render 'shared/on_track_pill', status: goal.on_track_status_for_check_in(most_recent_check_in)
                  - else
                    %span= goal_index_info_sentence(goal)
                - if goal.most_likely_target_date.present? && goal.completed_at.nil?
                  - checkin_collapse_id = "goal-checkin-#{goal.id}"
                  %button.btn.btn-sm.btn-link.p-0.toggle-checkin.flex-shrink-0.text-nowrap{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "##{checkin_collapse_id}", "aria-expanded": "false", "aria-controls": checkin_collapse_id, style: "text-decoration: none; color: #666; line-height: 1;"}
                    %span.small.me-1 Confidence check
                    %i.bi.bi-chevron-down.toggle-icon
              - if goal.most_likely_target_date.present? && goal.completed_at.nil?
                .collapse.mt-1{id: "goal-checkin-#{goal.id}"}
                  = render 'organizations/goals/customize_view/styles/goal_check_in_body', goal: goal, show_note_win_cta_for_viewer: show_note_win_cta_for_viewer, can_check_in: can_check_in, current_week_check_in: current_week_check_in
              - elsif goal.completed_at.nil?
                - show_start = goal.started_at.nil? && policy(goal).update?
                - if show_start
                  .d-flex.gap-2.mt-1
                    = button_to start_organization_goal_path(@organization, goal), method: :patch, class: "btn btn-primary btn-sm", form: { style: "display: inline-block;" } do
                      %i.bi.bi-play-circle.me-1
                      Start
                    = link_to organization_goal_path(@organization, goal), class: "btn btn-outline-primary btn-sm" do
                      %i.bi.bi-eye.me-1
                      View
            - else
              / Full hierarchical-collapsible layout
              - if has_children
                .d-flex.align-items-center.mb-2
                  %button.btn.btn-sm.btn-link.p-0.me-2.toggle-children{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "##{children_id}", "aria-expanded": "true", "aria-controls": children_id, style: "text-decoration: none; color: #666; min-width: 20px;"}
                    %i.bi.bi-chevron-up.toggle-icon
                  %span.badge.bg-light.text-dark.small
                    - if direct_children_count == total_descendants_count
                      #{pluralize(direct_children_count, 'sub-goal')}
                    - else
                      #{pluralize(direct_children_count, 'sub-goal')} directly & #{total_descendants_count} total

              .d-flex.align-items-center.flex-wrap.mb-1
                = link_to goal.title, organization_goal_path(@organization, goal), class: "text-decoration-none fw-bold me-2"
                - if goal.should_show_warning?
                  %i.bi.bi-exclamation-triangle.text-warning{"data-bs-toggle" => "tooltip", "data-bs-title" => goal_warning_message(goal)}

              .d-flex.align-items-center.flex-wrap.mb-1
                %span.small.me-2
                  = goal_index_info_sentence(goal)
                %span.small.me-2
                  |
                %span.text-muted.small.me-2{"data-bs-toggle" => "tooltip", "data-bs-title" => goal_privacy_tooltip_text(goal)}
                  = goal_visibility_display(goal)
                %span.text-muted.small
                  | Owned by: #{goal_owner_display_name(goal)}
                = goal_external_association_links(@organization, goal)

              - if most_recent_check_in.present?
                .small.text-muted.mb-2
                  = render 'organizations/goals/goal_check_in_sentence', check_in: most_recent_check_in, goal: goal, short: true, use_casual_name: true
                  = render 'shared/on_track_pill', status: goal.on_track_status_for_check_in(most_recent_check_in)

              - if goal.most_likely_target_date.present? && goal.completed_at.nil?
                = render 'organizations/goals/customize_view/styles/goal_check_in_body', goal: goal, show_note_win_cta_for_viewer: show_note_win_cta_for_viewer, can_check_in: can_check_in, current_week_check_in: current_week_check_in
              - elsif goal.completed_at.nil?
                - show_start = goal.started_at.nil? && policy(goal).update?
                - if show_start
                  .d-flex.gap-2.mt-2
                    = button_to start_organization_goal_path(@organization, goal), method: :patch, class: "btn btn-primary btn-sm", form: { style: "display: inline-block;" } do
                      %i.bi.bi-play-circle.me-1
                      Start
                    = link_to organization_goal_path(@organization, goal), class: "btn btn-outline-primary btn-sm" do
                      %i.bi.bi-eye.me-1
                      View

- if has_children
  .collapse.show{id: children_id}
    - children.each do |child_node|
      = render 'organizations/goals/customize_view/styles/goal_node', node: child_node, depth: depth + 1, hide_check_in: hide_check_in
