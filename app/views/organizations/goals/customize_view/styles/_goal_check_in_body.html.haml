- if show_note_win_cta_for_viewer && policy(Observation).create?
  .mt-1
    - quick_note_params = { privacy_level: 'observed_and_managers', return_url: request.fullpath, return_text: 'Goals', goal_id: goal.id, observee_ids: goal.observee_teammate_ids_for_observation }
    = link_to new_quick_note_organization_observations_path(@organization, quick_note_params), class: 'btn btn-outline-primary w-100', target: '_blank', rel: 'noopener noreferrer' do
      %i.bi.bi-sticky.me-2
      Add a note/win/challenge about this goal
- elsif show_note_win_cta_for_viewer
  .d-flex.align-items-center.gap-2.mt-1
    .flex-grow-1
      %button.btn.btn-outline-secondary.w-100{type: "button", disabled: true}
        %i.bi.bi-sticky.me-2
        Add a note/win/challenge about this goal
    %i.bi.bi-exclamation-triangle.text-warning{"data-bs-toggle" => "tooltip", "data-bs-title" => "You don't have permission to add a note/win/challenge about this goal.", tabindex: "0", role: "img", "aria-label" => "Permission notice"}
- elsif can_check_in
  - can_update_goal = policy(goal).update?
  .check-in-inline.mt-1.p-1.bg-light.rounded
    .goal-check-in-inline-layout{class: ('goal-check-in-inline-layout--with-rail' if can_update_goal)}
      .goal-check-in-inline-layout__main
        = form_with url: check_in_organization_goal_path(@organization, goal), method: :post, local: true, html: { class: 'd-flex flex-column gap-1 goal-check-in-form' } do |f|
          = hidden_field_tag :return_url, request.fullpath
          .d-flex.flex-wrap.align-items-center.gap-2
            %span.small I'm
            = select_tag :confidence_percentage, options_for_select(confidence_percentage_options, current_week_check_in&.confidence_percentage), { include_blank: 'Select...', class: 'form-select form-select-sm', style: 'width: auto; min-width: 80px; display: inline-block;' }
            %span.small confident this'll be hit by
            - if can_update_goal
              = date_field_tag :most_likely_target_date, goal.most_likely_target_date, class: 'form-control form-control-sm', style: 'width: auto; min-width: 130px; display: inline-block;'
            - else
              %span.small= goal.most_likely_target_date.present? ? goal.most_likely_target_date.strftime('%b %d, %Y') : '—'
            %span.small .
            %button.btn.btn-primary.btn-sm{type: "submit"}
              %i.bi.bi-check-lg
              Check In
          = text_field_tag :confidence_reason, current_week_check_in&.confidence_reason, class: 'form-control form-control-sm goal-check-in-inline-layout__reason', placeholder: 'Brief update (optional)...'
      - if can_update_goal
        .goal-check-in-inline-layout__rail
          .goal-check-in-inline-layout__rail-or
            %span.small.text-muted or
          = link_to done_organization_goal_path(@organization, goal), class: 'btn btn-success btn-lg goal-check-in-inline-layout__done-btn text-nowrap', "data-bs-toggle" => "tooltip", "data-bs-title" => "mark this goal as done and log if it was hit or not" do
            %i.bi.bi-check-circle.me-1
            Complete
- else
  .check-in-inline.mt-1.p-1.bg-light.rounded.opacity-75
    .goal-check-in-inline-layout
      .goal-check-in-inline-layout__main.d-flex.flex-column.gap-1
        .d-flex.flex-wrap.align-items-center.gap-2
          %span.small I'm
          = select_tag "goal_check_in_disabled_#{goal.id}", options_for_select(confidence_percentage_options, current_week_check_in&.confidence_percentage), { include_blank: 'Select...', class: 'form-select form-select-sm', style: 'width: auto; min-width: 80px;', disabled: true }
          %span.small confident this'll be hit by
          %span.small= goal.most_likely_target_date.present? ? goal.most_likely_target_date.strftime('%b %d, %Y') : '—'
          %span.small .
          %span.btn.btn-primary.btn-sm.disabled
            %i.bi.bi-check-lg.me-1
            Check In
          %i.bi.bi-exclamation-triangle.text-warning.ms-1{"data-bs-toggle" => "tooltip", "data-bs-title" => goal_no_check_in_access_tooltip(goal)}
        = text_field_tag "goal_check_in_reason_disabled_#{goal.id}", current_week_check_in&.confidence_reason, class: 'form-control form-control-sm goal-check-in-inline-layout__reason', placeholder: 'Brief update (optional)...', disabled: true
