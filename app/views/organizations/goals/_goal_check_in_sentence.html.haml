- check_in = local_assigns[:check_in]
- goal = local_assigns[:goal] || check_in.goal
- short = local_assigns[:short]
- use_casual_name = local_assigns[:use_casual_name]
- calculated_date = goal&.calculated_target_date

- if check_in.present? && goal.present?
  - date_str = check_in.created_at.to_date.strftime('%m/%d/%y')
  - person_name = use_casual_name ? check_in.confidence_reporter.casual_name : check_in.confidence_reporter.display_name
  - confidence = check_in.confidence_percentage
  - goal_title = goal.title
  - due_str = calculated_date.present? ? calculated_date.strftime('%m/%d/%y') : nil
  - full_sentence = "As of #{date_str}, #{person_name} is #{confidence}% confident we'll hit #{goal_title}"
  - full_sentence += " by #{due_str}" if due_str.present?
  - full_sentence += "."

  - if short
    %span{"data-bs-toggle" => "tooltip", "data-bs-title" => full_sentence, title: full_sentence}
      = "As of "
      %strong= date_str
      = ", "
      %strong= person_name
      = " is "
      %strong= "#{confidence}%"
      = " confident"
      - if due_str.present?
        = " we'll hit by "
        %strong= due_str
  - else
    %span
      = "As of "
      %strong= date_str
      = ", "
      %strong= person_name
      = " is "
      %strong= "#{confidence}%"
      = " confident we'll hit "
      %strong= goal_title
      - if due_str.present?
        = " by "
        %strong= due_str
