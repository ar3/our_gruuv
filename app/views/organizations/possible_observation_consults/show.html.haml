- extraction_status_url = extraction_status_organization_possible_observation_consult_path(organization, @consult)
- form_id = "ogo-consult-candidates-form"
- processing = %w[pending processing].include?(@consult.extraction_status)
- completed = @consult.extraction_status == "completed"
- groups = @consult.extraction_groups_by_processed_teammate(teammates: @confirmed_teammates).map { |tm, items| [tm, candidate_items_for_review(items)] }

.mb-3
  = link_to "← All consults", organization_possible_observation_consults_path(organization), class: "text-decoration-none"
%h1.h3.mb-1= @consult.display_name
%p.small.text-muted.mb-4
  Status:
  %span.badge.text-bg-secondary= @consult.extraction_status
  · People: #{@consult.people_status}

- unless @consult.people_confirmed?
  .card.mb-4
    .card-body
      %h5.mb-2 Confirm teammates
      %p.small.text-muted
        Names detected in the content are pre-checked. Adjust the list, then start OG Consult.
      = form_with url: confirm_teammates_organization_possible_observation_consult_path(organization, @consult), method: :patch, local: true do
        - preselected = Array(@consult.suggested_teammate_ids).map(&:to_i)
        .row
          - @selectable_teammates.each do |tm|
            .col-md-4.mb-2
              .form-check
                = check_box_tag "confirmed_teammate_ids[]", tm.id, preselected.include?(tm.id), class: "form-check-input", id: "tm_#{tm.id}"
                = label_tag "tm_#{tm.id}", tm.person.display_name, class: "form-check-label"
        .btn-group.mt-3{ role: "group" }
          = button_tag "Confirm teammates and run OG Consult", type: "submit", class: "btn btn-primary"
          %button.btn.btn-primary.dropdown-toggle.dropdown-toggle-split{ type: "button", "data-bs-toggle" => "dropdown", "aria-expanded" => "false" }
            %span.visually-hidden Choose model
          %ul.dropdown-menu
            %li
              = button_tag "Faster, but less powerful model", type: "submit", class: "dropdown-item"
            %li
              = button_tag "Slower, but more powerful model", type: "submit", name: "model", value: "stronger", class: "dropdown-item"

- if @consult.people_confirmed? && processing
  = render "shared/og_consultations/status_banner",
           status_url: extraction_status_url,
           label: "OG Consult",
           initial_status: @consult.extraction_status,
           wrapper_class: "alert alert-secondary mb-3",
           time_zone: current_person_iana_timezone,
           processed_teammates_count: @consult.processed_teammate_ids.size

- if @consult.extraction_status == "failed"
  .alert.alert-danger
    = @consult.extraction_error.presence || "Consultation failed."
    - if policy(@consult).re_extract?
      = button_to "Try again", re_extract_organization_possible_observation_consult_path(organization, @consult), method: :post, class: "btn btn-sm btn-outline-primary ms-2"

- if completed && policy(@consult).extract?
  - latest_model = @latest_consultation&.model_id
  - stronger_ran = latest_model.present? && latest_model == Llm::MultiTeammateMomentsExtractor.stronger_model_id
  - faster_label = stronger_ran ? "Try: Faster, but less powerful model" : "Re-run: Faster, but less powerful model"
  - stronger_label = stronger_ran ? "Re-run: Slower, but more powerful model" : "Try: Slower, but more powerful model"
  .d-flex.flex-wrap.gap-2.mb-3
    .btn-group{ role: "group" }
      %button.btn.btn-sm.btn-outline-primary.dropdown-toggle{ type: "button", "data-bs-toggle" => "dropdown", "aria-expanded" => "false" }
        %i.bi.bi-stars.me-1
        Consult OG again
      %ul.dropdown-menu
        %li
          = button_to faster_label, extract_organization_possible_observation_consult_path(organization, @consult), method: :post, class: "dropdown-item"
        %li
          = button_to stronger_label, extract_organization_possible_observation_consult_path(organization, @consult, model: "stronger"), method: :post, class: "dropdown-item"

- if processing && groups.any?
  - confirmed_n = Array(@consult.confirmed_teammate_ids).size
  - processed_n = @consult.processed_teammate_ids.size
  %h5.mb-3 Results so far
  %p.small.text-muted.mb-3
    Showing finished teammates while others are still being consulted.
    #{processed_n} of #{confirmed_n} people complete.
  = render "candidate_groups_readonly", groups: groups

- if completed
  - items = @consult.extraction_items
  - if items.empty? && groups.empty?
    .alert.alert-warning
      = @consult.extraction_error.presence || "No candidates found."
      - if policy(@consult).re_extract?
        = button_to "Consult again", re_extract_organization_possible_observation_consult_path(organization, @consult), method: :post, class: "btn btn-sm btn-outline-primary ms-2"
  - else
    %h5.mb-3 Review candidate OGOs
    = form_with url: organization_possible_observation_consult_path(organization, @consult), method: :patch, local: true, html: { id: form_id, data: { turbo: false } } do
      - idx = 0
      - groups.each do |teammate, person_items|
        .mb-4
          %h6.mb-2= teammate.person.display_name
          - if person_items.empty?
            %p.small.text-muted.mb-0 No candidates for this person.
          - else
            .table-responsive
              %table.table.table-bordered.align-middle
                %thead.table-light
                  %tr
                    %th Quote
                    %th Actions
                    %th Status
                %tbody
                  - person_items.each do |item|
                    = render "candidate_row", item: item, idx: idx, editable: true
                    - idx += 1
      .d-flex.flex-wrap.gap-2.mt-3
        = submit_tag "Save all", name: "commit", value: "Save all", class: "btn btn-primary"
      %p.mt-3.mb-0.text-muted.small
        Each candidate is either #{content_tag(:strong, "Reviewing")}, #{content_tag(:strong, "Include")}, or #{content_tag(:strong, "Dismiss")}.
        Save all actualizes every row: included candidates become draft OGOs (you are the creator),
        dismissed candidates are hidden, and the rest stay as potential OGOs.
        Use the per-row buttons to act on one candidate immediately: Create draft OGO now, Create published OGO now (private)
        (publishes only when you are the observer; otherwise it stays a draft), or Dismiss now.

    :javascript
      (function() {
        var form = document.getElementById("#{form_id}");
        if (!form) return;
        function syncRow(row) {
          var states = row.querySelectorAll("[data-consult-state]");
          if (!states.length) return;
          var included = false;
          states.forEach(function(el) {
            if (el.checked && el.value === "included") included = true;
          });
          row.querySelectorAll("[data-consult-row-field]").forEach(function(field) {
            field.disabled = !included;
          });
        }
        form.querySelectorAll("[data-consult-candidate-row]").forEach(function(row) {
          syncRow(row);
          row.querySelectorAll("[data-consult-state]").forEach(function(el) {
            el.addEventListener("change", function() { syncRow(row); });
          });
        });
      })();
