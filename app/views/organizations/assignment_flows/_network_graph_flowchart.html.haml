- network_graph = local_assigns.fetch(:network_graph)
- assignments = local_assigns.fetch(:assignments)
- supply_relationships = local_assigns.fetch(:supply_relationships)
- organization = local_assigns.fetch(:organization)

.assignment-full-network-graph{
  data: {
    controller: "assignment-full-network-graph",
    action: "shown.bs.tab->assignment-full-network-graph#onTabShown",
    assignment_full_network_graph_highcharts_network_data_json_value: network_graph.highcharts_network_graph_data.to_json,
    assignment_full_network_graph_highcharts_sankey_data_json_value: network_graph.highcharts_sankey_data.to_json,
    assignment_full_network_graph_g6_graph_data_json_value: network_graph.g6_graph_data.to_json,
    assignment_full_network_graph_vis_network_data_json_value: network_graph.vis_network_data.to_json
  }
}
  %ul.nav.nav-tabs.card-header-tabs{role: "tablist"}
    %li.nav-item{role: "presentation"}
      %button.nav-link.active{id: "full-network-cytoscape-tab", type: "button", role: "tab", "data-bs-toggle": "tab", "data-bs-target": "#full-network-cytoscape-pane", "aria-controls": "full-network-cytoscape-pane", "aria-selected": "true"}
        Cytoscape
    %li.nav-item{role: "presentation"}
      %button.nav-link{id: "full-network-mermaid-tab", type: "button", role: "tab", "data-bs-toggle": "tab", "data-bs-target": "#full-network-mermaid-pane", "aria-controls": "full-network-mermaid-pane", "aria-selected": "false"}
        Mermaid
    %li.nav-item{role: "presentation"}
      %button.nav-link{id: "full-network-highcharts-sankey-tab", type: "button", role: "tab", "data-bs-toggle": "tab", "data-bs-target": "#full-network-highcharts-sankey-pane", "aria-controls": "full-network-highcharts-sankey-pane", "aria-selected": "false"}
        Highcharts – Sankey
    %li.nav-item{role: "presentation"}
      %button.nav-link{id: "full-network-highcharts-network-tab", type: "button", role: "tab", "data-bs-toggle": "tab", "data-bs-target": "#full-network-highcharts-network-pane", "aria-controls": "full-network-highcharts-network-pane", "aria-selected": "false"}
        Highcharts – Network
    %li.nav-item{role: "presentation"}
      %button.nav-link{id: "full-network-g6-tab", type: "button", role: "tab", "data-bs-toggle": "tab", "data-bs-target": "#full-network-g6-pane", "aria-controls": "full-network-g6-pane", "aria-selected": "false"}
        G6
    %li.nav-item{role: "presentation"}
      %button.nav-link{id: "full-network-vis-tab", type: "button", role: "tab", "data-bs-toggle": "tab", "data-bs-target": "#full-network-vis-pane", "aria-controls": "full-network-vis-pane", "aria-selected": "false"}
        vis.js
  .tab-content.pt-3
    .tab-pane.fade.show.active{id: "full-network-cytoscape-pane", role: "tabpanel", "aria-labelledby": "full-network-cytoscape-tab", data: { assignment_full_network_graph_target: "cytoscapePane" }}
      %p.small.text-muted.mb-2
        Interactive supply network. Click a node to open that assignment, or export as PNG or SVG.
      - cytoscape_locals = cytoscape_supply_flow_graph_locals(elements: network_graph.cytoscape_elements, root_node_ids: network_graph.cytoscape_root_node_ids, layoutable: organization, graph_kind: "full_network", organization: organization)
      = render partial: "shared/cytoscape/supply_flow_graph", locals: cytoscape_locals.merge(export_filename: "organization-assignment-supply-network", lazy: true, aria_label: "Interactive map of assignment supply relationships")
    .tab-pane.fade{id: "full-network-mermaid-pane", role: "tabpanel", "aria-labelledby": "full-network-mermaid-tab", data: { assignment_full_network_graph_target: "mermaidPane" }}
      %p.small.text-muted.mb-2
        Top-to-bottom flowchart. Click a node to open that assignment.
      .assignment-flow-mermaid.assignment-full-network-graph-mermaid{
        data: {
          controller: "assignment-flow-mermaid",
          assignment_flow_mermaid_lazy_value: true,
          assignment_flow_mermaid_source_value: mermaid_flowchart_dsl(assignments, supply_relationships, organization: organization),
          assignment_flow_mermaid_click_urls_value: mermaid_assignment_click_urls(assignments, organization: organization).to_json,
          assignment_full_network_graph_target: "mermaidContainer"
        }
      }
    .tab-pane.fade{id: "full-network-highcharts-sankey-pane", role: "tabpanel", "aria-labelledby": "full-network-highcharts-sankey-tab", data: { assignment_full_network_graph_target: "highchartsSankeyPane" }}
      %p.small.text-muted.mb-2
        Structured left-to-right flows (supplier → consumer). Click a node to open that assignment.
      #full-network-highcharts-sankey.assignment-full-network-graph-highcharts{
        data: { assignment_full_network_graph_target: "highchartsSankeyContainer" }
      }
    .tab-pane.fade{id: "full-network-highcharts-network-pane", role: "tabpanel", "aria-labelledby": "full-network-highcharts-network-tab", data: { assignment_full_network_graph_target: "highchartsNetworkPane" }}
      %p.small.text-muted.mb-2
        Force-directed layout with physics simulation. Pan and zoom; click a node to open that assignment.
      #full-network-highcharts-network.assignment-full-network-graph-highcharts{
        data: { assignment_full_network_graph_target: "highchartsNetworkContainer" }
      }
    .tab-pane.fade{id: "full-network-g6-pane", role: "tabpanel", "aria-labelledby": "full-network-g6-tab", data: { assignment_full_network_graph_target: "g6Pane" }}
      %p.small.text-muted.mb-2
        Ant Design G6 directed layout (left → right). Pan, zoom, and click a node to open that assignment.
      #full-network-g6-chart.assignment-full-network-graph-g6{
        data: { assignment_full_network_graph_target: "g6Container" }
      }
    .tab-pane.fade{id: "full-network-vis-pane", role: "tabpanel", "aria-labelledby": "full-network-vis-tab", data: { assignment_full_network_graph_target: "visPane" }}
      %p.small.text-muted.mb-2
        Hierarchical left-to-right layout (vis-network). Click a node to open that assignment.
      #full-network-vis-chart.assignment-full-network-graph-vis{
        data: { assignment_full_network_graph_target: "visContainer" }
      }
  %p.small.text-muted.mb-0.mt-3
    %i.bi.bi-arrow-right.me-1
    Arrows show supply direction: an assignment on the left supplies results consumed by the assignment on the right.
