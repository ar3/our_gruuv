- content_for :title, "New Team"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Teams", url: organization_teams_path(@organization) }, { label: "New team", url: nil }])

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0
      %i.bi.bi-plus-circle.me-2
      New Team

.row.justify-content-center
  .col-lg-8
    .card
      .card-body
        = render 'form', team: @team
