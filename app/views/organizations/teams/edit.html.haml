- content_for :title, "Edit Team"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: @team.name, url: organization_team_path(@organization, @team) }, { label: "Edit", url: nil }])

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0
      %i.bi.bi-pencil.me-2
      Edit Team

.row.justify-content-center
  .col-lg-8
    .card
      .card-body
        = render 'form', team: @team
