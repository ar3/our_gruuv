- content_for :title, "Start Here"
- org_name = current_organization&.name || "Organization"
- dash = @start_here_dashboard
- rows = dash.active_rows

- content_for :header do
  .d-flex.flex-wrap.align-items-center.justify-content-between.gap-2.w-100
    %div
      %h1.mb-0 Start Here
      %p.lead.text-muted.mb-0
        A quick guide to #{org_name}'s Gruuv. Pick a place to go.

- preset_confirm = "This replaces your current Start Here layout. You can still add, remove, and reorder widgets afterward. Continue?"

- if rows.empty?
  .alert.alert-info.mb-4
    You have no widgets on this page yet. Use “Add new widgets” below.

.row.g-4{data: { controller: "start-here-dashboard", start_here_dashboard_url_value: organization_start_here_widget_dashboards_path(current_organization) }}
  - rows.each do |row|
    - w = row[:widget]
    - wid = row[:id]
    - collapse_id = "start-here-widget-tools-#{wid}"
    .col-12.col-sm-6.col-md-4
      .card.h-100.border-0.shadow-sm
        .card-body.d-flex.flex-column
          %h5.card-title.mb-2= w.display_title
          .mb-3.start-here-dashboard-content
            .start-here-dashboard-slot{data: { widget_id: wid, start_here_dashboard_target: "slot" }}
              .start-here-dashboard-skeleton.placeholder-glow
                .placeholder.col-12.mb-2.rounded{style: "height: 0.9rem;"}
                .placeholder.col-10.mb-2.rounded{style: "height: 0.9rem;"}
                .placeholder.col-11.rounded{style: "height: 0.9rem;"}
              .start-here-dashboard-body.d-none
              .start-here-dashboard-error.alert.alert-warning.py-2.px-3.small.d-none{role: "alert"}
                %p.mb-1.start-here-dashboard-error-message
                %button.btn.btn-link.btn-sm.p-0.align-baseline{type: "button", data: { action: "start-here-dashboard#retry" }} Retry
          .row.g-2.align-items-center.mt-auto
            .col-10
              - if w.button_path.present?
                = link_to w.button_path, class: "btn btn-primary btn-lg w-100" do
                  %i{class: "#{w.icon} me-2"}
                  = w.button_label
            .col-2.text-end
              %button.btn.btn-link.text-muted.p-0{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "##{collapse_id}", "aria-expanded": "false", "aria-controls": collapse_id}
                %i.bi.bi-pencil.fs-5
          .collapse.border-top.mt-3.pt-3{id: collapse_id}
            .row.g-3.align-items-end
              .col-12.col-md-6
                = button_to "Remove", organization_start_here_remove_widget_path(current_organization), method: :post, params: { widget_id: wid }, form: { data: { turbo: false } }, class: "btn btn-outline-danger"
              .col-12.col-md-6
                = form_with url: organization_start_here_reorder_widget_path(current_organization), method: :post, local: true, html: { data: { turbo: false } }, class: "d-flex flex-wrap align-items-center gap-2 justify-content-md-end" do
                  = hidden_field_tag :widget_id, wid
                  %label.small.text-muted.mb-0{for: "reorder_pos_#{wid}"} Position
                  = select_tag :position, options_for_select((1..row[:total]).to_a, row[:position]), id: "reorder_pos_#{wid}", class: "form-select form-select-sm", style: "width: auto; min-width: 4rem;", onchange: "this.form.submit()"

.start-here-add-widgets-section{data: { controller: "start-here-add-widgets" }}
  .mt-2.mb-4
    %button.btn.btn-outline-primary.w-100.text-center{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#start-here-add-widgets", "aria-expanded": "false", "data-start-here-add-widgets-target": "trigger"}
      Add new widgets

  .collapse.mb-5#start-here-add-widgets
    .d-flex.justify-content-end.mb-2
      %button.btn.btn-sm.btn-link.text-muted.text-decoration-none{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "#start-here-add-widgets", "aria-expanded": "true", "aria-controls": "start-here-add-widgets"}
        Hide add widgets
    .card.mb-3.border
      .card-body
        %p.small.text-muted.mb-2 Replace your whole layout with a starter set (you can still edit widgets afterward).
        .d-flex.flex-wrap.gap-2
          = button_to "Manager default", organization_start_here_apply_preset_path(current_organization), method: :post, params: { preset: "manager" }, form: { data: { turbo: false }, onsubmit: "return confirm(#{preset_confirm.to_json});" }, class: "btn btn-sm btn-outline-secondary"
          = button_to "Non-manager default", organization_start_here_apply_preset_path(current_organization), method: :post, params: { preset: "non_manager" }, form: { data: { turbo: false }, onsubmit: "return confirm(#{preset_confirm.to_json});" }, class: "btn btn-sm btn-outline-secondary"
          = button_to "OG enthusiast default", organization_start_here_apply_preset_path(current_organization), method: :post, params: { preset: "og_enthusiast" }, form: { data: { turbo: false }, onsubmit: "return confirm(#{preset_confirm.to_json});" }, class: "btn btn-sm btn-outline-secondary"
    %hr.my-3
    %p.small.text-muted.mb-2 Add individual widgets by group.
    - dash.inactive_widgets_by_group.each do |group_name, widgets|
      .card.mb-3
        .card-header.fw-semibold.small.text-uppercase.text-muted= group_name
        .card-body
          - if widgets.any?
            - widgets.each do |iw|
              .row.g-2.align-items-center.border-bottom.py-3
                .col-12.col-md-3.fw-semibold= iw.selection_title
                .col-12.col-md-6.text-muted.small= iw.selection_description
                .col-12.col-md-3
                  = button_to "Add", organization_start_here_add_widget_path(current_organization), method: :post, params: { widget_id: iw.widget_id }, form: { data: { turbo: false } }, class: "btn btn-outline-primary w-100 w-md-auto"
          - else
            %p.small.text-muted.mb-0 All added in this group.

- prefs = current_user_preferences
- layout_cur = prefs.layout.to_s.presence || "vertical"

%hr.my-4
%a.start-here-customize-toggle.h5.fw-semibold.text-body.text-decoration-none.d-inline-flex.align-items-center.gap-2.mb-3.collapsed{href: "#start-here-other-customize", role: "button", data: { turbo: false, bs_toggle: "collapse", bs_target: "#start-here-other-customize" }, "aria-expanded": "false", "aria-controls": "start-here-other-customize"}
  Other ways to customize OurGruuv
  %i.bi.bi-chevron-down.start-here-customize-chevron-down{aria: { hidden: true }}
  %i.bi.bi-chevron-up.start-here-customize-chevron-up{aria: { hidden: true }}

.collapse#start-here-other-customize
  - if show_start_page_picker_on_start_here?(prefs)
    .mb-4
      %label.form-label.small.fw-semibold.mb-1{for: "start_here_start_page"} Start page when I open #{org_name}
      = form_with url: organization_start_here_update_start_page_path(current_organization), method: :post, local: true, html: { data: { turbo: false }, class: "mb-0" } do
        = select_tag :start_page, options_for_select(start_page_options_for_select(current_organization, current_company_teammate), start_page_preference(current_organization, current_person)), { id: "start_here_start_page", class: "form-select", onchange: "this.form.submit()" }
      %p.form-text.text-muted.small.mb-0 Choose where you land when you sign in or click the org name in the header.

  .mb-4
    %p.small.fw-semibold.text-muted.mb-2 Navigation style
    .d-flex.flex-wrap.gap-2
      = button_to "Vertical", layout_user_preferences_path, method: :patch, params: { layout: "vertical" }, form: { data: { turbo: false }, class: "d-inline" }, class: "btn btn-sm #{layout_cur == 'vertical' ? 'btn-primary' : 'btn-outline-secondary'}"
      = button_to "Horizontal", layout_user_preferences_path, method: :patch, params: { layout: "horizontal" }, form: { data: { turbo: false }, class: "d-inline" }, class: "btn btn-sm #{layout_cur == 'horizontal' ? 'btn-primary' : 'btn-outline-secondary'}"
      = button_to "Clean/No Navigation", layout_user_preferences_path, method: :patch, params: { layout: "no_nav" }, form: { data: { turbo: false }, class: "d-inline" }, class: "btn btn-sm #{layout_cur == 'no_nav' ? 'btn-primary' : 'btn-outline-secondary'}"

  .mb-5
    .alert.alert-info.mb-0
      Digest timing and delivery preferences moved to Digest settings.
      = link_to "Open digest settings", edit_organization_digest_path(current_organization, return_url: organization_start_here_path(current_organization), return_text: "Back to Start Here"), class: "alert-link ms-1"
