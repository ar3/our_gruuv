- rows = ObservationsInvolvingMeDashboardCounts.new(organization: context.organization, person: context.person, company_teammate: context.company_teammate).rows
.start-here-observations-involving-me-dashboard
  %table.table.table-sm.table-bordered.mb-0.small.text-muted
    %thead
      %tr
        %th
        %th.text-end Last 90 days
        %th.text-end All time
    %tbody
      - rows.each do |label, n90, all|
        %tr
          %td= label
          %td.text-end= number_with_delimiter(n90)
          %td.text-end= number_with_delimiter(all)
