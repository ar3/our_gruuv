- ct = context.company_teammate
- org = context.organization
- records = ct.present? && org.present? ? EngagementHealth::ClarityMetrics.records_for_teammate(organization: org, teammate_id: ct.id) : []
- breakdown = EngagementHealth::ClarityActionMetrics.for_records(records)
- names = ct.present? ? teammate_and_manager_short_names(ct, org) : { employee: "Employee", manager: "Manager" }
- action_popover_html = check_ins_health_action_popover_html(records: records, employee_name: names[:employee], manager_name: names[:manager])
- name = ERB::Util.html_escape(context.casual_name.to_s)
- up_next_url = ct.present? && org.present? ? up_next_organization_company_teammate_check_ins_path(org, ct) : nil
.start-here-check-in-status-dashboard.mb-3
  .d-flex.align-items-center.flex-wrap.gap-2
    %p.small.mb-0= "#{name}, you are".html_safe
    = render "shared/clarity_action_slots/summary",
             breakdown: breakdown,
             popover_html: action_popover_html,
             url: up_next_url,
             show_bar: false
