- ct = context.company_teammate
- org = context.organization
- records = ct.present? && org.present? ? EngagementHealth::ClarityMetrics.records_for_teammate(organization: org, teammate_id: ct.id) : []
- breakdown = EngagementHealth::ClarityMetrics.breakdown(records)
- total = breakdown&.fetch(:completion_rate, 0) || 0
- values_pct = breakdown&.fetch(:aspirations_pct, 0) || 0
- assignments_pct = breakdown&.fetch(:assignments_pct, 0) || 0
- position_pct = breakdown&.fetch(:position_pct, 0) || 0
- name = ERB::Util.html_escape(context.casual_name.to_s)
.start-here-check-in-status-dashboard.mb-3
  %p.small.mb-2= "#{name}, you are #{total}% healthy on required clarity check-ins.".html_safe
  %table.table.table-sm.table-bordered.small.mb-0
    %thead
      %tr
        %th{scope: "col"} Values
        %th{scope: "col"} Assignments
        %th{scope: "col"} Position
    %tbody
      %tr
        %td.text-end= "#{values_pct}%"
        %td.text-end= "#{assignments_pct}%"
        %td.text-end= "#{position_pct}%"
