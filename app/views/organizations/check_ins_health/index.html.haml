- content_for :title, "Check-ins Health Dashboard"

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-clipboard-check.me-2
      Check-ins Health Dashboard
      %span.d-inline-flex.align-items-center.ms-2{"data-bs-toggle" => "tooltip", "data-bs-placement" => "top", "data-bs-title" => "Quickly monitor who needs clarity support. Click for a full breakdown of this page."}
        %button.btn.btn-link.p-0.text-body{type: "button", "data-bs-toggle" => "collapse", "data-bs-target" => "#checkInsHealthPageInfo", "aria-expanded" => "false", "aria-controls" => "checkInsHealthPageInfo", "aria-label" => "Show page explanation"}
          %i.bi.bi-info-circle.fs-1.lh-1.align-middle{style: "text-shadow: 0 1px 3px rgba(0,0,0,0.25);"}

.mb-4
  = content_for :go_back_link

.collapse.mb-4#checkInsHealthPageInfo
  .alert.alert-info.mb-0
    %h5.fw-semibold.mb-2 Ultimate goal
    %p.mb-3 Give a manager a quick view at where they should focus in order to keep their folks 100% clear.
    %p.mb-2
      %strong How to read each row:
      the top bar shows Gruuv Health Required Clarity per item (Healthy, At Risk, Needs Attention); the bottom bar shows what action to take next on each check-in.
    %p.mb-3 Hover any segment for details. Use refresh controls when data seems stale — they queue a Gruuv Health recalculation.

    .card.mb-3
      .card-header.py-2
        %strong Example employee row
      .card-body.py-2
        .table-responsive
          %table.table.table-sm.mb-2
            %thead
              %tr
                %th Employee
                %th Aspirations
                %th Assignments
                %th Position
            %tbody
              %tr
                %td
                  Alex Rivera
                  %br
                  %small.text-muted Casey Manager
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 80px;"}
                    .flex-grow-0.check-in-health-eh-at-risk{style: "width: 100%;"}
                  .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 6px; min-width: 80px;"}
                    .flex-grow-0.check-in-health-action-red{style: "width: 100%;"}
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 80px;"}
                    .flex-grow-0.check-in-health-eh-healthy{style: "width: 50%;"}
                    .flex-grow-0.check-in-health-eh-at-risk{style: "width: 50%;"}
                  .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 6px; min-width: 80px;"}
                    .flex-grow-0.check-in-health-action-green-striped{style: "width: 50%;"}
                    .flex-grow-0.check-in-health-action-orange{style: "width: 50%;"}
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 60px;"}
                    .flex-grow-0.check-in-health-eh-healthy{style: "width: 100%;"}
                  .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 6px; min-width: 60px;"}
                    .flex-grow-0.check-in-health-action-neon-green-striped{style: "width: 100%;"}
        .row.g-2.small
          .col-12.col-lg-6
            %div
              %i.bi.bi-arrow-up-right.me-1
              Top bars (taller) show Gruuv Health per required item.
            %div
              %i.bi.bi-arrow-up-right.me-1
              Bottom bars (shorter) show the recommended next action for each item.
          .col-12.col-lg-6
            %div
              %i.bi.bi-arrow-up-right.me-1
              Hover a segment for status, last finalized date, and next steps.
            %div
              %i.bi.bi-arrow-up-right.me-1
              Refresh controls should be used only when data seems stale/incorrect.

    .row
      .col-12.col-lg-6
        %h6.fw-semibold.mb-2 Top bar (Gruuv Health Required Clarity)
        %ul.mb-0
          - [EngagementHealth::NEEDS_ATTENTION, EngagementHealth::AT_RISK, EngagementHealth::HEALTHY].each do |status|
            %li
              %span.d-inline-block.rounded-circle.me-2.align-middle{class: check_ins_health_eh_status_swatch_css(status), style: "width: 10px; height: 10px;"}
              %strong= EngagementHealth::STATUS_LABELS.fetch(status)
              = " - #{check_ins_health_engagement_status_meaning(status)}"
      .col-12.col-lg-6
        %h6.fw-semibold.mb-2 Bottom bar (action-based)
        %ul.mb-0
          - check_ins_health_action_bar_legend_items.each do |legend|
            %li
              %span.d-inline-block.rounded-circle.me-2.align-middle{class: legend[:css], style: "width: 10px; height: 10px;"}
              %strong= legend[:color].humanize
              = " - #{legend[:label]}"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Check-ins Health Dashboard", url: nil }])

/ Spotlight Section
.row.justify-content-center.mb-4
  .col-lg-12
    .card.border-0.shadow-sm
      .card-body
        .row.text-center.g-2
          .col
            .h3.text-primary.mb-0= @spotlight_stats[:total_employees]
            %small.text-muted Total Active Employees
          .col
            .h3.text-success.mb-0= @spotlight_stats[:healthy_count]
            %small.text-muted Healthy
          .col
            .h3.text-warning.mb-0= @spotlight_stats[:at_risk_count]
            %small.text-muted At Risk
          .col
            .h3.text-danger.mb-0= @spotlight_stats[:needs_attention_count]
            %small.text-muted Needs Attention
          .col
            .h3.text-info.mb-0= "#{@spotlight_stats[:ok_percentage]}%"
            %small.text-muted "% Ok"
      .card-footer.bg-light
        .row.align-items-center
          .col-md-6
            %small.text-muted
              %i.bi.bi-building.me-1
              Organization: #{@organization.display_name}
          .col-md-6.text-end
            %small.text-muted
              %i.bi.bi-clipboard-check.me-1
              Bar colors: top = Gruuv Health; bottom = next action per item

/ Filter (below spotlight, above table)
.row.justify-content-center.mb-4
  .col-lg-12
    .card.border-0.shadow-sm
      .card-body
        = form_with url: organization_check_ins_health_path(@organization), method: :get, local: true, id: "check-ins-health-filter-form" do |f|
          .row.align-items-end
            .col-md-10
              %label.form-label.fw-bold.fs-5.mb-2 Who to show
              = select_tag :manager_id, options_for_select(@available_manager_filter_options, @current_manager_filter), class: "form-select form-select-lg", id: "check-ins-health-manager-select", required: true
              %small.form-text.text-muted Choose scope: everyone, your reports, or a specific manager's direct reports
            .col-md-2
              = f.submit "Go", class: "btn btn-primary btn-lg w-100"
          - if params[:page].present?
            = hidden_field_tag :page, params[:page]

/ Health dashboard switcher + page actions
.row.justify-content-center.mb-3
  .col-lg-12
    = render "organizations/health/dashboard_switcher", organization: @organization, current: :check_ins_health, manager_id: @current_manager_filter
    .d-flex.gap-2.flex-wrap.align-items-center
      = link_to organization_check_ins_health_export_path(@organization, manager_id: @current_manager_filter), class: 'btn btn-outline-primary' do
        %i.bi.bi-download.me-2
        Download check-ins (CSV)
      = link_to organization_check_ins_health_employee_summary_export_path(@organization, manager_id: @current_manager_filter), class: 'btn btn-outline-primary' do
        %i.bi.bi-download.me-2
        Download employee check-in summary CSV
      - if can_view_check_ins_health_by_manager?
        = link_to organization_check_ins_health_by_manager_path(@organization), class: 'btn btn-outline-primary' do
          %i.bi.bi-people.me-2
          By manager
      - else
        %span.d-inline-block{title: "You must be a manager with direct reports to view the By Manager page.", "data-bs-toggle" => "tooltip", "data-bs-placement" => "top"}
          %button.btn.btn-outline-secondary.disabled{type: "button", disabled: true}
            %i.bi.bi-exclamation-triangle.me-2
            By manager
      = link_to organization_insights_check_ins_progress_path(@organization), class: 'btn btn-outline-secondary' do
        %i.bi.bi-bar-chart-steps.me-2
        Check-ins Progress

/ Pagination Info
.row.justify-content-center.mb-2
  .col-lg-12
    .d-flex.justify-content-between.align-items-center
      %small.text-muted= raw pagy_info(@pagy)

/ Main table: Employee | Aspirations | Assignments | Position
.row.justify-content-center
  .col-lg-12
    - if @employee_health_data.any?
      .table-responsive
        %table.table.table-hover.table-layout-fixed
          %colgroup
            %col{style: "width: 25%"}
            %col{style: "width: 25%"}
            %col{style: "width: 35%"}
            %col{style: "width: 15%"}
          %thead
            %tr
              %th
                .d-flex.align-items-center.justify-content-between.gap-2
                  %span Employee
                  = button_to organization_check_ins_health_refresh_all_path(@organization),
                              method: :post,
                              params: { manager_id: @current_manager_filter },
                              class: "btn btn-link btn-sm p-0 text-muted",
                              form: { class: "d-inline" },
                              title: "Refresh all in current filter" do
                    %i.bi.bi-arrow-repeat.me-1
                    Refresh all
              %th Aspirations
              %th Assignments
              %th Position
          %tbody
            - @employee_health_data.each do |data|
              - person = data[:person]
              - teammate = data[:teammate]
              - engagement_records = data[:engagement_health_records]
              - manager_teammate = data[:manager_teammate]
              %tr
                %td.align-top{style: "width: 25%", rowspan: 2}
                  .d-flex.align-items-center.gap-2
                    = link_to person.display_name, organization_company_teammate_check_ins_path(@organization, teammate), class: "text-decoration-none fw-bold"
                    - refreshed_tooltip = check_ins_health_engagement_refreshed_tooltip(engagement_records)
                    = button_to organization_check_ins_health_refresh_path(@organization, teammate_id: teammate.id), method: :post, class: "btn btn-link btn-sm p-0 text-muted", title: refreshed_tooltip, form: { class: "d-inline" } do
                      %i.bi.bi-arrow-clockwise
                  - if manager_teammate
                    %small.text-muted
                      = link_to manager_teammate.person&.display_name, organization_check_ins_health_path(@organization, manager_id: "CompanyTeammate_#{manager_teammate.id}"), class: "text-muted"
                  - else
                    %small.text-muted —
                
                %td{style: "width: 25%"}
                  - if engagement_records.any?
                    - aspiration_segments = check_ins_health_item_bar_segments(records: engagement_records, entity_type: "Aspiration", teammate: teammate, organization: @organization)
                    .check-ins-health-bars{data: { controller: "check-ins-health-bars" }}
                      = render "organizations/check_ins_health/item_bars", segments: aspiration_segments, bar_key: :eh, height_px: 24, empty_label: "No aspirations", show_initials: true
                      = render "organizations/check_ins_health/item_bars", segments: aspiration_segments, bar_key: :action, height_px: 8, empty_label: "No aspirations"
                  - else
                    %span.text-muted Pending
                
                %td{style: "width: 35%"}
                  - if engagement_records.any?
                    - assignment_segments = check_ins_health_item_bar_segments(records: engagement_records, entity_type: "Assignment", teammate: teammate, organization: @organization)
                    .check-ins-health-bars{data: { controller: "check-ins-health-bars" }}
                      = render "organizations/check_ins_health/item_bars", segments: assignment_segments, bar_key: :eh, height_px: 24, empty_label: "No assignments", show_initials: true
                      = render "organizations/check_ins_health/item_bars", segments: assignment_segments, bar_key: :action, height_px: 8, empty_label: "No assignments"
                  - else
                    %span.text-muted Pending
                
                %td{style: "width: 15%"}
                  - if engagement_records.any?
                    - position_segments = check_ins_health_item_bar_segments(records: engagement_records, entity_type: "Position", teammate: teammate, organization: @organization)
                    .check-ins-health-bars{data: { controller: "check-ins-health-bars" }}
                      = render "organizations/check_ins_health/item_bars", segments: position_segments, bar_key: :eh, height_px: 24, empty_label: "—"
                      = render "organizations/check_ins_health/item_bars", segments: position_segments, bar_key: :action, height_px: 8, empty_label: "—"
                  - else
                    %span.text-muted Pending
                
              %tr
                %td{colspan: 4}
                  - if engagement_records.any?
                    - alert_data = check_ins_health_engagement_alert_data(records: engagement_records, organization: @organization, teammate: teammate)
                    - if alert_data[:all_clear]
                      .alert.alert-success.py-1.mb-0.small
                        %i.bi.bi-check-circle-fill.me-1
                        = alert_data[:message]
                    - else
                      .alert.alert-warning.py-1.mb-0.small
                        %i.bi.bi-exclamation-triangle-fill.me-1
                        - if alert_data[:url].present?
                          = link_to alert_data[:message], alert_data[:url], class: "alert-link text-decoration-none"
                        - else
                          = alert_data[:message]
                  - else
                    .alert.alert-secondary.py-1.mb-0.small
                      %i.bi.bi-hourglass-split.me-1
                      Waiting for Gruuv Health data refresh.
      .d-flex.justify-content-center.mt-4
        - if @pagy.pages > 1
          = raw pagy_nav(@pagy)
    - else
      .alert.alert-info
        %h6.mb-2
          %i.bi.bi-info-circle.me-2
          No one in this view
        %p.mb-2
          Change the filter above or there are no active employees in the selected scope.
