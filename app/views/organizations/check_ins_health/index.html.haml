- content_for :title, "Check-ins Health Dashboard"

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-clipboard-check.me-2
      Check-ins Health Dashboard
      %span.d-inline-flex.align-items-center.ms-2{"data-bs-toggle" => "tooltip", "data-bs-placement" => "top", "data-bs-title" => "Quickly monitor who needs clarity support. Click for a full breakdown of this page."}
        %button.btn.btn-link.p-0.text-body{type: "button", "data-bs-toggle" => "collapse", "data-bs-target" => "#checkInsHealthPageInfo", "aria-expanded" => "false", "aria-controls" => "checkInsHealthPageInfo", "aria-label" => "Show page explanation"}
          %i.bi.bi-info-circle.fs-1.lh-1.align-middle{style: "text-shadow: 0 1px 3px rgba(0,0,0,0.25);"}

.mb-4
  = content_for :go_back_link

.collapse.mb-4#checkInsHealthPageInfo
  .alert.alert-info.mb-0
    %h5.fw-semibold.mb-2 Ultimate goal
    %p.mb-3 Give a manager a quick view at where they should focus in order to keep their folks 100% clear.
    %p.mb-2
      %strong How to read each row:
      the top bar shows what state you and your employees are in for current check-ins; the bottom bar shows how long ago the last check-in was completed.
    %p.mb-3 Use refresh controls only when you believe the data is out-of-date and want to queue a background refresh.

    .card.mb-3
      .card-header.py-2
        %strong Example employee row
      .card-body.py-2
        .table-responsive
          %table.table.table-sm.mb-2
            %thead
              %tr
                %th Employee
                %th Aspirations
                %th Assignments
                %th Position
                %th Milestones
            %tbody
              %tr
                %td
                  Alex Rivera
                  %br
                  %small.text-muted Casey Manager
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 80px;"}
                    .flex-grow-0.bg-warning{style: "width: 100%;"}
                  .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 6px; min-width: 80px;"}
                    .flex-grow-0.bg-danger{style: "width: 100%;"}
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 80px;"}
                    .flex-grow-0.bg-success{style: "width: 55%;"}
                    .flex-grow-0.bg-warning{style: "width: 45%;"}
                  .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 6px; min-width: 80px;"}
                    .flex-grow-0.bg-success{style: "width: 50%;"}
                    .flex-grow-0.bg-warning{style: "width: 50%;"}
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 60px;"}
                    .flex-grow-0.bg-success{style: "width: 100%;"}
                  .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 6px; min-width: 60px;"}
                    .flex-grow-0.check-in-health-neon-green{style: "width: 100%;"}
                %td
                  .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 16px; min-width: 60px;"}
                    .flex-grow-0.bg-success{style: "width: 70%;"}
                    .flex-grow-0.bg-danger{style: "width: 30%;"}
        .row.g-2.small
          .col-12.col-lg-6
            %div
              %i.bi.bi-arrow-up-right.me-1
              Top bars (taller bars) explain current check-in workflow status.
            %div
              %i.bi.bi-arrow-up-right.me-1
              Bottom bars (shorter bars) explain recency of completed check-ins.
          .col-12.col-lg-6
            %div
              %i.bi.bi-arrow-up-right.me-1
              Row alert text points to the most urgent thing to check in on next.
            %div
              %i.bi.bi-arrow-up-right.me-1
              Refresh controls should be used only when data seems stale/incorrect.

    .row
      .col-12.col-lg-6
        %h6.fw-semibold.mb-2 Top bar states (check-in workflow state)
        %ul.mb-0
          - CheckInHealthHelper::CHECK_IN_HEALTH_BAR_ORDER.each do |category|
            %li
              %span.d-inline-block.rounded-circle.me-2.align-middle{class: check_in_health_category_css(category), style: "width: 10px; height: 10px;"}
              %strong= category.humanize
              = " - #{check_in_health_category_meaning(category)}"
      .col-12.col-lg-6
        %h6.fw-semibold.mb-2 Bottom bar states (last completed recency)
        %ul.mb-0
          - %w[crystal_clear clear blurred obscured].each do |clarity_level|
            %li
              %span.d-inline-block.rounded-circle.me-2.align-middle{class: required_check_in_category_css(clarity_level), style: "width: 10px; height: 10px;"}
              %strong= clarity_level.humanize
              = " - #{required_check_in_clarity_meaning(clarity_level)}"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Check-ins Health Dashboard", url: nil }])

/ Spotlight Section
.row.justify-content-center.mb-4
  .col-lg-12
    .card.border-0.shadow-sm
      .card-body
        .row
          .col-md-8
            .row.text-center
              .col-3
                .h3.text-primary= @spotlight_stats[:total_employees]
                %small.text-muted Total Active Employees
              .col-3
                .h3.text-success= @spotlight_stats[:all_healthy]
                %small.text-muted All Healthy
              .col-3
                .h3.text-warning= @spotlight_stats[:needing_attention]
                %small.text-muted Need Attention
              .col-3
                .h3.text-info= "#{@spotlight_stats[:completion_rate]}%"
                %small.text-muted Completion Rate
          .col-md-4
            - if @spotlight_stats[:needing_attention] > 0
              .alert.alert-warning.small
                %i.bi.bi-exclamation-triangle.me-2
                %strong #{@spotlight_stats[:needing_attention]} employee#{'s' if @spotlight_stats[:needing_attention] != 1} need#{'s' if @spotlight_stats[:needing_attention] == 1} attention
      .card-footer.bg-light
        .row.align-items-center
          .col-md-6
            %small.text-muted
              %i.bi.bi-building.me-1
              Organization: #{@organization.display_name}
          .col-md-6.text-end
            %small.text-muted
              %i.bi.bi-clipboard-check.me-1
              Bar colors: Red (none) → Orange → Light Blue/Purple → Light Green → Green → Neon Green (finalized & acknowledged)

/ Filter (below spotlight, above table)
.row.justify-content-center.mb-4
  .col-lg-12
    .card.border-0.shadow-sm
      .card-body
        = form_with url: organization_check_ins_health_path(@organization), method: :get, local: true, id: "check-ins-health-filter-form" do |f|
          .row.align-items-end
            .col-md-10
              %label.form-label.fw-bold.fs-5.mb-2 Who to show
              = select_tag :manager_id, options_for_select(@available_manager_filter_options, @current_manager_filter), class: "form-select form-select-lg", id: "check-ins-health-manager-select", required: true
              %small.form-text.text-muted Choose scope: everyone, your reports, or a specific manager's direct reports
            .col-md-2
              = f.submit "Go", class: "btn btn-primary btn-lg w-100"
          - if params[:page].present?
            = hidden_field_tag :page, params[:page]

/ Download and link
.row.justify-content-center.mb-3
  .col-lg-12.d-flex.gap-2.flex-wrap.align-items-center
    = link_to organization_check_ins_health_export_path(@organization, manager_id: @current_manager_filter), class: 'btn btn-outline-primary' do
      %i.bi.bi-download.me-2
      Download check-ins (CSV)
    = link_to organization_check_ins_health_employee_summary_export_path(@organization, manager_id: @current_manager_filter), class: 'btn btn-outline-primary' do
      %i.bi.bi-download.me-2
      Download employee check-in summary CSV
    - if can_view_check_ins_health_by_manager?
      = link_to organization_check_ins_health_by_manager_path(@organization), class: 'btn btn-outline-primary' do
        %i.bi.bi-people.me-2
        By manager
    - else
      %span.d-inline-block{title: "You must be a manager with direct reports to view the By Manager page.", "data-bs-toggle" => "tooltip", "data-bs-placement" => "top"}
        %button.btn.btn-outline-secondary.disabled{type: "button", disabled: true}
          %i.bi.bi-exclamation-triangle.me-2
          By manager
    = link_to organization_insights_check_ins_progress_path(@organization), class: 'btn btn-outline-secondary' do
      %i.bi.bi-bar-chart-steps.me-2
      Check-ins Progress

/ Pagination Info
.row.justify-content-center.mb-2
  .col-lg-12
    .d-flex.justify-content-between.align-items-center
      %small.text-muted= raw pagy_info(@pagy)

/ Main table: Employee (20%) | Aspirations (20%) | Assignments (30%) | Position (15%) | Milestones (15%)
.row.justify-content-center
  .col-lg-12
    - if @employee_health_data.any?
      .table-responsive
        %table.table.table-hover.table-layout-fixed
          %colgroup
            %col{style: "width: 20%"}
            %col{style: "width: 20%"}
            %col{style: "width: 30%"}
            %col{style: "width: 15%"}
            %col{style: "width: 15%"}
          %thead
            %tr
              %th
                .d-flex.align-items-center.justify-content-between.gap-2
                  %span Employee
                  = button_to organization_check_ins_health_refresh_all_path(@organization),
                              method: :post,
                              params: { manager_id: @current_manager_filter },
                              class: "btn btn-link btn-sm p-0 text-muted",
                              form: { class: "d-inline" },
                              title: "Refresh all in current filter" do
                    %i.bi.bi-arrow-repeat.me-1
                    Refresh all
              %th Aspirations
              %th Assignments
              %th Position
              %th Milestones
          %tbody
            - @employee_health_data.each do |data|
              - person = data[:person]
              - teammate = data[:teammate]
              - cache = data[:cache]
              - manager_teammate = teammate.employment_tenures.active.where(company: @organization).first&.manager_teammate
              %tr
                %td.align-top{style: "width: 20%", rowspan: 2}
                  .d-flex.align-items-center.gap-2
                    = link_to person.display_name, organization_company_teammate_check_ins_path(@organization, teammate), class: "text-decoration-none fw-bold"
                    - refreshed_tooltip = cache&.refreshed_at ? "Last refreshed #{time_ago_in_words(cache.refreshed_at)} ago" : "Cache has not been refreshed yet"
                    = button_to organization_check_ins_health_refresh_path(@organization, teammate_id: teammate.id), method: :post, class: "btn btn-link btn-sm p-0 text-muted", title: refreshed_tooltip, form: { class: "d-inline" } do
                      %i.bi.bi-arrow-clockwise
                  - if manager_teammate
                    %small.text-muted
                      = link_to manager_teammate.person&.display_name, organization_check_ins_health_path(@organization, manager_id: "CompanyTeammate_#{manager_teammate.id}"), class: "text-muted"
                  - else
                    %small.text-muted —
                
                %td{style: "width: 20%"}
                  - if cache
                    - segments = check_in_health_stacked_bar_segments(check_in_health_category_counts(cache.payload_aspirations))
                    - if segments.any?
                      - total = segments.sum { |s| s[:count] }
                      .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 80px;"}
                        - segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_in_health_segment_tooltip(seg, total, "aspirations")}
                    - else
                      %span.text-muted No aspirations
                    - required_items = required_check_in_items_for(cache, :aspirations)
                    - required_segments = required_check_in_stacked_bar_segments(required_check_in_category_counts(required_items))
                    - if required_segments.any?
                      - total_required = required_segments.sum { |s| s[:count] }
                      .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 8px; min-width: 80px; opacity: 0.85;"}
                        - required_segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => required_check_in_segment_tooltip(seg, total_required, "aspirations")}
                  - else
                    %span.text-muted Pending
                
                %td{style: "width: 30%"}
                  - if cache
                    - segments = check_in_health_stacked_bar_segments(check_in_health_category_counts(cache.payload_assignments))
                    - if segments.any?
                      - total = segments.sum { |s| s[:count] }
                      .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 80px;"}
                        - segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_in_health_segment_tooltip(seg, total, "assignments")}
                    - else
                      %span.text-muted No assignments
                    - required_items = required_check_in_items_for(cache, :assignments)
                    - required_segments = required_check_in_stacked_bar_segments(required_check_in_category_counts(required_items))
                    - if required_segments.any?
                      - total_required = required_segments.sum { |s| s[:count] }
                      .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 8px; min-width: 80px; opacity: 0.85;"}
                        - required_segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => required_check_in_segment_tooltip(seg, total_required, "assignments")}
                  - else
                    %span.text-muted Pending
                
                %td{style: "width: 15%"}
                  - if cache
                    - segments = check_in_health_stacked_bar_segments(check_in_health_position_segment(cache.payload_position))
                    - if segments.any?
                      - total = segments.sum { |s| s[:count] }
                      .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 60px;"}
                        - segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_in_health_segment_tooltip(seg, total, "position")}
                    - else
                      %span.text-muted —
                    - required_items = required_check_in_items_for(cache, :position)
                    - required_segments = required_check_in_stacked_bar_segments(required_check_in_category_counts(required_items))
                    - if required_segments.any?
                      - total_required = required_segments.sum { |s| s[:count] }
                      .check-in-health-bar.d-flex.rounded.overflow-hidden.mt-1{style: "height: 8px; min-width: 60px; opacity: 0.85;"}
                        - required_segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => required_check_in_segment_tooltip(seg, total_required, "position")}
                  - else
                    %span.text-muted Pending
                
                %td{style: "width: 15%"}
                  - if cache
                    - ms = cache.payload_milestones
                    - total_req = ms['total_required'].to_i
                    - if total_req.positive?
                      - segments = check_in_health_stacked_bar_segments(check_in_health_milestone_segments(ms))
                      .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 60px;"}
                        - segments.each do |seg|
                          .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_in_health_milestone_segment_tooltip(seg, total_req)}
                    - else
                      %span.text-muted No milestones
                  - else
                    %span.text-muted Pending
              %tr
                %td{colspan: 3}
                  - if cache
                    - alert_data = required_check_in_alert_data(cache: cache, organization: @organization, teammate: teammate)
                    - if alert_data[:all_clear]
                      .alert.alert-success.py-1.mb-0.small
                        %i.bi.bi-check-circle-fill.me-1
                        = alert_data[:message]
                    - else
                      .alert.alert-warning.py-1.mb-0.small
                        %i.bi.bi-exclamation-triangle-fill.me-1
                        - if alert_data[:url].present?
                          = link_to alert_data[:message], alert_data[:url], class: "alert-link text-decoration-none"
                        - else
                          = alert_data[:message]
                  - else
                    .alert.alert-secondary.py-1.mb-0.small
                      %i.bi.bi-hourglass-split.me-1
                      Waiting for check-in health cache refresh.
                %td
      
      .d-flex.justify-content-center.mt-4
        - if @pagy.pages > 1
          = raw pagy_nav(@pagy)
    - else
      .alert.alert-info
        %h6.mb-2
          %i.bi.bi-info-circle.me-2
          No one in this view
        %p.mb-2
          Change the filter above or there are no active employees in the selected scope.
