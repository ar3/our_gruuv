- content_for :title, "Check-ins Health by Manager"

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-clipboard-check.me-2
      Check-ins Health by Manager
    .d-flex.align-items-center
      %small.text-muted.ms-3
        %i.bi.bi-info-circle.me-1
        Aggregated Gruuv Health Required Clarity for each manager's direct reports

.mb-4
  = content_for :go_back_link

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Check-ins Health Dashboard", url: organization_check_ins_health_path(@organization) }, { label: "Check-ins Health by Manager", url: nil }])

.row.justify-content-center
  .col-lg-12
    - if @manager_health_rows.any?
      .d-flex.align-items-center.mb-3
        %span.me-2.fw-medium Sort by
        .btn-group{role: "group"}
          = link_to "Name", organization_check_ins_health_by_manager_path(@organization, sort: "name"), class: "btn btn-sm #{@sort_by == 'name' ? 'btn-primary' : 'btn-outline-primary'}"
          = link_to "% employees are healthy", organization_check_ins_health_by_manager_path(@organization, sort: "completion_rate"), class: "btn btn-sm #{@sort_by == 'completion_rate' ? 'btn-primary' : 'btn-outline-primary'}"
      .table-responsive
        %table.table.table-hover.table-layout-fixed
          %colgroup
            %col{style: "width: 25%"}
            %col{style: "width: 25%"}
            %col{style: "width: 35%"}
            %col{style: "width: 15%"}
          %thead
            %tr
              %th Manager
              %th Aspirations
              %th Assignments
              %th Position
          %tbody
            - @manager_health_rows.each do |row|
              - mt = row[:manager_teammate]
              - segments_asp = check_ins_health_engagement_stacked_bar_segments(row[:aspiration_status_counts])
              - segments_assign = check_ins_health_engagement_stacked_bar_segments(row[:assignment_status_counts])
              - segments_pos = check_ins_health_engagement_stacked_bar_segments(row[:position_status_counts])
              %tr
                %td
                  = link_to mt.person&.display_name, organization_check_ins_health_path(@organization, manager_id: "CompanyTeammate_#{mt.id}"), class: "text-decoration-none fw-bold"
                  %br
                  %small.text-muted
                    #{row[:direct_report_count]} direct report#{'s' if row[:direct_report_count] != 1}
                    · #{row[:completion_rate]}% healthy
                %td
                  - if segments_asp.any?
                    - total = segments_asp.sum { |s| s[:count] }
                    .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 80px;"}
                      - segments_asp.each do |seg|
                        .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_ins_health_engagement_segment_tooltip(seg, total, "aspirations")}
                  - else
                    %span.text-muted No aspirations
                %td
                  - if segments_assign.any?
                    - total = segments_assign.sum { |s| s[:count] }
                    .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 80px;"}
                      - segments_assign.each do |seg|
                        .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_ins_health_engagement_segment_tooltip(seg, total, "assignments")}
                  - else
                    %span.text-muted No assignments
                %td
                  - if segments_pos.any?
                    - total = segments_pos.sum { |s| s[:count] }
                    .check-in-health-bar.d-flex.rounded.overflow-hidden{style: "height: 24px; min-width: 60px;"}
                      - segments_pos.each do |seg|
                        .flex-grow-0{style: "width: #{seg[:pct]}%;", class: seg[:css], "data-bs-toggle" => "tooltip", "data-bs-title" => check_ins_health_engagement_segment_tooltip(seg, total, "position")}
                  - else
                    %span.text-muted —
    - else
      .alert.alert-info
        %h6.mb-2
          %i.bi.bi-info-circle.me-2
          No managers with direct reports
        %p.mb-0
          There are no managers with direct reports in the current scope, or you do not have access to view them.
