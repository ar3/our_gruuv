- content_for :title, "Admin: Value / Billing"

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0
      %i.bi.bi-currency-dollar.me-2
      Value / Billing
    %span.badge.text-bg-warning
      %i.bi.bi-flask.me-1
      Beta

= render 'organizations/insights/timeframe_selector',
  timeframe: @timeframe,
  path_for: ->(**opts) { organization_value_billing_path(organization, **opts) },
  show_custom: true,
  custom_from: @insights_custom_from,
  custom_to: @insights_custom_to,
  wrapper_class: 'mb-3'

.row.mb-4
  .col-12
    .card.border-0.shadow-sm
      .card-body.border-start.border-5.border-primary{style: "background-color: #f8fbff;"}
        %p.fw-semibold.fs-3.mb-3 Clarity leads to both personal and team growth.
        - company_name = organization.display_name
        .d-grid.gap-2
          - @value_billing_outcome_rows.each do |row|
            - hover_copy = case row[:key]; when :stories then "The foundation of clarity is communication. We help teams communicate with radical candor and nonviolent communication by capturing observation-based stories. This represents #{number_with_delimiter(row[:teammate_count])} teammates across #{number_with_delimiter(row[:activity_count])} activities in this timeframe."; when :stand then "The only thing worse than being surprised in a performance review is vague and unactionable feedback in that review. We help people get specific feedback they can act on. This represents #{number_with_delimiter(row[:teammate_count])} teammates across #{number_with_delimiter(row[:activity_count])} activities in this timeframe."; when :growth then "Being clear about the behaviors, skills, and knowledge needed to exceed expectations drives continuous and predictable greatness. This represents #{number_with_delimiter(row[:teammate_count])} teammates across #{number_with_delimiter(row[:activity_count])} activities in this timeframe."; when :goals then "Goals you set and forget create the illusion of alignment. We help teams stay clear about why confidence is rising or falling so communication leads to real change. This represents #{number_with_delimiter(row[:teammate_count])} teammates across #{number_with_delimiter(row[:activity_count])} activities in this timeframe."; end
            .py-2{ class: ('border-top border-primary-subtle' unless row == @value_billing_outcome_rows.first) }
              .mb-1
                - if row[:key] == :stories
                  %span OG helped
                  %strong= " #{number_with_delimiter(row[:teammate_count])} teammates"
                  %span Capture
                  %strong= " #{number_with_delimiter(row[:activity_count])} #{company_name} #{'Story'.pluralize(row[:activity_count])}"
                - elsif row[:key] == :stand
                  %span OG helped
                  %strong= " #{number_with_delimiter(row[:teammate_count])} teammates"
                  %span Know where they stand across
                  %strong= " #{number_with_delimiter(row[:activity_count])} Performance Clarity Check-ins"
                - elsif row[:key] == :growth
                  %span OG helped
                  %strong= " #{number_with_delimiter(row[:teammate_count])} teammates"
                  %span be Recognized for demonstrating Growth across
                  %strong= " #{number_with_delimiter(row[:activity_count])} Milestone achievements"
                  %span awarded
                - elsif row[:key] == :goals
                  %span OG helped
                  %strong= " #{number_with_delimiter(row[:teammate_count])} teammates"
                  %span Communicate Real Progress across
                  %strong= " #{number_with_delimiter(row[:activity_count])} Goal Check-ins"
              %small.text-muted.d-flex.align-items-center.gap-1
                %span Which is valued at #{number_to_currency(row[:value_sum])}
                %button.btn.btn-link.btn-sm.p-0.text-muted{type: "button", "aria-label" => "More details for #{row[:heading]}", "data-bs-toggle" => "tooltip", "data-bs-placement" => "top", title: hover_copy}
                  %i.bi.bi-info-circle
        %details.mt-3
          %summary.text-muted.fw-semibold How value is calculated
          %ul.mb-0.mt-2
            %li Every milestone attained is worth $1.00
            %li Every person named as an observee in a published observation is worth $0.50
            %li Every completed aspiration, assignment, or position check-in is worth $0.50
            %li Every goal check-in made is worth $0.25

.row.mb-4
  .col-12
    .card.border-0.shadow-sm
      .card-header.bg-primary.text-white
        %h4.mb-0
          %i.bi.bi-graph-up.me-2
          Total value attained by week
          %span.fw-normal.fs-6.text-white-50
            (#{@value_billing_period_label})
      .card-body
        #value-billing-total-chart{style: "height: 360px;"}
        - if @value_billing_per_employee_week
          .border-top.pt-3.mt-3
            .alert.border-0.border-start.border-5.border-success.bg-success-subtle.rounded.mb-0.py-3.px-3{role: 'region', 'aria-label': 'Per-employee value summary'}
              .d-flex.flex-wrap.align-items-baseline.gap-2.mb-2
                %span.fw-semibold= number_to_currency(@value_billing_total_value_sum)
                %span.text-muted ÷
                %span= "#{@value_billing_week_count} #{'week'.pluralize(@value_billing_week_count)}"
                %span.text-muted ÷
                %span= "#{number_with_delimiter(@value_billing_active_teammate_count)} active #{'teammate'.pluralize(@value_billing_active_teammate_count)}"
                %span.text-muted =
              .fs-3.fw-semibold.text-success-emphasis.mb-1
                #{number_to_currency(@value_billing_per_employee_week)} weekly clarity value per active teammate
              %small.text-muted.d-block
                #{number_to_currency(@value_billing_per_employee_year)} annualized clarity value per active teammate
        - elsif @value_billing_active_teammate_count.zero?
          .border-top.pt-3.mt-3
            %p.text-muted.mb-0 No active teammates in this organization hierarchy; per-employee value is not shown.
        - elsif @value_billing_week_count.zero?
          .border-top.pt-3.mt-3
            %p.text-muted.mb-0 No weeks in the selected range; per-employee value is not shown.

.row.g-4
  .col-12.col-xl-6
    .card.border-0.shadow-sm.h-100
      .card-header.bg-light
        %h5.mb-0 OGO Stories Captured
      .card-body
        #value-billing-observees-chart{style: "height: 280px;"}
  .col-12.col-xl-6
    .card.border-0.shadow-sm.h-100
      .card-header.bg-light
        %h5.mb-0 Clarity Check-ins Completed
      .card-body
        #value-billing-check-ins-chart{style: "height: 280px;"}
  .col-12.col-xl-6
    .card.border-0.shadow-sm.h-100
      .card-header.bg-light
        %h5.mb-0 Demonstrated Abilities Recognized
      .card-body
        #value-billing-milestones-chart{style: "height: 280px;"}
  .col-12.col-xl-6
    .card.border-0.shadow-sm.h-100
      .card-header.bg-light
        %h5.mb-0 Goals Progressed
      .card-body
        #value-billing-goal-check-ins-chart{style: "height: 280px;"}

:javascript
  (function() {
    var chartData = #{@value_billing_chart_data.to_json};
    var valueBillingPeriodLabel = #{@value_billing_period_label.to_json};

    function renderChart(containerId, title, data, yAxisTitle, asCurrency, unitValue) {
      if (typeof Highcharts === 'undefined') return;
      var container = document.getElementById(containerId);
      if (!container) return;

      Highcharts.chart(containerId, {
        chart: { type: 'line' },
        title: { text: title },
        accessibility: { enabled: false },
        xAxis: {
          categories: chartData.categories,
          title: { text: 'Week of' }
        },
        yAxis: {
          min: 0,
          title: { text: yAxisTitle }
        },
        tooltip: {
          pointFormatter: function() {
            if (asCurrency) {
              return '<span style="color:' + this.color + '">\u25CF</span> ' + this.series.name + ': <b>$' + this.y.toFixed(2) + '</b><br/>';
            }
            var valueAmount = (this.y * (unitValue || 0)).toFixed(2);
            return '<span style="color:' + this.color + '">\u25CF</span> ' + this.series.name + ': <b>' + this.y + '</b> (<b>$' + valueAmount + '</b>)<br/>';
          }
        },
        series: [{ name: title, data: data }]
      });
    }

    function initializeValueBillingCharts() {
      if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function(tooltipTriggerEl) {
          if (!bootstrap.Tooltip.getInstance(tooltipTriggerEl)) {
            new bootstrap.Tooltip(tooltipTriggerEl);
          }
        });
      }

      renderChart(
        'value-billing-total-chart',
        'Total weekly value attained (' + valueBillingPeriodLabel + ')',
        chartData.total_value,
        'Value in dollars',
        true,
        0
      );
      renderChart(
        'value-billing-milestones-chart',
        'Demonstrated Abilities Recognized',
        chartData.milestones,
        'Count',
        false,
        1.0
      );
      renderChart(
        'value-billing-observees-chart',
        'OGO Stories Captured',
        chartData.observees,
        'Count',
        false,
        0.5
      );
      renderChart(
        'value-billing-check-ins-chart',
        'Clarity Check-ins Completed',
        chartData.completed_check_ins,
        'Count',
        false,
        0.5
      );
      renderChart(
        'value-billing-goal-check-ins-chart',
        'Goals Progressed',
        chartData.goal_check_ins,
        'Count',
        false,
        0.25
      );
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeValueBillingCharts);
    } else {
      initializeValueBillingCharts();
    }
    window.addEventListener('load', initializeValueBillingCharts);
  })();
