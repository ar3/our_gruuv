- content_for :title, "Digest settings"

- content_for :go_back_link do
  - if @return_url.present? && @return_text.present?
    = nav_return_back(url: @return_url, text: @return_text)
  - else
    = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "About Me", url: about_me_organization_company_teammate_path(@organization, @teammate) }, { label: "Digest settings", url: nil }])

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-bell.me-2
      Digest settings
    %p.text-muted.mb-0.ms-2
      Choose where you receive reminders for your #{company_label_for('get_shit_done', 'Get Shit Done')} list.

- has_slack = @teammate.has_slack_identity?
- has_phone = @teammate.person.unique_textable_phone_number.present?
- effective_slack = @user_preference.effective_digest_slack(@teammate)
- effective_email = @user_preference.effective_digest_email
- effective_sms = @user_preference.effective_digest_sms(@teammate.person)
- gsd_label = company_label_for('get_shit_done', 'Get Shit Done')
- gsd_test_enabled = @gsd_pending_items_count.to_i.positive?
- about_me_digest_on = @user_preference.preference(:about_me_digest_enabled) == 'on'
- one_on_one_digest_on = @user_preference.preference(:one_on_one_digest_enabled) == 'on'

.card.mb-4
  .card-body
    .row.g-4.mb-4
      .col-12.col-lg-6
        .border.rounded.p-3.h-100
          %h6.mb-2= "#{gsd_label} digest"
          %p.text-muted.small.mb-3
            Sent on weekdays at 8:00 AM in your timezone when you have items in #{gsd_label}. Uses your notification preferences below.
          - if gsd_test_enabled
            = link_to send_gsd_test_organization_digest_path(@organization, return_url: @return_url, return_text: @return_text),
                      class: 'btn btn-outline-primary btn-sm',
                      data: { turbo_method: :post } do
              %i.bi.bi-send.me-2
              = "Send test (#{gsd_label})"
          - else
            %button.btn.btn-outline-primary.btn-sm{ type: 'button', disabled: true }
              %i.bi.bi-send.me-2
              = "Send test (#{gsd_label})"
            %span.ms-2.text-muted.small{ data: { bs_toggle: 'tooltip', bs_placement: 'top' }, title: "Add an item to your #{gsd_label} list, then you can send a test." }
              %i.bi.bi-info-circle
          - if @gsd_digest_status
            .mt-3.pt-3.border-top
              %div.small.fw-semibold.mb-1 Scheduling & delivery
              %p.text-muted.small.mb-2= @gsd_digest_status.gsd_schedule_summary
              = render 'organizations/digest/digest_blockers',
                       blockers: @gsd_digest_status.gsd_blockers,
                       ready_summary: (@gsd_digest_status.gsd_blockers.empty? ? "Ready to send when #{gsd_label} has pending items." : nil)
              %div.small.fw-semibold.mb-1.mt-3 Recent sends (last 3 weeks)
              - gsd_events_by_week = @gsd_digest_status.recent_events_by_week(weeks: 3).transform_values { |events| events.select { |e| e.digest_key == 'gsd_digest' } }.reject { |_k, v| v.empty? }
              = render 'organizations/digest/digest_recent_activity',
                       events_by_week: gsd_events_by_week,
                       weeks: 3,
                       empty_message: "No #{gsd_label} digest notifications recorded in this period (SMS sends are not logged here)."
      .col-12.col-lg-6
        .border.rounded.p-3.h-100
          %h6.mb-2 Weekly Slack digests (1:1 + About Me)
          %p.text-muted.small.mb-3
            Sent on the selected weekday at 8:00 AM in each employee's timezone to a DM with the employee and their direct manager.
          - about_me_test_options = @about_me_teammates.map { |tm| [tm.person.display_name, tm.id] }
          .d-flex.flex-wrap.gap-2.align-items-center.mb-2
            = form_with url: send_one_on_one_test_organization_digest_path(@organization), method: :post, local: true, class: "d-flex flex-wrap gap-2 align-items-center" do
              = hidden_field_tag :return_url, @return_url
              = hidden_field_tag :return_text, @return_text
              = select_tag :teammate_id, options_for_select(about_me_test_options, @teammate.id), class: 'form-select form-select-sm', style: 'max-width: 280px;'
              = button_tag type: 'submit', class: 'btn btn-outline-secondary btn-sm' do
                %i.bi.bi-send.me-1
                Send test (1:1)
          .d-flex.flex-wrap.gap-2.align-items-center
            = form_with url: send_about_me_test_organization_digest_path(@organization), method: :post, local: true, class: "d-flex flex-wrap gap-2 align-items-center" do
              = hidden_field_tag :return_url, @return_url
              = hidden_field_tag :return_text, @return_text
              = select_tag :teammate_id, options_for_select(about_me_test_options, @teammate.id), class: 'form-select form-select-sm', style: 'max-width: 280px;'
              = button_tag type: 'submit', class: 'btn btn-outline-secondary btn-sm' do
                %i.bi.bi-send.me-1
                Send test (About Me)

    = form_with url: organization_digest_path(@organization), method: :patch, local: true do |f|
      - if @return_url.present?
        = hidden_field_tag :return_url, @return_url
      - if @return_text.present?
        = hidden_field_tag :return_text, @return_text

      %h5.mb-3 Delivery mediums
      .form-check.mb-2
        = check_box_tag :digest_slack, 'on', effective_slack == 'on', class: 'form-check-input', disabled: !has_slack
        = label_tag :digest_slack, 'Slack', class: 'form-check-label'
      - unless has_slack
        %p.text-muted.small.ms-4
          Connect your Slack account in Slack Settings to enable Slack reminders.

      .form-check.mb-2
        = check_box_tag :digest_sms, 'on', effective_sms == 'on', class: 'form-check-input', disabled: !has_phone
        = label_tag :digest_sms, 'SMS', class: 'form-check-label'
      - unless has_phone
        %p.text-muted.small.ms-4.mb-2
          Add a phone number in your profile to enable SMS reminders.
        .ms-4.mb-3
          = link_to 'Add phone number in profile', about_me_organization_company_teammate_path(@organization, @teammate), class: 'small'

      .form-check.mb-3
        = check_box_tag :digest_email, 'on', false, class: 'form-check-input', disabled: true
        = label_tag :digest_email, 'Email (coming soon)', class: 'form-check-label text-muted'

      %hr.my-4
      %h5.mb-3 Your weekly digest toggles
      %p.text-muted.small.mb-2
        Both digests use the same weekday below. Turn on one or both.
      = hidden_field_tag :one_on_one_digest_enabled, 'off'
      .form-check.mb-2
        = check_box_tag :one_on_one_digest_enabled, 'on', one_on_one_digest_on, class: 'form-check-input'
        = label_tag :one_on_one_digest_enabled, 'Weekly 1:1 guide digest', class: 'form-check-label'
      = hidden_field_tag :about_me_digest_enabled, 'off'
      .form-check.mb-3
        = check_box_tag :about_me_digest_enabled, 'on', about_me_digest_on, class: 'form-check-input'
        = label_tag :about_me_digest_enabled, 'Weekly About Me reminder digest', class: 'form-check-label'

      %hr.my-4
      %h5.mb-3 Weekly reminder day
      %p.text-muted.small
        Applies to each employee listed. Sent at 8:00 AM in that employee's timezone. Expand each row for recent Slack activity and reasons a digest might not send.
      .table-responsive
        %table.table.table-sm.align-middle
          %thead
            %tr
              %th Employee
              - [['Sun', '0'], ['Mon', '1'], ['Tue', '2'], ['Wed', '3'], ['Thu', '4'], ['Fri', '5'], ['Sat', '6'], ['No weekly reminder', 'off']].each do |label, _value|
                %th.text-center= label
          %tbody
            - @about_me_teammates.each do |employee|
              - pref = UserPreference.for_person(employee.person)
              - selected_day = pref.preference(:about_me_weekly_day).presence || 'off'
              - manager_name = employee.active_employment_tenure&.manager_teammate&.person&.casual_name
              - employee_status = @digest_status_by_teammate_id&.dig(employee.id)
              %tr
                %td
                  .d-flex.align-items-center.gap-2
                    .flex-grow-1
                      %div= employee.person.display_name
                      - if manager_name.present?
                        %div.small.text-muted
                          = "... and #{manager_name} will be notified as well"
                    = link_to organization_company_teammate_path(@organization, employee),
                              target: '_blank',
                              rel: 'noopener noreferrer',
                              class: 'text-muted',
                              title: "Open #{employee.person.display_name} profile in a new tab" do
                      %i.bi.bi-box-arrow-up-right
                - [['0'], ['1'], ['2'], ['3'], ['4'], ['5'], ['6'], ['off']].flatten.each do |value|
                  %td.text-center
                    = radio_button_tag "about_me_days[#{employee.id}]", value, selected_day.to_s == value.to_s, class: 'form-check-input'
              - if employee_status
                %tr
                  %td{ colspan: 9, class: 'p-0 border-0' }
                    = render 'organizations/digest/teammate_weekly_digest_status', status: employee_status, weeks: 3

      .d-flex.flex-wrap.gap-2.align-items-center.mt-4
        = f.submit "Save preferences", class: "btn btn-primary"
        = link_to "Cancel", (@return_url.presence || about_me_organization_company_teammate_path(@organization, @teammate)), class: "btn btn-secondary"
