-# locals: status:, weeks: 3
.bg-light.rounded.p-3.mt-1.mb-2
  .row.g-3
    .col-md-6
      %div.small.fw-semibold.mb-1 Scheduling
      %p.text-muted.small.mb-2= status.weekly_schedule_summary
      %p.text-muted.small.mb-2= status.next_weekly_send_label(:one_on_one)
      - schedule_notes = status.schedule_diagnosis
      - if schedule_notes.any?
        %ul.list-unstyled.mb-2.small.text-muted
          - schedule_notes.each do |note|
            %li
              %i.bi.bi-clock.me-1
              = note
      .mb-2
        %span.small.fw-semibold 1:1 guide
        = render 'organizations/digest/digest_blockers', blockers: status.one_on_one_blockers, ready_summary: (status.one_on_one_blockers.empty? ? 'Configured to schedule.' : nil)
        - if status.already_sent_this_week?(:one_on_one)
          %p.text-muted.small.mb-0.mt-1
            %i.bi.bi-check2.me-1
            Already sent this calendar week (per preferences).
      .mb-0
        %span.small.fw-semibold About Me reminder
        = render 'organizations/digest/digest_blockers', blockers: status.about_me_blockers, ready_summary: (status.about_me_blockers.empty? ? 'Configured to schedule.' : nil)
        - if status.already_sent_this_week?(:about_me)
          %p.text-muted.small.mb-0.mt-1
            %i.bi.bi-check2.me-1
            Already sent this calendar week (per preferences).
    .col-md-6
      %div.small.fw-semibold.mb-1 Recent Slack sends (last #{weeks} weeks)
      = render 'organizations/digest/digest_recent_activity',
               events_by_week: status.recent_events_by_week(weeks: weeks),
               weeks: weeks,
               empty_message: 'No weekly digest notifications recorded in this period.'
