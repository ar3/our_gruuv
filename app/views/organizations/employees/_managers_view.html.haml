:css
  .managers-view-card .managers-view-health-row {
    font-size: 0.8125rem;
    line-height: 1.25;
  }
  .managers-view-card .managers-view-health-row a {
    text-decoration: none;
  }
  .managers-view-card .managers-view-health-row a:hover {
    text-decoration: underline;
  }

.list-group.managers-view-card
  - @filtered_and_paginated_teammates.each do |teammate|
    .list-group-item.py-2
      - cache = @check_in_health_caches_by_teammate && @check_in_health_caches_by_teammate[teammate.id]
      - rate_data = check_in_health_completion_rate_and_breakdown(cache)
      - health_table_data = single_item_health_popover_table(cache)
      - health_popover_html = health_table_data ? render(partial: "shared/clarity_popover_table", locals: { table_data: health_table_data }) : no_clarity_check_in_health_data_label
      - casual_name = teammate.person.casual_name
      - row_data = (@managers_view_row_data_by_teammate_id || {})[teammate.id]
      - check_in_actions_needed = row_data&.check_in_actions_needed.to_i
      - goals_health_status = row_data&.goals_health_status || :concerning
      - active_goals_count = row_data&.active_goals_count.to_i
      - draft_goals_count = row_data&.draft_goals_count.to_i
      - ogo_overall_status = row_data&.ogo_overall_status
      - ogos_given_count = row_data&.ogos_given_30d_count.to_i
      - ogos_received_count = row_data&.ogos_received_30d_count.to_i
      - ogo_30d_tooltip = managers_view_ogo_30d_tooltip
      - active_goals_path = organization_goals_path(@organization, owner_id: "CompanyTeammate_#{teammate.id}", status: "active", view: "hierarchical-collapsible")
      - draft_goals_path = organization_goals_path(@organization, owner_id: "CompanyTeammate_#{teammate.id}", status: "draft", view: "hierarchical-collapsible")

      .row.g-2.align-items-center
        .col-6.col-md-1
          = teammate_profile_image(teammate, size: 48)
        .col-6.col-md-2
          = link_to teammate.person.display_name, internal_organization_company_teammate_path(@organization, teammate), class: "text-decoration-none fw-semibold fs-5 lh-sm"
        .col-12.col-md-3
          = link_to organization_company_teammate_one_on_one_link_path(@organization, teammate), class: "btn btn-primary btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-2 shadow-sm hover-lift text-center" do
            %i.bi.bi-compass.text-white
            %span= "#{casual_name}'s Top Action"
        .col-6.col-md-3
          = link_to about_me_organization_company_teammate_path(@organization, teammate), class: "btn btn-outline-secondary btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-2 shadow-sm hover-lift text-center" do
            %i.bi.bi-person-badge.text-primary
            %span= "View About #{casual_name}"
        .col-6.col-md-3
          = link_to my_growth_experiences_organization_company_teammate_path(@organization, teammate), class: "btn btn-outline-secondary btn-sm w-100 d-inline-flex align-items-center justify-content-center gap-2 shadow-sm hover-lift text-center" do
            %i.bi.bi-graph-up-arrow.text-primary
            %span= "Explore #{casual_name}'s Growth"

      .row.g-1.mt-1.align-items-center.managers-view-health-row
        .offset-md-1.col-6.col-md-2
          - if rate_data
            %span.fw-semibold{class: check_in_health_rate_text_class(rate_data[:completion_rate]), "data-bs-toggle" => "popover", "data-bs-trigger" => "hover", "data-bs-placement" => "top", "data-bs-html" => "true", "data-bs-content" => health_popover_html.html_safe, style: "cursor: pointer;"}
              #{rate_data[:completion_rate]}% clear
          - else
            %span.text-muted.fw-semibold{"data-bs-toggle" => "popover", "data-bs-trigger" => "hover", "data-bs-placement" => "top", "data-bs-content" => health_popover_html, style: "cursor: pointer;"}
              —
        .col-6.col-md-3
          = link_to up_next_organization_company_teammate_check_ins_path(@organization, teammate), class: "text-body" do
            %i.bi.bi-list-check.me-1.text-primary
            %span= managers_view_check_in_actions_label(check_in_actions_needed)
        .col-6.col-md-3
          = link_to review_most_recent_organization_company_teammate_check_ins_path(@organization, teammate), class: "text-body" do
            %i.bi.bi-clock-history.me-1.text-primary
            %span View Last Check-ins
        .col-12.col-md-3
          = link_to hub_organization_company_teammate_check_ins_path(@organization, teammate), class: "text-body" do
            %i.bi.bi-signpost-split.me-1.text-primary
            %span Clarity Check-in Hub

      .row.g-1.mt-1.align-items-center.managers-view-health-row
        .offset-md-1.col-6.col-md-2.d-flex.align-items-center.gap-1
          %span.text-muted Goals:
          = managers_view_axis_status_icon(goals_health_status, kind: :goals)
        .col-6.col-md-3
          = link_to active_goals_path, class: "text-body" do
            %i.bi.bi-bullseye.me-1.text-primary
            %span= "#{casual_name}'s #{active_goals_count} active #{'goal'.pluralize(active_goals_count)}"
        .col-6.col-md-3
          = link_to draft_goals_path, class: "text-body" do
            %i.bi.bi-pencil-square.me-1.text-primary
            %span= "#{casual_name}'s #{draft_goals_count} draft #{'goal'.pluralize(draft_goals_count)}"
        .col-12.col-md-3
          = link_to my_growth_goals_organization_company_teammate_path(@organization, teammate), class: "text-body" do
            %i.bi.bi-graph-up.me-1.text-primary
            %span Grow by Goals

      .row.g-1.mt-1.align-items-center.managers-view-health-row
        .offset-md-1.col-6.col-md-2.d-flex.align-items-center.gap-1
          %span.text-muted OGOs:
          = managers_view_axis_status_icon(ogo_overall_status, kind: :ogos)
        .col-6.col-md-3
          = link_to ogos_from_organization_company_teammate_path(@organization, teammate), class: "text-body", "data-bs-toggle" => "tooltip", "data-bs-placement" => "top", title: ogo_30d_tooltip do
            %i.bi.bi-send.me-1.text-primary
            %span= "#{ogos_given_count} #{'OGO'.pluralize(ogos_given_count)} given"
        .col-6.col-md-3
          = link_to ogos_organization_company_teammate_path(@organization, teammate), class: "text-body", "data-bs-toggle" => "tooltip", "data-bs-placement" => "top", title: ogo_30d_tooltip do
            %i.bi.bi-inbox.me-1.text-primary
            %span= "#{ogos_received_count} #{'OGO'.pluralize(ogos_received_count)} received"
        .col-12.col-md-3
          = link_to ogos_organization_company_teammate_path(@organization, teammate), class: "text-body" do
            %i.bi.bi-chat-left-quote.me-1.text-primary
            %span OGO Overview
