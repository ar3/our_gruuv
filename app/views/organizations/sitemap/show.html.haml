- content_for :title, "Sitemap"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Sitemap", url: nil }])

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-map.me-2
      Sitemap
    %span.badge.bg-secondary.ms-2= "#{@sitemap_entry_count} pages"

.row.justify-content-center.mb-4
  .col-lg-12
    .alert.alert-light.border.mb-0
      %p.mb-0
        Every page you can access in #{@organization.display_name}, organized by area.
        Search uses the labels, goals, and keywords listed here under
        = link_to "Go To", organization_search_path(@organization)
        results.

- @sitemap_sections.each do |section|
  .row.justify-content-center.mb-4
    .col-lg-12
      .card.border-0.shadow-sm
        .card-header
          %h5.mb-0
            %i.bi.me-2{class: section[:icon]}
            = section[:label]
            %span.badge.bg-light.text-dark.ms-2= section[:entries].size
        .card-body.p-0
          .table-responsive
            %table.table.table-hover.mb-0
              %thead
                %tr
                  %th Page
                  %th Goal
                  %th Also known as
              %tbody
                - section[:entries].each do |entry|
                  %tr
                    %td
                      = link_to entry.path, class: "text-decoration-none fw-bold" do
                        %i.bi.me-2.text-muted{class: entry.icon}
                        = entry.label
                    %td= entry.goal
                    %td
                      - if entry.synonyms.any?
                        %small.text-muted= entry.synonym_list
                      - else
                        %span.text-muted —
