- content_for :title, "Associate Goals"

- content_for :header do
  Associate goals with "#{associable_display_title(@associable)}"

- content_for :return_url do
  = @return_url

- content_for :return_text do
  = @return_text

.card.mb-3
  .card-header
    %h5.mb-0
      %i.bi.bi-bullseye.me-2
      How do you want to add goals?
  .card-body
    .list-group.list-group-flush
      %a.list-group-item.list-group-item-action.d-flex.align-items-center{href: associable_goals_manage_path(@organization, @associable, return_url: @return_url, return_text: @return_text), data: { turbo: false }}
        %i.bi.bi-plus-circle.me-3.fs-4
        .flex-grow-1
          %strong Create new goals
          %small.d-block.text-muted
            Add one or more new goals and associate them with this #{@associable.model_name.human.downcase}.
        %i.bi.bi-chevron-right
      %a.list-group-item.list-group-item-action.d-flex.align-items-center{href: associable_goals_associate_existing_path(@organization, @associable, return_url: @return_url, return_text: @return_text), data: { turbo: false }}
        %i.bi.bi-link-45deg.me-3.fs-4
        .flex-grow-1
          %strong Associate existing goals
          %small.d-block.text-muted
            Choose from goals in your company that are not yet associated.
        %i.bi.bi-chevron-right
    .mt-3
      = link_to @return_url, class: 'btn btn-outline-secondary' do
        %i.bi.bi-arrow-left.me-1
        = @return_text
