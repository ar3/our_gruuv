- content_for :title, "Create New Goals"

- content_for :header do
  Create new goals and associate with "#{associable_display_title(@associable)}"

- content_for :return_url do
  = @return_url

- content_for :return_text do
  = @return_text

- associable_goal_flow_opts = { return_url: @return_url, return_text: @return_text, for_company_teammate_id: @for_company_teammate_id }.compact

.card.mb-3
  .card-header
    %h5.mb-0
      %i.bi.bi-bullseye.me-2
      Create new goals
      %small.text-muted.ms-2
        Each goal will be created and associated with this #{@associable.model_name.human.downcase}.
  .card-body
    = form_with url: associable_goal_associations_path(@organization, @associable), method: :post, local: true do |f|
      = hidden_field_tag :return_url, @return_url if @return_url.present?
      = hidden_field_tag :return_text, @return_text if @return_text.present?
      = hidden_field_tag :for_company_teammate_id, @for_company_teammate_id if @for_company_teammate_id.present?

      .mb-4
        %label.form-label.fw-bold
          Create New Goals
          %i.bi.bi-info-circle.text-muted.ms-2{
            "data-bs-toggle" => "tooltip",
            "data-bs-title" => "Create nested goals: Regular lines create goals. Sub-goals: start with numbers, *, •, -, –, .., a letter and . or ) (e.g. A. or a)), a roman numeral and . or ) (e.g. i. or ii)), or 2+ spaces. A goal followed by sub-goals becomes an objective. Use 2+ more leading spaces than the previous sub-goal to create a sub-sub goal."
          }
        %small.text-muted.d-block.mb-2
          Enter one goal per line. Each goal will be created as a stepping stone goal with a due date 90 days from now.
        = text_area_tag "bulk_goal_titles", nil,
                        class: "form-control",
                        id: "bulk_goal_titles",
                        rows: 6,
                        placeholder: "Goal 1\n1. Stepping Stone 1-1\n2. Stepping Stone 1-2\n..."
        = render "shared/goals/bulk_nested_goals_example_link", associated_label: associable_display_title(@associable)

      .d-flex.gap-2.mt-3
        = link_to @return_url, class: 'btn btn-outline-secondary' do
          %i.bi.bi-arrow-left.me-1
          = @return_text || 'Cancel'
        = f.submit 'Create and associate goals', class: 'btn btn-primary'
