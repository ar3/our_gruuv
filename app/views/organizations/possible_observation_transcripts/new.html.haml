- content_for :title, 'Upload meeting transcript'

- content_for :header do
  .d-flex.align-items-center.flex-wrap.gap-2
    %h1.mb-0
      %i.bi.bi-cloud-upload.me-2
      Upload meeting transcript
    %span.badge.text-bg-warning
      %i.bi.bi-flask.me-1
      Beta
  %p.lead.text-muted.mb-0
    Use an export from Zoom, Google Meet, Webex, Grain, or plain text (.txt, .vtt, .srt, .json, .csv).

= form_with model: @transcript, url: organization_possible_observation_transcripts_path(organization), local: true, html: { multipart: true } do |f|
  - if @transcript.errors.any?
    .alert.alert-danger
      %ul.mb-0
        - @transcript.errors.full_messages.each do |msg|
          %li= msg

  .card.mb-4
    .card-body
      .mb-3
        = f.label :display_name, class: 'form-label'
        = f.text_field :display_name, class: 'form-control', required: true
        .form-text Defaults to today’s date; used in feedback request subject lines (“Potential Observation from: …”).
      .mb-3
        = f.label :transcript_file, 'Transcript file', class: 'form-label'
        = f.file_field :transcript_file, class: 'form-control', accept: '.txt,.vtt,.srt,.json,.csv,text/plain', required: true
        .form-text Max #{PossibleObservationTranscript::MAX_TRANSCRIPT_BYTES / 1.megabyte} MB.

  .d-flex.gap-2
    = f.submit 'Upload and extract', class: 'btn btn-primary'
    = link_to 'Cancel', organization_possible_observation_transcripts_path(organization), class: 'btn btn-outline-secondary'
