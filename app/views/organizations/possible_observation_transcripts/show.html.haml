- content_for :title, @transcript.display_name

- content_for :go_back_link do
  = link_to '← Meeting transcripts', organization_possible_observation_transcripts_path(organization), class: 'text-decoration-none'

- content_for :header do
  .d-flex.align-items-center.flex-wrap.gap-2
    %h1.mb-0
      %i.bi.bi-file-earmark-text.me-2
      = @transcript.display_name
    %span.badge.text-bg-warning
      %i.bi.bi-flask.me-1
      Beta
  %p.lead.text-muted.mb-0
    Step 1 of 2: review suggested observations before drafting feedback requests.

%ul.nav.nav-tabs.mb-3
  %li.nav-item
    %span.nav-link.active Review observations
  %li.nav-item
    = link_to 'Create feedback requests', review_feedback_requests_organization_possible_observation_transcript_path(organization, @transcript), class: 'nav-link'

.d-flex.flex-wrap.gap-2.mb-3
  - if @transcript.transcript_file.attached?
    = link_to 'Download original file', rails_blob_path(@transcript.transcript_file, disposition: 'attachment'), class: 'btn btn-outline-secondary btn-sm'
  - if policy(@transcript).destroy? && @transcript.deletable?
    = button_to 'Delete transcript', organization_possible_observation_transcript_path(organization, @transcript), method: :delete, class: 'btn btn-outline-danger btn-sm', form: { data: { turbo_confirm: 'Delete this transcript? This cannot be undone.' } }
  - if policy(@transcript).re_extract? && @transcript.deletable?
    = button_to 'Re-run extraction', re_extract_organization_possible_observation_transcript_path(organization, @transcript), method: :post, class: 'btn btn-outline-secondary btn-sm'

- if @transcript.extraction_error.present?
  .alert.alert-info
    %strong Note:
    = @transcript.extraction_error

- case @transcript.extraction_status
- when 'pending', 'processing'
  = render 'shared/og_consultations/status_banner',
           status_url: extraction_status_organization_possible_observation_transcript_path(organization, @transcript),
           label: 'Consultation',
           initial_status: @transcript.extraction_status,
           wrapper_class: 'alert alert-secondary mb-0',
           time_zone: current_person_iana_timezone

  .table-responsive.mt-3
    %table.table.table-bordered.align-middle
      %thead.table-light
        %tr
          %th Include
          %th Kind
          %th Quote
          %th Speaker → subject
          %th Status
      %tbody
        - 3.times do
          %tr
            %td{ colspan: 5 }
              .start-here-dashboard-skeleton.placeholder-glow.py-1
                .placeholder.col-12.mb-2.rounded{style: "height: 0.9rem;"}
                .placeholder.col-10.mb-2.rounded{style: "height: 0.9rem;"}
                .placeholder.col-11.rounded{style: "height: 0.9rem;"}
- when 'failed'
  .alert.alert-danger
    Extraction failed. Try re-uploading or use a different export format.
- when 'completed'
  - items = @transcript.extraction_items
  - if items.empty?
    .alert.alert-warning.mb-0 No moments were extracted. You can adjust the file and re-upload, or re-run extraction if the transcript is unchanged.
  - else
    = form_with url: organization_possible_observation_transcript_path(organization, @transcript), method: :patch, local: true do
      .table-responsive
        %table.table.table-bordered.align-middle
          %thead.table-light
            %tr
              %th Include
              %th Kind
              %th Quote
              %th Speaker → subject
              %th Status
          %tbody
            - items.each_with_index do |item, idx|
              - locked = item[:feedback_request_id].present?
              - responder_selected = item[:responder_company_teammate_id].present?
              - subject_selected = item[:subject_company_teammate_id].present?
              - ready = responder_selected && subject_selected
              %tr
                %td
                  = hidden_field_tag "items[#{idx}][id]", item[:id]
                  - if locked
                    = hidden_field_tag "items[#{idx}][include]", ActiveModel::Type::Boolean.new.cast(item[:include]) ? '1' : '0'
                  = check_box_tag "items[#{idx}][include]", '1', ActiveModel::Type::Boolean.new.cast(item[:include]), class: 'form-check-input', disabled: locked
                  - if locked
                    %span.small.text-muted.ms-1 locked
                %td
                  - if locked
                    = hidden_field_tag "items[#{idx}][kind]", item[:kind]
                  - @observation_type_options.each do |label, value|
                    .form-check.form-check-inline
                      = radio_button_tag "items[#{idx}][kind]", value, item[:kind].to_s == value, class: 'form-check-input', id: "items_#{idx}_kind_#{value}", disabled: locked
                      = label_tag "items_#{idx}_kind_#{value}", label, class: 'form-check-label'
                %td
                  - if locked
                    = hidden_field_tag "items[#{idx}][quote]", item[:quote]
                  = text_area_tag "items[#{idx}][quote]", item[:quote], class: 'form-control form-control-sm', rows: 8, style: 'min-width: 500px;', disabled: locked
                %td
                  .small.text-muted.mb-1
                    #{item[:speaker_label]} → #{item[:recipient_label]}
                  .row.g-1
                    .col-12
                      = label_tag "items_#{idx}_responder", 'Responder (speaker)', class: 'form-label small mb-0'
                      - if locked
                        = hidden_field_tag "items[#{idx}][responder_company_teammate_id]", item[:responder_company_teammate_id]
                      = select_tag "items[#{idx}][responder_company_teammate_id]", grouped_options_for_select([['—', [['—', '']]]] + @teammates_grouped_for_select, item[:responder_company_teammate_id]), class: 'form-select form-select-sm', id: "items_#{idx}_responder", disabled: locked
                    .col-12
                      = label_tag "items_#{idx}_subject", 'Subject (recipient)', class: 'form-label small mb-0'
                      - if locked
                        = hidden_field_tag "items[#{idx}][subject_company_teammate_id]", item[:subject_company_teammate_id]
                      = select_tag "items[#{idx}][subject_company_teammate_id]", grouped_options_for_select([['—', [['—', '']]]] + @teammates_grouped_for_select, item[:subject_company_teammate_id]), class: 'form-select form-select-sm', id: "items_#{idx}_subject", disabled: locked
                  - if !responder_selected
                    .badge.text-bg-secondary.mt-1 Observer unclear from transcript
                  - if !subject_selected
                    .badge.text-bg-secondary.mt-1 Recipient unclear from transcript
                  = hidden_field_tag "items[#{idx}][observer_unknown]", item[:observer_unknown]
                  = hidden_field_tag "items[#{idx}][observee_unknown]", item[:observee_unknown]
                  = hidden_field_tag "items[#{idx}][feedback_request_id]", item[:feedback_request_id]
                  = hidden_field_tag "items[#{idx}][speaker_label]", item[:speaker_label]
                  = hidden_field_tag "items[#{idx}][recipient_label]", item[:recipient_label]
                  = hidden_field_tag "items[#{idx}][summary]", item[:summary]
                  = hidden_field_tag "items[#{idx}][short_quote]", item[:short_quote]
                  = hidden_field_tag "items[#{idx}][full_quote]", item[:full_quote]
                %td
                  - if item[:feedback_request_id].present?
                    %span.text-success Created (locked)
                    .mt-1
                      = link_to 'Open request', organization_feedback_request_path(organization, item[:feedback_request_id]), class: 'btn btn-sm btn-outline-primary'
                  - elsif !ready
                    %span.text-warning Needs IDs
                  - else
                    %span.text-muted Reviewing
      = submit_tag 'Save and continue to request creation', class: 'btn btn-primary mt-2'
