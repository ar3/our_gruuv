= render "header"
= render "tabs", active_tab: :results

.mb-3
  = link_to results_organization_assignment_survey_path(organization), class: "text-decoration-none" do
    %i.bi.bi-arrow-left.me-1
    Back to results

.card.mb-4
  .card-body
    .d-flex.justify-content-between.align-items-start.flex-wrap.gap-2
      %div
        %h2.h3.mb-1= @submission.company_teammate.person.display_name
        %p.text-muted.mb-0
          Started #{l(@submission.created_at, format: :long)}
          - if @submission.finalized_at
            · Finalized #{l(@submission.finalized_at, format: :long)}
      - if @submission.draft?
        %span.badge.text-bg-warning Draft — answers may change
      - else
        %span.badge.text-bg-success Finalized

- labels = { 1 => "Strongly disagree", 2 => "Disagree", 3 => "Somewhat disagree", 4 => "Somewhat agree", 5 => "Agree", 6 => "Strongly agree" }
- @submission.responses.each do |response|
  .card.mb-4
    .card-header.bg-light
      .d-flex.justify-content-between.align-items-start.flex-wrap.gap-2
        %div
          %h3.h4.mb-1= response.snapshot_title
          - if response.snapshot_tagline.present?
            %p.text-muted.mb-0= response.snapshot_tagline
        %span.badge.text-bg-secondary= response.source_label
    .card-body
      .row.g-3
        - rating_rows = [["Understandable", response.understandable_rating], ["Possible", response.possible_rating], ["Relevant", response.relevant_rating]]
        - rating_rows.each do |title, rating|
          .col-12.col-md-4
            .border.rounded.p-3.h-100
              .text-muted.small= title
              - if rating
                .fw-semibold= labels.fetch(rating)
                .small.text-muted #{rating} / 6
              - else
                .text-muted Not answered
      .mt-3
        %h4.h6 Comment
        - if response.comment.present?
          = simple_format(response.comment, {}, wrapper_tag: "div")
        - else
          %p.text-muted.mb-0 No comment provided.
