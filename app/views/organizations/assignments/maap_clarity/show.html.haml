- content_for :title, "Consult OG — #{@assignment.title}"

- content_for :header do
  .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      %i.bi.bi-stars.me-2.fs-1
      %span.fs-1.fw-medium Consult OG about
      = render 'assignment_switcher',
               organization: @organization,
               assignment: @assignment,
               assignments_by_department: @assignments_by_department_for_maap_switcher
    %span.badge.text-bg-warning
      %i.bi.bi-flask.me-1
      Beta

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Assignments", url: organization_assignments_path(@organization) }, { label: @assignment.title, url: organization_assignment_path(@organization, @assignment) }, { label: "Consult OG", url: nil }])

- content_for :header_action do
  = render 'assignments/view_switcher'

.row.justify-content-center
  .col-lg-10
    %p.lead.text-muted
      Consult OG reviews outcomes, neighbor assignments, consumer/supplier links, position fit, and ability alignment.
      Results are saved as the latest run for this assignment.

    - consult_focus_value = @run&.consult_focus.presence || params[:consult_focus].presence
    = form_with url: run_maap_clarity_organization_assignment_path(@organization, @assignment), method: :post, local: true, data: { turbo: false }, class: 'mb-4' do
      .mb-3
        %label.form-label{ for: 'consult_focus' } What do you want help with?
        = text_area_tag :consult_focus, consult_focus_value, id: 'consult_focus', class: 'form-control', rows: 4, maxlength: 8000, placeholder: 'Leave blank for a standard review — or add context, e.g. “Are outcomes 2–3 too overlapping?” or “Should this link to another assignment?”'
        .form-text.text-muted
          You can leave this blank; Consult OG works just fine without it. Use this when you have extra context you want to give OG before the analysis.
      .d-flex.flex-wrap.gap-2
        %button.btn.btn-primary{ type: 'submit' }
          %i.bi.bi-play-fill.me-2
          - if @run&.persisted?
            Consult OG again
          - else
            Consult OG

    - if @run&.error_message.present? && @run.status == 'failed'
      .alert.alert-danger.mb-3
        %strong Something went wrong.
        = @run.error_message

    - if @run&.status.in?(%w[pending processing])
      .alert.alert-secondary.mb-3#maap-clarity-status-banner{ data: { status_url: maap_clarity_status_organization_assignment_path(@organization, @assignment) } }
        %i.bi.bi-hourglass-split.me-2
        %span#maap-clarity-status-text
          Consultation is #{@run.status}…
        %span.ms-1.text-muted#maap-clarity-elapsed
        %span.ms-1.text-warning.d-none#maap-clarity-slow-warning
          Taking longer than expected.
        .small.text-muted.mt-1#maap-clarity-last-checked
          Last checked: just now

      .card.mb-4.border-0.bg-light
        .card-body.placeholder-glow.py-4
          - 4.times do
            .placeholder.col-12.mb-2.rounded{ style: "height: 0.9rem;" }
            .placeholder.col-10.mb-2.rounded{ style: "height: 0.9rem;" }

    - elsif @run&.status == 'completed' && @run.output_text.present?
      - parsed = Maap::AssignmentClarityOutputParser.call(@run.output_text)
      - rating = parsed.rating.presence || @run.clarity_rating
      - score = @run.clarity_score.nil? ? parsed.score : @run.clarity_score
      - recs = Array(@run.clarity_recommendations).map(&:stringify_keys)
      - if @run.consult_focus.present?
        .card.mb-3.border-0.bg-light
          .card-body.py-3
            %div.small.text-muted.mb-1 Your focus for this run
            .small{ style: 'white-space: pre-wrap; word-break: break-word;' }= @run.consult_focus
      .d-flex.align-items-center.flex-wrap.gap-2.mb-3
        - unless score.nil?
          %span.text-muted Consult OG score:
          %span.fw-semibold #{score}/100
          %span.text-muted ·
        %span.text-muted Clarity signal:
        - case rating
        - when 'green'
          %span.badge.text-bg-success Green (80–100)
        - when 'yellow'
          %span.badge.text-bg-warning Yellow (60–79)
        - when 'red'
          %span.badge.text-bg-danger Red (0–59)
        - else
          %span.badge.text-bg-secondary Unknown
        - if @run.updated_at
          %small.text-muted.ms-2 Updated #{l(@run.updated_at, format: :long)}
      .card.mb-0
        .card-body.markdown-content
          = render_markdown(parsed.body)
      - if recs.any?
        .card.mt-3.mb-0.border-primary.border-opacity-25
          .card-header.bg-light
            %strong High-confidence recommendations
            %span.text-muted.small.ms-2 (quick accept — apply actions coming later)
          %ul.list-group.list-group-flush
            - recs.each do |rec|
              %li.list-group-item.d-flex.flex-wrap.align-items-start.justify-content-between.gap-2
                .flex-grow-1
                  %div.fw-semibold= rec['title']
                  %div.small.text-muted.mt-1= rec['rationale']
                  %div.small.mt-1
                    %span.badge.text-bg-secondary.text-uppercase= rec['kind']
                .flex-shrink-0
                  - if @accepted_maap_recommendation_ids.include?(rec['id'])
                    %span.badge.text-bg-success
                      %i.bi.bi-check-lg.me-1
                      Accepted
                  - else
                    = button_to accept_maap_clarity_recommendation_organization_assignment_path(@organization, @assignment),
                                params: { recommendation_id: rec['id'] },
                                method: :post,
                                class: 'btn btn-sm btn-outline-primary',
                                form: { data: { turbo: false } } do
                      Quick accept

    - elsif (@run.nil? || (@run.status == 'completed' && @run.output_text.blank?)) && @run&.status != 'failed'
      .alert.alert-info.mb-0
        No completed consultation yet. Click “Consult OG” to generate one.

- if @run && %w[pending processing].include?(@run.status)
  :javascript
    (() => {
      const banner = document.getElementById('maap-clarity-status-banner');
      if (!banner) return;

      const url = banner.dataset.statusUrl;
      const statusText = document.getElementById('maap-clarity-status-text');
      const elapsedText = document.getElementById('maap-clarity-elapsed');
      const slowWarning = document.getElementById('maap-clarity-slow-warning');
      const lastChecked = document.getElementById('maap-clarity-last-checked');
      const fmt = (seconds) => {
        const s = Math.max(parseInt(seconds || 0, 10), 0);
        const mins = Math.floor(s / 60);
        const rem = s % 60;
        return mins > 0 ? `${mins}m ${rem}s` : `${rem}s`;
      };
      const fmtTime = (date) => {
        const d = date || new Date();
        return d.toLocaleString([], {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: 'numeric',
          minute: '2-digit',
          second: '2-digit',
          timeZoneName: 'short'
        });
      };

      const poll = async () => {
        try {
          const res = await fetch(url, { headers: { Accept: 'application/json' } });
          if (!res.ok) return;
          const data = await res.json();
          if (statusText) statusText.textContent = `Consultation is ${data.status}...`;
          if (elapsedText) elapsedText.textContent = `(${fmt(data.elapsed_seconds)})`;
          if (slowWarning) {
            slowWarning.classList.toggle('d-none', !data.slow);
            if (data.stale) slowWarning.textContent = 'Possible stall detected. Try refreshing or re-run.';
          }
          if (lastChecked) lastChecked.textContent = `Last checked: ${fmtTime(new Date())}`;
          if (data.status === 'completed' || data.status === 'failed') {
            window.location.reload();
          }
        } catch (_) {
          // Keep polling; transient failures are expected.
        }
      };

      poll();
      window.setInterval(poll, 3000);
    })();
