- page_help_id = "associateExistingIncomingPageHelp"

- content_for :title, "Associate Existing Parent Goals"

- content_for :header do
  Associate "#{@goal.title}" as child to existing goals
  = render "shared/page_help/header_info_button",
           collapse_id: page_help_id,
           tooltip: "Which goals can be parents, and the org-vs-teammate hierarchy rule. Click for details."

- content_for :return_url do
  = @return_url || organization_goal_path(@organization, @goal)

- content_for :return_text do
  = @return_text || "Back to the #{@goal.title} goal"

.collapse.mb-4{id: page_help_id}
  = render "organizations/goal_links/associate_existing_incoming_page_help"

.card.mb-3
  .card-header
    %h5.mb-0
      %i.bi.bi-link-45deg.me-2
      Select parent goals
      %small.text-muted.ms-2
        Goals already in this goal's hierarchy are disabled.
  .card-body
    = form_with url: associate_existing_incoming_organization_goal_goal_links_path(@organization, @goal), method: :post, local: true do |f|
      = hidden_field_tag :return_url, @return_url
      = hidden_field_tag :return_text, @return_text

      - if @available_goals_with_status.any?
        .mb-3{data: {controller: "selection-toolbar options-filter"}}
          = render "shared/selection_pages/toolbar",
            form: f,
            save_label: "Associate selected",
            can_manage: true,
            search_placeholder: "Search goals by title or parent...",
            search_aria_label: "Filter parent goals"

          .selection-page-columns{data: {options_filter_target: "list"}}
            - @available_goals_with_status.each do |goal_status|
              = render "organizations/goal_links/associable_goal_option",
                goal: goal_status[:goal],
                disabled: goal_status[:in_hierarchy]
      - else
        .alert.alert-info
          %i.bi.bi-info-circle.me-2
          No other goals available to associate as parents. Create goals first or use "Create new parent goals" from the previous step.

      .d-flex.gap-2.mt-3
        = link_to @return_url, class: 'btn btn-outline-secondary' do
          %i.bi.bi-arrow-left.me-1
          = @return_text || 'Cancel'
        = render "shared/selection_pages/save_button",
          form: f,
          label: "Associate selected",
          can_manage: true,
          button_id: "associate-selected-btn",
          test_id: "associate-selected"
