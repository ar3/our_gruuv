- content_for :title, "Search"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @organization, crumbs: [{ label: "Search", url: nil }])

- content_for :header do
  .d-flex.align-items-center
    %h1.mb-0.me-2
      %i.bi.bi-search.me-2
      Search Results
    - if @results[:total_count] > 0
      %span.badge.bg-primary.ms-2= "#{@results[:total_count]} results"

.row.justify-content-center.mb-4
  .col-lg-12
    .card.border-0.shadow-sm
      .card-body
        = form_with url: organization_search_path(@organization), method: :get, local: true, class: "mb-0" do |f|
          .row
            .col-md-10
              = f.text_field :q, 
                  value: @query, 
                  placeholder: "Search people, organizations, pages, observations, assignments, abilities, and titles...", 
                  class: "form-control form-control-lg",
                  autofocus: true,
                  style: "font-size: 1.25rem; padding: 1rem;"
            .col-md-2
              = f.submit "Search", class: "btn btn-primary btn-lg w-100", style: "padding: 1rem; font-size: 1.1rem;"

- if @query.present?
  - if @results[:total_count] > 0
    .row.justify-content-center
      .col-lg-12
        - if @results[:people].any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-people.me-2
                People (#{@results[:people].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Name
                      %th Email
                  %tbody
                    - @results[:people].each do |person|
                      - teammate = person.teammates.find_by(organization: @organization)
                      %tr
                        %td
                          - if teammate
                            = link_to person.display_name, internal_organization_company_teammate_path(@organization, teammate), class: "text-decoration-none fw-bold"
                          - else
                            = person.display_name
                        %td= person.email

        - if @results[:organizations].any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-building.me-2
                Organizations (#{@results[:organizations].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Name
                      %th Type
                  %tbody
                    - @results[:organizations].each do |organization|
                      %tr
                        %td
                          = link_to organization.display_name, organization_path(organization), class: "text-decoration-none fw-bold"
                        %td Organization

        - if @results[:assignments].any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-briefcase.me-2
                Assignments (#{@results[:assignments].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Title
                      %th Tagline
                      %th Department
                  %tbody
                    - @results[:assignments].each do |assignment|
                      %tr
                        %td
                          = link_to assignment.title, organization_assignment_path(@organization, assignment), class: "text-decoration-none fw-bold"
                        %td= truncate(assignment.tagline, length: 50)
                        %td= search_department_cell(assignment)

        - if @results[:abilities].any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-award.me-2
                Abilities (#{@results[:abilities].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Name
                      %th Description
                      %th Department
                  %tbody
                    - @results[:abilities].each do |ability|
                      %tr
                        %td
                          = link_to ability.name, organization_ability_path(@organization, ability), class: "text-decoration-none fw-bold"
                        %td= truncate(ability.description, length: 100)
                        %td= search_department_cell(ability)

        - if @results[:titles].any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-briefcase-fill.me-2
                Titles (#{@results[:titles].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Title
                      %th Department
                  %tbody
                    - @results[:titles].each do |title|
                      %tr
                        %td
                          = link_to title.external_title, organization_title_path(@organization, title), class: "text-decoration-none fw-bold"
                        %td= search_department_cell(title)

        - if @results.fetch(:go_to, []).any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-signpost-split.me-2
                Go To (#{@results[:go_to].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Page
                      %th Section
                      %th Goal
                  %tbody
                    - @results[:go_to].each do |entry|
                      %tr
                        %td
                          = link_to entry.path, class: "text-decoration-none fw-bold" do
                            %i.bi.me-2.text-muted{class: entry.icon}
                            = entry.label
                        %td= entry.section_label
                        %td= truncate(entry.goal, length: 100)

        - if @results[:observations].any?
          .card.mb-4
            .card-header
              %h5.mb-0
                %i.bi.bi-chat-text.me-2
                Observations (#{@results[:observations].count})
            .card-body
              .table-responsive
                %table.table.table-hover
                  %thead
                    %tr
                      %th Story Preview
                      %th Observer
                      %th Date
                  %tbody
                    - @results[:observations].each do |observation|
                      %tr
                        %td
                          = link_to truncate(observation.story, length: 100), organization_observation_path(@organization, observation), class: "text-decoration-none fw-bold"
                        %td= observation.observer.display_name
                        %td= format_date_in_user_timezone(observation.observed_at, format: "%b %d, %Y")
  - else
    .row.justify-content-center
      .col-lg-12
        .alert.alert-info
          %h6.mb-2
            %i.bi.bi-info-circle.me-2
            No Results Found
          %p.mb-2 
            No results found for "#{@query}". Try different keywords or check your spelling.
          %p.mb-0
            %small.text-muted Search across people, organizations, pages, observations, assignments, abilities, and titles in #{@organization.display_name}.
- else
  .row.justify-content-center
    .col-lg-12
      .alert.alert-light
        %h6.mb-2
          %i.bi.bi-search.me-2
          Start Searching
        %p.mb-2 
          Enter a search term above to find people, organizations, pages, observations, assignments, abilities, and titles.
        %p.mb-0
          %small.text-muted Search is scoped to #{@organization.display_name} and respects your permissions.
