- page_help_id = "sourceFromSlackPageHelp"
- viewer = current_company_teammate
- return_to = ogos_source_from_slack_organization_company_teammate_path(organization, teammate_route_param(@teammate))

= render "page_header",
         page_help_id: page_help_id,
         page_help_tooltip: "Source draft OGOs from Slack moments already about #{@casual_name}. Click for details."

.collapse.mb-4{id: page_help_id}
  = render "source_from_slack_page_help", casual_name: @casual_name

= render "tabs"

.card.border-0.shadow-sm.mb-4
  .card-header.bg-transparent.border-0
    %h5.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      %span
        %i.bi.bi-slack.me-2
        Source OGOs from Slack about #{@casual_name}
  .card-body
    - if viewer.nil?
      %p.mb-0.text-muted
        Sign in as a teammate in this organization to connect Slack search.
    - elsif viewer.has_slack_search_identity?
      .alert.alert-success.border.mb-3
        %i.bi.bi-check-circle.me-1
        Slack (search) is connected for
        %strong= viewer.person.casual_name
        — searches run with your Slack visibility.
      .d-flex.flex-wrap.gap-2.mb-4
        = link_to organization_company_teammate_slack_search_oauth_authorize_path(organization, teammate_route_param(viewer), source: "sourceFromSlack", return_to: return_to), class: "btn btn-outline-secondary btn-sm" do
          %i.bi.bi-arrow-repeat.me-1
          Reconnect
        = button_to organization_company_teammate_slack_search_disconnect_path(organization, teammate_route_param(viewer), return_to: return_to),
                    method: :delete,
                    class: "btn btn-outline-danger btn-sm",
                    data: { turbo: false, confirm: "Disconnect Slack (search)? You will not be able to search Slack as yourself until you reconnect." } do
          %i.bi.bi-x-circle.me-1
          Disconnect

      %h6.fw-semibold.mb-2 Run a new search
      = form_with url: organization_company_teammate_possible_observation_slack_searches_path(organization, teammate_route_param(@teammate)), method: :post, local: true, class: "row g-2 align-items-end" do
        .col-auto
          %label.form-label.mb-1{for: "slack-search-window-days"} Time window
          %select#slack-search-window-days.form-select{name: "possible_observation_slack_search[window_days]"}
            - PossibleObservationSlackSearch::ALLOWED_WINDOW_DAYS.each do |days|
              %option{value: days, selected: days == PossibleObservationSlackSearch::DEFAULT_WINDOW_DAYS}
                Last #{days} days
        .col-auto
          %button.btn.btn-primary{type: "submit"}
            %i.bi.bi-search.me-1
            Search Slack about #{@casual_name}
      %p.mt-2.mb-0.small.text-muted
        Uses your Slack (search) token. Prefer a linked Slack identity on #{@casual_name} for mention-based results; otherwise we search by name.
    - else
      %p.mb-3
        Connect
        %strong Slack (search)
        on your own profile so OurGruuv can search Slack
        %em as you
        (your visibility). This is separate from the linked Slack identity used for DMs and mentions.
      = link_to organization_company_teammate_slack_search_oauth_authorize_path(organization, teammate_route_param(viewer), source: "sourceFromSlack", return_to: return_to), class: "btn btn-primary" do
        %i.bi.bi-slack.me-1
        Connect Slack (search)
      %p.mt-3.mb-0.text-muted
        %i.bi.bi-info-circle.me-1
        You can also connect or disconnect from your profile Identities section.

.card.border-0.shadow-sm
  .card-header.bg-transparent.border-0
    %h5.mb-0 Prior searches about #{@casual_name}
  .card-body
    - searches = @prior_slack_searches || []
    - if searches.any?
      .table-responsive
        %table.table.table-hover.align-middle.mb-0
          %thead
            %tr
              %th Search
              %th Run by
              %th Status
              %th Messages
              %th When
              %th
          %tbody
            - searches.each do |search|
              %tr
                %td= search.display_name
                %td= search.creator_company_teammate&.person&.casual_name
                %td
                  %span.badge.text-bg-secondary= search.search_status
                %td= search.search_status == "completed" ? search.raw_messages_count : "—"
                %td.text-muted= l(search.created_at, format: :short)
                %td.text-end
                  - if policy(search).show?
                    = link_to "Open", organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), search), class: "btn btn-sm btn-outline-primary"
                  - else
                    %span.text-muted Open (creator only)
    - else
      %p.mb-0.text-muted No Slack searches about #{@casual_name} yet.
