- summary = local_assigns[:summary]
- teammate = local_assigns[:teammate]
- org = local_assigns[:organization]
- chart_id_prefix = local_assigns.fetch(:chart_id_prefix, 'my-growth-experiences')
- show_divider = local_assigns.fetch(:show_divider, true)
- energy_chart_id = "#{chart_id_prefix}-energy-pie-chart"
- rating_chart_id = "#{chart_id_prefix}-rating-pie-chart"

- if show_divider
  %hr.my-4

.row.mb-3
  .col-12
    .alert.my-growth-experiences-summary-alert{class: my_growth_experiences_summary_alert_class(summary), role: 'status'}
      %p.mb-0= my_growth_experiences_summary_alert_html(summary, teammate, org)

.row.mb-3
  .col-lg-6.mb-3.mb-lg-0
    .card.h-100
      .card-body
        %h6.mb-3 Energy allocation
        - if summary.chart_data_present?
          %div{id: energy_chart_id, style: 'height: 300px;'}
        - else
          %p.text-muted.mb-0 No active assignments with energy allocated.
  .col-lg-6
    .card.h-100
      .card-body
        %h6.mb-3 Energy by latest check-in rating
        - if summary.chart_data_present?
          %div{id: rating_chart_id, style: 'height: 300px;'}
        - else
          %p.text-muted.mb-0 No active assignments with energy allocated.

- if summary.chart_data_present?
  :javascript
    (function() {
      var energyChartId = #{energy_chart_id.to_json};
      var ratingChartId = #{rating_chart_id.to_json};
      var energyData = #{summary.energy_by_assignment_chart.to_json};
      var ratingData = #{summary.energy_by_rating_chart.to_json};

      function initExperiencesSummaryCharts() {
        if (typeof Highcharts === 'undefined') return;

        var energyEl = document.getElementById(energyChartId);
        if (energyEl && energyData.length > 0) {
          Highcharts.chart(energyChartId, {
            chart: { type: 'pie' },
            title: { text: null },
            accessibility: { enabled: false },
            plotOptions: {
              pie: {
                allowPointSelect: true,
                cursor: 'pointer',
                dataLabels: {
                  enabled: true,
                  format: '<b>{point.name}</b>: {point.y}% ({point.percentage:.1f}%)'
                }
              }
            },
            series: [{
              name: 'Energy',
              colorByPoint: true,
              data: energyData
            }]
          });
        }

        var ratingEl = document.getElementById(ratingChartId);
        if (ratingEl && ratingData.length > 0) {
          Highcharts.chart(ratingChartId, {
            chart: { type: 'pie' },
            title: { text: null },
            accessibility: { enabled: false },
            plotOptions: {
              pie: {
                allowPointSelect: true,
                cursor: 'pointer',
                dataLabels: {
                  enabled: true,
                  format: '<b>{point.name}</b>: {point.y}% ({point.percentage:.1f}%)'
                }
              }
            },
            series: [{
              name: 'Energy',
              colorByPoint: false,
              data: ratingData
            }]
          });
        } else if (ratingEl) {
          ratingEl.innerHTML = '<p class="text-muted mb-0">No rating data to chart.</p>';
        }
      }

      document.addEventListener('turbo:load', initExperiencesSummaryCharts);
      document.addEventListener('DOMContentLoaded', initExperiencesSummaryCharts);
    })();
