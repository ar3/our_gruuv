- organization = local_assigns[:organization]
- teammate = local_assigns[:teammate]
- associable = local_assigns[:associable]
- casual_name = local_assigns[:casual_name]
- return_url = local_assigns[:return_url]
- return_text = local_assigns[:return_text]
- open_count = (local_assigns[:counts] || {})[:open_associated_goals_count].to_i
- object_label = associable_display_title(associable)
- ogo_href = my_growth_observation_new_for_associable_path(organization, teammate, associable, return_url: return_url, return_text: return_text)
- ogo_label = "Add a win/challenge/note (OGO) about #{casual_name} & #{object_label}"
- goal_flow_allowed = my_growth_goal_flow_allowed_for_associable?(associable, teammate)
- goal_href = associable_goals_choose_manage_path(organization, associable, return_url: return_url, return_text: return_text, for_company_teammate_id: teammate.id)
- goal_label = my_growth_catalog_goal_button_label(casual_name: casual_name, associable: associable, open_count: open_count)
.assignment-card-action-footer.border-top.row.g-0
  .assignment-card-action-footer__half.col-6.border-end
    = link_to ogo_href, class: 'assignment-card-action-footer__action text-wrap small flex-grow-1', target: '_blank', rel: 'noopener', data: { turbo: false } do
      = ogo_label
  .assignment-card-action-footer__half.col-6
    - if goal_flow_allowed
      = link_to goal_href, class: 'assignment-card-action-footer__action text-wrap small flex-grow-1', target: '_blank', rel: 'noopener', data: { turbo: false } do
        = goal_label
    - else
      %span.assignment-card-action-footer__read-only-hit.d-flex.flex-column.flex-grow-1{tabindex: 0, role: 'note', data: { bs_toggle: 'tooltip' }, title: my_growth_goal_flow_denied_tooltip}
        .assignment-card-action-footer__action.assignment-card-action-footer__action--read-only.text-wrap.small.flex-grow-1
          %i.bi.bi-exclamation-triangle.me-1
          = goal_label
