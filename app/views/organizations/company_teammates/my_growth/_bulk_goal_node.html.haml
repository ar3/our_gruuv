- goal = node[:goal]
- children = node[:children] || []
- direct_children_count = node[:direct_children_count] || 0
- total_descendants_count = node[:total_descendants_count] || 0
- has_children = children.any?
- node_id = "bulk-goal-node-#{goal.id}"
- children_id = "bulk-goal-children-#{goal.id}"
- most_recent_check_in = node[:most_recent_check_in]
- current_week_check_in = node[:current_week_check_in]
- can_check_in = node[:can_check_in]
- viewer_is_goal_owner = current_company_teammate.present? && goal.owner_id == current_company_teammate.id
- show_bulk_check_in_form = bulk_goal_check_in_form?(goal: goal, can_check_in: can_check_in, viewer_is_goal_owner: viewer_is_goal_owner)
- show_note_win_cta = bulk_goal_note_win_cta?(goal: goal, show_form: show_bulk_check_in_form)

.tree-node{id: node_id, style: "margin-left: #{depth * 40}px; margin-bottom: 10px;"}
  .d-flex.align-items-start
    - if depth > 0
      %i.bi.bi-arrow-return-right.me-2{style: "color: #999; margin-top: 12px;"}
    .card{style: "width: 100%; max-width: 820px; position: relative;", class: goal_warning_class(goal)}
      .card-body.p-2
        .d-flex.align-items-start
          .flex-shrink-0.me-3
            = goal_owner_image(goal, size: 48)
          .flex-grow-1
            - if has_children
              .d-flex.align-items-center.mb-2
                %button.btn.btn-sm.btn-link.p-0.me-2.toggle-children{type: "button", "data-bs-toggle": "collapse", "data-bs-target": "##{children_id}", "aria-expanded": "true", "aria-controls": children_id, style: "text-decoration: none; color: #666; min-width: 20px;"}
                  %i.bi.bi-chevron-up.toggle-icon
                %span.badge.bg-light.text-dark.small
                  - if direct_children_count == total_descendants_count
                    #{pluralize(direct_children_count, 'sub-goal')}
                  - else
                    #{pluralize(direct_children_count, 'sub-goal')} directly & #{total_descendants_count} total

            .d-flex.align-items-center.flex-wrap.mb-1
              = link_to goal.title, organization_goal_path(organization, goal), class: "text-decoration-none fw-bold me-2"
              - if goal.should_show_warning?
                %i.bi.bi-exclamation-triangle.text-warning{"data-bs-toggle" => "tooltip", "data-bs-title" => goal_warning_message(goal)}

            .d-flex.align-items-center.flex-wrap.mb-1
              %span.small.me-2
                = goal_index_info_sentence(goal)
              %span.text-muted.small.me-2
                |
              %span.text-muted.small.me-2{"data-bs-toggle" => "tooltip", "data-bs-title" => goal_privacy_tooltip_text(goal)}
                = goal_visibility_display(goal)
              %span.text-muted.small
                | Owned by: #{goal_owner_display_name(goal)}
              = goal_external_association_links(organization, goal)

            - if most_recent_check_in.present?
              .small.text-muted.mb-2
                = render 'organizations/goals/goal_check_in_sentence', check_in: most_recent_check_in, goal: goal, short: true, use_casual_name: true
                = render 'shared/on_track_pill', status: goal.on_track_status_for_check_in(most_recent_check_in)

            - if goal.most_likely_target_date.present? && goal.completed_at.nil?
              - if show_note_win_cta && policy(Observation).create?
                .mt-1
                  - quick_note_params = { privacy_level: 'observed_and_managers', return_url: request.fullpath, return_text: weekly_goal_confidence_check_in_bulk_label, goal_id: goal.id, observee_ids: goal.observee_teammate_ids_for_observation }
                  = link_to new_quick_note_organization_observations_path(organization, quick_note_params), class: 'btn btn-outline-primary w-100', target: '_blank', rel: 'noopener noreferrer' do
                    %i.bi.bi-sticky.me-2
                    Add a note/win/challenge about this goal
              - elsif show_note_win_cta
                .d-flex.align-items-center.gap-2.mt-1
                  .flex-grow-1
                    %button.btn.btn-outline-secondary.w-100{type: "button", disabled: true}
                      %i.bi.bi-sticky.me-2
                      Add a note/win/challenge about this goal
                  %i.bi.bi-exclamation-triangle.text-warning{"data-bs-toggle" => "tooltip", "data-bs-title" => "You don't have permission to add a note/win/challenge about this goal.", tabindex: "0", role: "img", "aria-label" => "Permission notice"}
              - elsif show_bulk_check_in_form
                - can_update_goal = policy(goal).update?
                .check-in-inline.mt-1.p-1.bg-light.rounded
                  .goal-check-in-inline-layout
                    .goal-check-in-inline-layout__main.d-flex.flex-column.gap-1
                      .d-flex.flex-wrap.align-items-center.gap-2
                        %span.small I'm
                        = select_tag "goal_check_ins[#{goal.id}][confidence_percentage]", options_for_select(confidence_percentage_options, current_week_check_in&.confidence_percentage), { include_blank: 'Select...', class: 'form-select form-select-sm', style: 'width: auto; min-width: 80px; display: inline-block;' }
                        %span.small confident this'll be hit by
                        - if can_update_goal
                          = date_field_tag "goal_check_ins[#{goal.id}][most_likely_target_date]", goal.most_likely_target_date, class: 'form-control form-control-sm', style: 'width: auto; min-width: 130px; display: inline-block;'
                        - else
                          %span.small= goal.most_likely_target_date.present? ? goal.most_likely_target_date.strftime('%b %d, %Y') : '—'
                        %span.small .
                      = text_field_tag "goal_check_ins[#{goal.id}][confidence_reason]", current_week_check_in&.confidence_reason, class: 'form-control form-control-sm goal-check-in-inline-layout__reason', placeholder: 'Brief update (optional)...'

- if has_children
  .collapse.show{id: children_id}
    - children.each do |child_node|
      = render 'organizations/company_teammates/my_growth/bulk_goal_node', node: child_node, depth: depth + 1, organization: organization
