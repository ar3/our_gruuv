-# Locals: messages, search
- messages = local_assigns.fetch(:messages)
- search = local_assigns.fetch(:search)
- preview_limit = 10
- preview_messages = messages.first(preview_limit)

.card.border-0.shadow-sm
  .card-header.bg-transparent.border-0
    .d-flex.justify-content-between.align-items-center.flex-wrap.gap-2
      %h5.mb-0
        Messages
        %span.badge.text-bg-light.ms-1= search.messages_count
      - if search.raw_results_file.attached?
        = link_to download_raw_results_organization_company_teammate_possible_observation_slack_search_path(organization, @teammate, search),
                  class: "btn btn-sm btn-outline-secondary" do
          %i.bi.bi-download.me-1
          Download
  .card-body
    - if messages.empty?
      %p.mb-0.text-muted No messages matched this search in the selected window (or none were visible to you).
    - else
      .list-group.list-group-flush
        - preview_messages.each do |message|
          .list-group-item.px-0
            .d-flex.justify-content-between.align-items-start.gap-3.flex-wrap
              .flex-grow-1
                .small.text-muted.mb-1
                  - if message[:channel_name].present?
                    %span ##{message[:channel_name]}
                  - if message[:username].present?
                    %span.ms-1 @#{message[:username]}
                  - if message[:ts].present?
                    %span.ms-1= Time.zone.at(message[:ts].to_f).strftime("%Y-%m-%d %H:%M")
                %p.mb-0.text-break= truncate(message[:text].to_s, length: 500)
              .flex-shrink-0
                - if message[:permalink].present?
                  = link_to message[:permalink], class: "btn btn-sm btn-outline-primary", target: "_blank", rel: "noopener" do
                    %i.bi.bi-box-arrow-up-right.me-1
                    Open in Slack
      %p.mt-2.mb-0.small.text-muted
        Showing #{preview_messages.size} of #{messages.size} messages.
        - if search.raw_results_file.attached? && messages.size > preview_limit
          Download for the full set.
