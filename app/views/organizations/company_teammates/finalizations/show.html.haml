- finalize_page_label = review_finalize_clarity_check_ins_together_label
- content_for :title, teammate_context_page_title(@selected_teammate, finalize_page_label)
- finalization_page_help_id = 'finalizationClarityPageHelp'

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups,
               path_for_teammate: ->(tm) { organization_company_teammate_finalization_path(organization, tm) },
               switch_aria_label: "Switch teammate for review and finalization"
      %span= " - #{finalize_page_label}"
      = render 'shared/page_help/header_info_button',
               collapse_id: finalization_page_help_id,
               tooltip: 'Review and finalization purpose and MAAP flow. Click for details.'

- content_for :header_action do
  = render 'people/view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: clarity_hub_label, url: hub_organization_company_teammate_check_ins_path(organization, @teammate) }, { label: finalize_page_label, url: nil }])

-# Only prompt "did you save?" when there is an editable form (manager with check-ins ready to finalize)
- finalize_confirm_leave = @view_mode == :manager && (@ready_position_check_in || @ready_assignment_check_ins&.any? || @ready_aspiration_check_ins&.any?)
- finalization_form_data = finalize_confirm_leave ? { controller: "confirm-leave", action: "input->confirm-leave#markDirty change->confirm-leave#markDirty turbo:submit-end->confirm-leave#markCleanOnSuccess" } : {}
.collapse.mb-4{id: finalization_page_help_id}
  = render 'organizations/company_teammates/finalizations/finalization_page_help',
           organization: organization,
           teammate: @teammate

= render 'shared/check_in_wizard_header', organization: @organization, teammate: @teammate, current_step: 2

= form_with url: organization_company_teammate_finalization_path(organization, @teammate), method: :post, local: true, data: finalization_form_data do |f|
  -# Aspiration Section
  = render 'shared/section_header', 
           title: 'Aspirational Values', 
           icon: 'bi-star', 
           description: 'Set official aspiration ratings'
  
  = render 'organizations/finalizations/aspiration_finalization_table', form: f, view_mode: @view_mode
  
  -# Assignment Section
  - employee_name = @teammate.person.casual_name
  - manager_name = @teammate.current_manager&.casual_name.presence || 'Manager'
  - energy_allocation = @assignment_energy_allocation
  - show_energy_allocation = energy_allocation&.contexts? || false
  = render 'shared/section_header',
           title: 'Assignments/Outcomes',
           icon: 'bi-clipboard-check',
           description: 'Finalize individual assignment ratings and energy'

  - if show_energy_allocation
    = render 'organizations/company_teammates/finalizations/assignment_energy_allocation_section_help',
             employee_name: employee_name,
             manager_name: manager_name
    %div#finalization-assignment-energy-section.finalization-assignment-energy-section{
      data: {
        controller: 'assignment-energy-allocation-finalization',
        assignment_energy_allocation_finalization_colors_value: energy_allocation.color_by_assignment_id.to_json,
        assignment_energy_allocation_finalization_current_forecast_value: energy_allocation.current_forecast_by_assignment_id.to_json,
        assignment_energy_allocation_finalization_employee_actual_value: energy_allocation.employee_actual_by_assignment_id.transform_values { |v| v.nil? ? '' : v }.to_json,
        assignment_energy_allocation_finalization_updated_forecast_value: energy_allocation.updated_forecast_by_assignment_id.to_json,
        assignment_energy_allocation_finalization_assignments_value: energy_allocation.assignment_metadata_by_id.to_json,
        assignment_energy_allocation_finalization_employee_name_value: employee_name
      }
    }
      .assignment-energy-allocation-sticky-wrap
        = render 'organizations/company_teammates/finalizations/assignment_energy_allocation_panel',
                 summary: energy_allocation,
                 employee_name: employee_name,
                 manager_name: manager_name
      = render 'organizations/finalizations/assignment_finalization_table', form: f, view_mode: @view_mode
  - else
    = render 'organizations/finalizations/assignment_finalization_table', form: f, view_mode: @view_mode
  
  
  -# Position Section
  = render 'shared/section_header', 
           title: 'Position/Overall', 
           icon: 'bi-briefcase', 
           description: 'Set official position rating'
  
  = render 'organizations/finalizations/position_finalization_table', form: f, view_mode: @view_mode
  
  -# Finalization button section
  - if @ready_position_check_in || @ready_assignment_check_ins&.any? || @ready_aspiration_check_ins&.any?
    .row.mt-4
      .col-12
        - if @view_mode == :manager
          .alert.alert-warning
            %strong ⚠️ This will:
            %ul
              %li Create an Audit record for #{@person.casual_name} to acknowledge
              %li= close_selected_clarity_check_ins_label
              %li Send notification to #{@person.casual_name} (coming soon)
          
          .mb-3
            = f.label :maap_snapshot_reason, "Reason (optional)", class: "form-label"
            = f.text_field :maap_snapshot_reason, 
                           class: "form-control", 
                           placeholder: "e.g., Q4 2024 Performance Review, Annual Check-in, etc.",
                           value: "Check-in finalization for #{@teammate.person.display_name}"
          
          = f.submit finalize_selected_clarity_check_ins_label, class: 'btn btn-success btn-lg',
                     data: { confirm: finalize_clarity_check_ins_confirm_message }
        - else
          .alert.alert-info
            %i.bi.bi-info-circle.me-2
            %strong
              %i.bi.bi-exclamation-triangle.me-2
              = manager_will_finalize_clarity_check_ins_label
          
          = f.submit finalize_selected_clarity_check_ins_label, class: 'btn btn-success btn-lg', disabled: true
  - else
    .row.mt-4
      .col-12
        .alert.alert-info
          %i.bi.bi-info-circle.me-2
          %strong= no_clarity_check_ins_ready_for_finalization_label

:javascript
  document.addEventListener('DOMContentLoaded', function() {
    const checkboxes = document.querySelectorAll('.finalize-checkbox');
    
    checkboxes.forEach(function(checkbox) {
      checkbox.addEventListener('change', function() {
        if (!this.checked) {
          const alertMessage = this.dataset.alert || 'This row will not be saved if this stays unchecked';
          alert(alertMessage);
        }
      });
    });
  });