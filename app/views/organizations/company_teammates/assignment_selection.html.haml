- content_for :title, "Select Assignments - #{@teammate.person.display_name}"

- content_for :header do
  %h1.mb-0 Select Assignments for #{@teammate.person.display_name}

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Check-Ins", url: organization_company_teammate_check_ins_path(organization, @teammate) }, { label: "Select Assignments", url: nil }])

.row.justify-content-center
  .col-lg-10
    - if @current_employment
      .card.mb-4
        .card-header
          %h5.mb-0
            %i.bi.bi-clipboard-check.me-2
            Assignment Selection
          %p.text-muted.mb-0
            Select assignments for #{@teammate.person.display_name}. Required and active assignments are handled automatically (see note below the toolbar).
        .card-body
          = form_with url: update_assignments_organization_company_teammate_path(organization, @teammate), method: :post do |f|
            - if @assignments.any?
              .mb-3{data: {controller: "selection-toolbar options-filter"}}
                = render "shared/selection_pages/toolbar",
                  form: f,
                  save_label: "Save Assignments",
                  can_manage: true,
                  search_placeholder: "Search assignments by name, department, or tagline...",
                  search_aria_label: "Filter assignments"

                %p.text-muted.small.mb-3
                  Required and active assignments are automatically added and cannot be changed from this list.

                .selection-page-columns{data: {options_filter_target: "list"}}
                  - @assignments.each do |assignment|
                    - is_required = @required_assignment_ids.include?(assignment.id)
                    - is_suggested = @suggested_assignment_ids.include?(assignment.id)
                    - is_assigned = @assigned_assignment_ids.include?(assignment.id)
                    - is_disabled = is_required || is_assigned
                    - is_checked = is_required || is_assigned
                    - department_label = assignment.department&.display_name || "Company-wide"

                    .filterable-option{class: ("opacity-75" if is_disabled)}
                      .form-check
                        = check_box_tag "assignment_ids[]",
                          assignment.id,
                          is_checked,
                          disabled: is_disabled,
                          class: "form-check-input",
                          id: "assignment_ids_#{assignment.id}",
                          data: {selection_toolbar_label: assignment.title}
                        = label_tag "assignment_ids_#{assignment.id}", class: "form-check-label w-100" do
                          %strong= assignment.title
                          %br
                          %small.text-muted= department_label
                          - if assignment.tagline.present?
                            %br
                            %small.text-muted= assignment.tagline
                          .mt-1
                            - if is_required
                              %span.badge.bg-primary
                                %i.bi.bi-star-fill.me-1
                                Required for position
                            - elsif is_assigned
                              %span.badge.bg-success
                                %i.bi.bi-check-circle-fill.me-1
                                Already assigned
                            - elsif is_suggested
                              %span.badge.bg-info.text-dark
                                %i.bi.bi-lightbulb.me-1
                                Suggested
                            - else
                              %span.badge.bg-secondary Optional

              .d-flex.gap-2.mt-3
                = link_to "Cancel", organization_company_teammate_check_ins_path(organization, @teammate), class: "btn btn-outline-secondary"
                = render "shared/selection_pages/save_button", form: f, label: "Save Assignments", can_manage: true
            - else
              .alert.alert-info
                %i.bi.bi-info-circle.me-2
                No assignments available for this organization.
                = link_to "Create an assignment", organization_assignments_path(organization), class: "btn btn-sm btn-primary ms-2"
    - else
      .card.mb-4
        .card-header
          %h5.mb-0
            %i.bi.bi-exclamation-triangle.me-2
            No Active Employment
        .card-body
          .alert.alert-warning
            %p.mb-2
              %strong #{@teammate.person.display_name} must have an active employment record before assignments can be selected.
            %p.mb-0
              Please create an employment record first, then return to select assignments.

          = link_to "Back to Check-Ins", organization_company_teammate_check_ins_path(organization, @teammate), class: "btn btn-outline-secondary"
