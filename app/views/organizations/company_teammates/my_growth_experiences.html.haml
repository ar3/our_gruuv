- content_for :title, "#{@selected_teammate.person.casual_name.strip}'s Growth"

- content_for :header do
  = render 'organizations/company_teammates/my_growth/header',
    path_for_teammate: ->(tm) { my_growth_experiences_organization_company_teammate_path(organization, tm) },
    intent_text: "Compare day-to-day assignments against the position blueprint so growth by experiences is clear."

- content_for :header_action do
  = render 'people/view_switcher'

= render 'organizations/company_teammates/my_growth/nav'

.alert.alert-info
  %p.mb-0
    There are four ways to grow: new experiences, gaining skills/knowledge/abilities, goal attainment, and position/title changes. This is the first of the four.
    %span.fw-bold.fs-5 Grow by experiences.
    Your Assignments are an indication of what you are being relied on for, and therefore can be a great way to gain new experiences that are invaluable to your growth.

- header_row_class = @teammate.next_goal_position.blank? ? 'my-growth-experiences__header-row--elevated' : nil
.row.mb-3{class: header_row_class}
  .col-lg-6
    %h2.h4.mb-1= "#{@teammate.person.casual_name}'s real day-to-day"
    %p.small.text-muted.mb-0
      = link_to "View #{@teammate.person.casual_name}'s teammate page", internal_organization_company_teammate_path(organization, @teammate), class: 'text-decoration-none'
  .col-lg-3
    %h2.h4.mb-1= "#{organization.display_name}'s blueprint"
    %p.small.text-muted.mb-0
      - if @current_employment&.position
        = link_to @current_employment.position.display_name, organization_position_path(organization, @current_employment.position), class: 'text-decoration-none'
      - else
        No current position selected
  - if @teammate.next_goal_position.present?
    .col-lg-3
      %h2.h4.mb-1= "#{organization.display_name}'s blueprint"
      %p.small.text-muted.mb-0
        = link_to @teammate.next_goal_position.display_name, organization_position_path(organization, @teammate.next_goal_position), class: 'text-decoration-none'
  - else
    .col-lg-3.my-growth-experiences__target-header--absent.d-none.d-lg-block
      %h2.visually-hidden Target position
      .my-growth-experiences__no-target-alert.alert.alert-info.small.mb-0
        %p.mb-2
          #{@teammate.person.casual_name} does not have a target position, and they are focused on growing in the other three ways: experiences, abilities, and goal quality.
        %p.mb-2
        %p.mb-0
          If a different position is a part of your growth goals, visit the
          = link_to 'Position / Title Change tab', my_growth_position_change_organization_company_teammate_path(organization, @teammate), class: 'alert-link'
          to define a target position.

- if @my_growth_experience_primary_rows.blank? && !@my_growth_suggested_toggle_visible && !@my_growth_show_suggested
  .alert.alert-secondary.mb-0
    No active assignments in this organization and no required blueprint assignments to compare.
- else
  - @my_growth_experience_primary_rows.each do |row|
    = render 'organizations/company_teammates/my_growth/experience_row',
      experience_row: row,
      teammate: @teammate,
      organization: organization,
      latest_finalized_assignment_check_ins_by_assignment_id: @latest_finalized_assignment_check_ins_by_assignment_id,
      my_growth_assignment_goal_counts_by_id: @my_growth_assignment_goal_counts_by_id,
      target_position: @teammate.next_goal_position

  - if @my_growth_suggested_toggle_visible
    .row.mb-3
      .col-12.text-center{id: @my_growth_suggested_anchor}
        - if @my_growth_show_suggested
          = link_to 'Hide suggested assignments', my_growth_experiences_organization_company_teammate_path(organization, @teammate, anchor: @my_growth_suggested_anchor), class: 'btn btn-outline-secondary btn-sm'
        - else
          = link_to 'Show suggested assignments', my_growth_experiences_organization_company_teammate_path(organization, @teammate, show_suggested: true, anchor: @my_growth_suggested_anchor), class: 'btn btn-outline-secondary btn-sm'

  - if @my_growth_show_suggested
    - @my_growth_experience_suggested_rows.each do |row|
      = render 'organizations/company_teammates/my_growth/experience_row',
        experience_row: row,
        teammate: @teammate,
        organization: organization,
        latest_finalized_assignment_check_ins_by_assignment_id: @latest_finalized_assignment_check_ins_by_assignment_id,
        my_growth_assignment_goal_counts_by_id: @my_growth_assignment_goal_counts_by_id,
        target_position: @teammate.next_goal_position

= render 'organizations/company_teammates/my_growth/experiences_summary',
  summary: @my_growth_experiences_summary,
  teammate: @teammate,
  organization: organization
