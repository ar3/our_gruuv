- content_for :title, "About Me - #{@teammate.person.casual_name}"

- content_for :header do
  %h1.mb-0 About #{@teammate.person.casual_name}
        
- content_for :header_action do
  = render 'people/view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Profile", url: organization_company_teammate_path(organization, @teammate) }, { label: "About Me", url: nil }])

-# Stories Section
= render 'stories_section'

-# Active Goals Section
= render 'goals_section'

-# Prompts/Reflections Section
= render 'prompts_section'

-# 1:1 Area Section
= render 'one_on_one_section'

-# Position/Overall Check-In Section (Read-Only)
= render 'position_check_in_section'

-# Assignments/Outcomes Check-In Section (Read-Only)
= render 'assignments_check_in_section'

-# Aspirational Values Check-In Section (Read-Only)
= render 'aspirations_check_in_section'

-# Abilities/Skills/Knowledge Section (Read-Only)
= render 'abilities_section'

