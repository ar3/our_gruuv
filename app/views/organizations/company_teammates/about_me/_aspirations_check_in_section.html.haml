- aspirations_indicator = aspirations_check_in_status_indicator(@teammate, organization)
= render 'shared/section_header', 
         title: 'Aspirational Values', 
         icon: 'bi-star', 
         description: 'Track progress toward personal goals',
         collapsible: true,
         collapse_target: 'aspirationsCheckInSection',
         status_indicator: aspirations_indicator

-# Summary view (shown when collapsed)
%div{class: "alert mb-4 collapse-summary #{status_indicator_alert_class(aspirations_indicator)}", "data-bs-toggle" => "collapse", "data-bs-target" => "#aspirationsCheckInSection", "aria-expanded" => "false", "aria-controls" => "aspirationsCheckInSection", "data-status-popover" => "true", "data-bs-trigger" => "hover", "data-bs-placement" => "top", "data-bs-html" => "true", "data-bs-content" => status_conditions_popover_content(:aspirations_check_in), style: "cursor: pointer;"}
  %p.mb-0
    %i{class: "#{status_indicator_icon(aspirations_indicator)} #{status_indicator_badge_class(aspirations_indicator)} me-2"}
    - if @company_aspirations.any?
      %span.inline-sentence-highlight= @company_name
      = " has ".html_safe
      %span.inline-sentence-highlight= pluralize(@company_aspirations.count, 'aspirational value')
      = ", and #{@teammate.person.casual_name} has had a check-in conversation about ".html_safe
      %span.inline-sentence-highlight= pluralize(@aspirations_with_recent_check_ins_count, 'aspirational value')
      = " of these aspirational values in the last 90 days.".html_safe
    - else
      No company aspirational values
  - if @viewing_own_about_me && @viewer_ready_aspiration_count.to_i.positive?
    %p.mb-0.mt-2
      ✅ You have completed your side of the check-in for #{@viewer_ready_aspiration_count} of the #{pluralize(@company_aspirations.count, 'aspirational value')}.

-# Collapsible content
.collapse#aspirationsCheckInSection
  .card.mb-4
    .card-body
      - if @aspiration_check_ins_data.any?
        .table-responsive
          %table.table.table-hover
            %thead
              %tr
                %th Aspiration
                %th Last Finalized
                %th Employee Status
                %th Manager Status
            %tbody
              - @aspiration_check_ins_data.each do |data|
                - aspiration = data[:aspiration]
                - check_in = data[:check_in]
                - latest_finalized = data[:latest_finalized]
                - clarity_level = latest_finalized&.clarity_level || :obscured
                - neither_side_ready = check_in.present? && !check_in.employee_completed? && !check_in.manager_completed?
                - show_clarity_merge_row = neither_side_ready && [:crystal_clear, :clear].include?(clarity_level)
                %tr
                  %td
                    - if clarity_level == :obscured
                      %i.bi.bi-exclamation-triangle-fill.text-danger.me-1
                    = link_to aspiration.name, organization_teammate_aspiration_path(organization, @teammate, aspiration), class: "text-decoration-none"
                  %td
                    - if latest_finalized
                      = format_date_in_user_timezone(latest_finalized.official_check_in_completed_at)
                    - else
                      %span.text-muted Check-in not started
                  - if show_clarity_merge_row
                    %td{ colspan: 2 }
                      .alert.alert-success.mb-0.py-2
                        - next_check_in_window = distance_of_time_in_words(latest_finalized.official_check_in_completed_at, latest_finalized.official_check_in_completed_at + 60.days)
                        = "#{@teammate.person.casual_name} is #{clarity_level.to_s.humanize.downcase} and a new check-in should be considered in #{next_check_in_window}"
                  - else
                    %td
                      - if check_in
                        - if check_in.employee_completed?
                          %span.badge.bg-success Ready
                          %br
                          %small.text-muted= format_date_in_user_timezone(check_in.employee_completed_at, format: '%b %d, %Y')
                        - else
                          %span.badge.bg-warning Not ready
                      - else
                        %span.text-muted Check-in not started
                    %td
                      - if check_in
                        - if check_in.manager_completed?
                          %span.badge.bg-success Ready
                          %br
                          %small.text-muted= format_date_in_user_timezone(check_in.manager_completed_at, format: '%b %d, %Y')
                        - else
                          %span.badge.bg-warning Not ready
                      - else
                        %span.text-muted Check-in not started
      - else
        %p.text-muted.mb-3 No company aspirational values found.
      
      .d-grid.mt-3
        = link_to "View Check-in Hub", 
                  hub_organization_company_teammate_check_ins_path(organization, @teammate),
                  class: "btn btn-outline-primary"

