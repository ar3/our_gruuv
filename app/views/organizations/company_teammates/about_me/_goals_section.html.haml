- goals_indicator = goals_status_indicator(@teammate)
= render 'shared/section_header', 
         title: 'Active Goals', 
         icon: 'bi-bullseye', 
         description: 'View goals and confidence ratings',
         collapsible: true,
         collapse_target: 'goalsSection',
         status_indicator: goals_indicator

-# Summary view (shown when collapsed)
- all_goals = @now_goals + @next_goals + @later_goals
- active_goals_count = all_goals.count
- all_goals_count = active_goals_count + @draft_goals_count
- goals_for_table = @about_me_goals_ordered || all_goals
- goal_child_ids = @about_me_goal_child_ids || Set.new
%div{class: "alert mb-4 collapse-summary #{status_indicator_alert_class(goals_indicator)}", "data-bs-toggle" => "collapse", "data-bs-target" => "#goalsSection", "aria-expanded" => "false", "aria-controls" => "goalsSection", "data-status-popover" => "true", "data-bs-trigger" => "hover", "data-bs-placement" => "top", "data-bs-html" => "true", "data-bs-content" => status_conditions_popover_content(:goals), style: "cursor: pointer;"}
  %p.mb-0
    %i{class: "#{status_indicator_icon(goals_indicator)} #{status_indicator_badge_class(goals_indicator)} me-2"}
    - if all_goals.any?
      = "#{@teammate.person.casual_name} has ".html_safe
      %span.inline-sentence-highlight= pluralize(all_goals.count, 'active goal')
      = ", ".html_safe
      %span.inline-sentence-highlight= pluralize(@goals_with_recent_check_ins_count, 'goal')
      = with_confidence_check_in_past_two_weeks.html_safe
      %span.inline-sentence-highlight= pluralize(@goals_completed_count, 'goal')
      = " completed in the last 90 days.".html_safe
    - else
      No active goals found.

-# Collapsible content
.collapse#goalsSection
  .card.mb-4
    .card-body
      - if all_goals.any?
        .table-responsive
          %table.table.table-hover
            %thead
              %tr
                %th Goal
                %th Last Confidence
                %th Status
            %tbody
              - goals_for_table.each do |goal|
                - latest_check_in = goal.instance_variable_get(:@latest_check_in)
                - needs_check_in = goal.instance_variable_get(:@needs_check_in)
                - is_child = goal_child_ids.include?(goal.id)
                %tr
                  %td
                    - if is_child
                      %i.bi.bi-arrow-90deg-down.rotate-270{style: "margin-right: 0.5rem;"}
                    = link_to goal.title, organization_goal_path(organization, goal), class: "text-decoration-none"
                  %td
                    - if latest_check_in
                      - reporter_name = latest_check_in.confidence_reporter.casual_name
                      - confidence = latest_check_in.confidence_percentage
                      - calc_date = goal.calculated_target_date
                      = "#{reporter_name}; #{confidence}%"
                      - if calc_date.present?
                        = " this will be hit by #{calc_date.strftime('%b %d, %Y')}"
                    - else
                      %span.text-muted= no_confidence_check_yet_label
                  %td
                    - if needs_check_in
                      %span.badge.bg-warning.text-dark= new_confidence_check_needed_label
                    - elsif latest_check_in
                      %span.badge.bg-success Up to date
                    - else
                      %span.badge.bg-secondary= no_confidence_check_yet_label
      - else
        %p.text-muted.mb-3 No active goals found.
      
      .row.g-2.mt-3
        .col-md-4.col-12
          = link_to organization_goals_path(organization,
                    owner_id: "CompanyTeammate_#{@teammate.id}",
                    view: 'hierarchical-collapsible',
                    return_url: about_me_organization_company_teammate_path(organization, @teammate),
                    return_text: "Back to About Me"),
                  class: "btn btn-outline-info w-100" do
            %i.bi.bi-box-arrow-up-right.me-2
            = "Go review your #{pluralize(all_goals_count, 'goal')} (draft + active)"
        .col-md-4.col-12
          = link_to organization_goals_path(organization,
                    owner_id: "CompanyTeammate_#{@teammate.id}",
                    status: 'active',
                    view: 'hierarchical-collapsible',
                    return_url: about_me_organization_company_teammate_path(organization, @teammate),
                    return_text: "Back to About Me"),
                  class: "btn btn-outline-success w-100" do
            %i.bi.bi-box-arrow-up-right.me-2
            = add_confidence_checks_on_active_goals_label(count: active_goals_count)
        .col-md-4.col-12
          = link_to organization_goals_path(organization,
                    owner_id: "CompanyTeammate_#{@teammate.id}",
                    status: 'draft',
                    view: 'hierarchical-collapsible',
                    return_url: about_me_organization_company_teammate_path(organization, @teammate),
                    return_text: "Back to About Me"),
                  class: "btn btn-outline-secondary w-100" do
            %i.bi.bi-box-arrow-up-right.me-2
            = "Go review your #{pluralize(@draft_goals_count, 'draft goal')}"

