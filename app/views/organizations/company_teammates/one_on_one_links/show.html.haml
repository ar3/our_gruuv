- content_for :title, teammate_context_page_title(@selected_teammate, "1:1 Hub")

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups,
               path_for_teammate: ->(tm) { organization_company_teammate_one_on_one_link_path(organization, teammate_route_param(tm)) },
               switch_aria_label: "Switch teammate for 1:1 Hub"
      %span= " - 1:1 Hub"

- content_for :header_action do
  = render 'people/view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Teammates", url: organization_employees_path(organization) }, { label: "1:1 Hub", url: nil }])

= render "hub_tabs", one_thing_active: true, detailed_active: false, work_to_meet_summary: @work_to_meet_summary

.container-fluid
  .card.border-primary
    .card-header.bg-primary.text-white
      %h2.mb-0
        %i.bi.bi-house.me-2
        The One Thing
    .card-body
      = render "priority_carousel", priority_carousel: @priority_carousel

      %p.mb-2
        %a.d-flex.align-items-center.justify-content-between.text-decoration-none.p-3.border.rounded.bg-light.text-body{"data-bs-toggle" => "collapse", href: "#oneThingPriorityAlgorithm", role: "button", "aria-expanded" => "false", "aria-controls" => "oneThingPriorityAlgorithm"}
          %span.fw-semibold
            %i.bi.bi-diagram-3.me-2
            How we choose the one thing
          %i.bi.bi-chevron-down.text-muted
      .collapse#oneThingPriorityAlgorithm
        .border.border-top-0.rounded-bottom.p-3.bg-white
          = render "one_thing_priority_algorithm"
          .d-flex.justify-content-end.mt-3
            %span.badge.rounded-pill.bg-info-subtle.text-info-emphasis.border{"data-status-popover" => "true", "data-bs-trigger" => "hover", "data-bs-placement" => "top", "data-bs-html" => "true", "data-bs-content" => one_thing_tie_breaks_popover_content, role: "note", style: "cursor: help;"}
              %i.bi.bi-info-circle.me-1{"aria-hidden" => "true"}
              How do we break ties?

  .mt-3
    = link_to "More detailed 1:1 hub", detailed_organization_company_teammate_one_on_one_link_path(organization, teammate_route_param(@teammate))

:javascript
  (function() {
    var oneThingCarouselEl = document.getElementById('oneThingPriorityCarousel');
    var oneThingCarouselCurrent = document.getElementById('oneThingPriorityCurrentIndicator');
    if (!oneThingCarouselEl || !oneThingCarouselCurrent) return;

    var oneThingTotal = parseInt(oneThingCarouselCurrent.getAttribute('data-total-priorities'), 10) || 12;
    var setOneThingCurrent = function(toIndex) {
      var oneBased = (toIndex || 0) + 1;
      oneThingCarouselCurrent.textContent = 'Viewing priority ' + oneBased + ' of ' + oneThingTotal;
    };

    oneThingCarouselEl.addEventListener('slid.bs.carousel', function(event) {
      setOneThingCurrent(event.to);
    });

    var activeDot = oneThingCarouselEl.querySelector('.carousel-indicators .active');
    var initialIndex = activeDot ? parseInt(activeDot.getAttribute('data-bs-slide-to'), 10) : 0;
    setOneThingCurrent(isNaN(initialIndex) ? 0 : initialIndex);
  })();
