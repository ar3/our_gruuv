- content_for :title, "About #{@selected_teammate.person.casual_name}"

- content_for :header do
  .d-flex.align-items-center.flex-wrap.gap-2
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      %span.fs-1.fw-medium About
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups,
               path_for_teammate: ->(tm) { about_me_organization_company_teammate_path(organization, tm) },
               switch_aria_label: "Switch teammate for About Me"

- content_for :header_action do
  = render 'people/view_switcher'

-# - content_for :go_back_link do
-#   = link_to organization_company_teammate_path(organization, @teammate), class: "go-back-link" do
-#     %i.bi.bi-arrow-left.me-2
-#     Back to Profile

-# Onboarding Spotlight (only shown when viewing own page and no observations/goals yet)
- if @show_onboarding_spotlight
  = render partial: 'organizations/company_teammates/about_me/onboarding_spotlight'

-# Aspirational Values Check-In Section (Read-Only)
= render partial: 'organizations/company_teammates/about_me/aspirations_check_in_section'

-# Assignments/Outcomes Check-In Section (Read-Only)
= render partial: 'organizations/company_teammates/about_me/assignments_check_in_section'

-# Position/Overall Check-In Section (Read-Only)
= render partial: 'organizations/company_teammates/about_me/position_check_in_section'

-# Active Goals Section
= render partial: 'organizations/company_teammates/about_me/goals_section'

-# Prompts/Reflections Section
= render partial: 'organizations/company_teammates/about_me/prompts_section'

-# Stories Section
= render partial: 'organizations/company_teammates/about_me/stories_section'

-# 1:1 Area Section
= render partial: 'organizations/company_teammates/about_me/one_on_one_section'

-# Abilities/Skills/Knowledge Section (Read-Only)
= render partial: 'organizations/company_teammates/about_me/abilities_section'

