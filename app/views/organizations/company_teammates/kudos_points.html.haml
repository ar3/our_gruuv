- kudos_heading = company_label_plural('kudos_point', 'Kudos Point')
- kudos_switch_params = { return_url: params[:return_url], return_text: params[:return_text] }.compact
- content_for :title, teammate_context_page_title(@selected_teammate, kudos_heading)

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups,
               path_for_teammate: ->(tm) { kudos_points_organization_company_teammate_path(organization, tm, **kudos_switch_params) },
               switch_aria_label: "Switch teammate for #{kudos_heading}"
      %span= " - #{kudos_heading}"

- content_for :header_action do
  = render 'people/view_switcher'

- content_for :go_back_link do
  - if @kudos_return_url.present? && @kudos_return_text.present?
    = nav_return_back(url: @kudos_return_url, text: @kudos_return_text)
  - else
    = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Profile", url: organization_company_teammate_path(organization, @selected_teammate) }, { label: kudos_heading, url: nil }])

.row.mb-4
  .col-md-6.mb-3.mb-md-0
    .card.h-100
      .card-body.text-center
        %h2.display-6.text-warning.mb-0= @ledger.points_to_give
        %p.lead.text-muted.mb-0= "#{company_label_plural('kudos_point', 'Kudos Point')} to Give"

  .col-md-6
    .card.h-100
      .card-body.text-center
        %h2.display-6.text-success.mb-0= @ledger.points_to_spend
        %p.lead.text-muted.mb-0= "#{company_label_plural('kudos_point', 'Kudos Point')} to Redeem"

.card
  .card-header
    %h5.mb-0
      %i.bi.bi-clock-history.me-2
      Transaction History

  .card-body
    - if @transactions.any?
      .table-responsive
        %table.table.table-hover.mb-0
          %thead
            %tr
              %th Date
              %th Type
              %th Description
              %th.text-end To Give
              %th.text-end To Spend
          %tbody
            - @transactions.each do |transaction|
              %tr
                %td
                  = transaction.created_at.strftime("%b %d, %Y")
                  %br
                  %small.text-muted= transaction.created_at.strftime("%I:%M %p")
                %td
                  %span.badge.bg-secondary= transaction.transaction_type_display
                %td= kudos_transaction_description_link(transaction)
                %td.text-end{class: kudos_delta_class(transaction.points_to_give_delta)}
                  = kudos_format_delta(transaction.points_to_give_delta)
                %td.text-end{class: kudos_delta_class(transaction.points_to_spend_delta)}
                  = kudos_format_delta(transaction.points_to_spend_delta)

      - if @pagy.pages > 1
        .mt-3
          == pagy_nav(@pagy)
    - else
      .text-center.py-4
        %i.bi.bi-inbox.fs-1.text-muted
        %p.text-muted.mt-2 No transactions yet.
        %p.small.text-muted= "#{company_label_plural('kudos_point', 'Kudos Point')} activity for this teammate will appear here."
