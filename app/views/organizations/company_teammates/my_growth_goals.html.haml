- content_for :title, "#{@selected_teammate.person.casual_name.strip}'s Growth"

- content_for :head do
  %script{ src: "https://cdnjs.cloudflare.com/ajax/libs/mermaid/11.12.0/mermaid.min.js", "data-turbo-track": "reload" }

- content_for :header do
  = render 'organizations/company_teammates/my_growth/header',
    path_for_teammate: ->(tm) { my_growth_goals_organization_company_teammate_path(organization, tm, timeframe: params[:timeframe]) },
    intent_text: "Visualize goal relationships and weekly momentum for goals this teammate owns."

- content_for :header_action do
  = render 'people/view_switcher'

= render 'organizations/company_teammates/my_growth/nav'

.alert.alert-info
  %p.mb-0
    There are four ways to grow: new experiences, gaining skills/knowledge/abilities, goal attainment, and position/title changes. This is the third of the four. 
    %span.fw-bold.fs-5 Grow by Goals.
    Setting goals — personal, professional, dream goals — these are an incredible way to track your progress to where you are wanting to go. Growth accountability!

- my_growth_goals_casual = @teammate.person.casual_name.presence || @teammate.person.display_name
- my_growth_goals_scope = Goal.where(company: organization, owner: @teammate).incomplete_unarchived
- my_growth_active_goals_count = my_growth_goals_scope.where.not(started_at: nil).count
- my_growth_draft_goals_count = my_growth_goals_scope.where(started_at: nil).count
- my_growth_all_goals_count = my_growth_active_goals_count + my_growth_draft_goals_count
.row.mb-4
  .col-md-4.col-12.mb-2.mb-md-0
    = link_to organization_goals_path(organization,
              owner_id: "CompanyTeammate_#{@teammate.id}",
              view: 'hierarchical-collapsible',
              return_url: my_growth_goals_organization_company_teammate_path(organization, @teammate, timeframe: params[:timeframe]),
              return_text: "Back to Grow by Goals"),
            class: "btn btn-outline-info w-100" do
      %i.bi.bi-box-arrow-up-right.me-2
      = "Go review #{my_growth_goals_casual}'s #{pluralize(my_growth_all_goals_count, 'goal')} (draft + active)"
  .col-md-4.col-12.mb-2.mb-md-0
    = link_to organization_goals_path(organization,
              owner_id: "CompanyTeammate_#{@teammate.id}",
              status: 'active',
              view: 'hierarchical-collapsible',
              return_url: my_growth_goals_organization_company_teammate_path(organization, @teammate, timeframe: params[:timeframe]),
              return_text: "Back to Grow by Goals"),
            class: "btn btn-outline-success w-100" do
      %i.bi.bi-box-arrow-up-right.me-2
      = go_add_confidence_checks_on_goals_label(name: my_growth_goals_casual, count: my_growth_active_goals_count)
  .col-md-4.col-12
    = link_to organization_goals_path(organization,
              owner_id: "CompanyTeammate_#{@teammate.id}",
              status: 'draft',
              view: 'hierarchical-collapsible',
              return_url: my_growth_goals_organization_company_teammate_path(organization, @teammate, timeframe: params[:timeframe]),
              return_text: "Back to Grow by Goals"),
            class: "btn btn-outline-secondary w-100" do
      %i.bi.bi-box-arrow-up-right.me-2
      = "Go review #{my_growth_goals_casual}'s #{pluralize(my_growth_draft_goals_count, 'draft goal')}"

.mb-4
  .btn-group{role: "group"}
    = link_to "Last 90 days", my_growth_goals_organization_company_teammate_path(organization, @teammate, timeframe: '90_days'), class: "btn #{@timeframe == :'90_days' ? 'btn-primary' : 'btn-outline-primary'}"
    = link_to "Last Year", my_growth_goals_organization_company_teammate_path(organization, @teammate, timeframe: 'year'), class: "btn #{@timeframe == :year ? 'btn-primary' : 'btn-outline-primary'}"
    = link_to "All-Time", my_growth_goals_organization_company_teammate_path(organization, @teammate, timeframe: 'all_time'), class: "btn #{@timeframe == :all_time ? 'btn-primary' : 'btn-outline-primary'}"

= render 'shared/goals_weekly_charts',
  chart_title_period: @chart_title_period,
  goals_for_network_graph: @goals_for_network_graph,
  goal_links_for_network_graph: @goal_links_for_network_graph,
  organization: organization,
  goals_chart_data: @goals_chart_data,
  first_chart_dom_id: 'my-growth-goals-by-week-chart',
  second_chart_dom_id: 'my-growth-goals-by-week-chart-hidden',
  second_card_heading: '',
  second_y_axis_title: 'Number of goals',
  second_highcharts_title: '',
  hide_second_chart: true,
  wrap_class: 'container-fluid px-0'
