- content_for :title, teammate_context_page_title(@selected_teammate, "Check-In Statuses")

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups
      %span= " - Check-In Statuses"

- content_for :header_action do
  = render "people/view_switcher"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: clarity_hub_label, url: hub_organization_company_teammate_check_ins_path(organization, @teammate) }, { label: "Check-In Statuses", url: nil }])

- employee_name = @teammate.person.casual_name
- manager_name = @teammate.current_manager&.casual_name.presence || 'Manager'

.row.g-3.mb-3
  .col-12.col-lg-6
    .alert.alert-info.mb-0
      %i.bi.bi-info-circle.me-2
      Check-in on any single assignment, value, or position one at a time by clicking on the name listed below
  .col-12.col-lg-6.d-flex.flex-column.justify-content-center
    = link_to organization_company_teammate_check_ins_path(organization, @teammate), class: "btn btn-outline-primary w-100" do
      Go to the Bulk Check-in page
    %small.text-muted.mt-2
      On that page you can check-in on just one item or all of them at once

= render 'shared/section_header',
         title: 'Aspirational Values',
         icon: 'bi-star',
         description: 'Compare latest reviewed and latest completion by each side'

.table-responsive
  %table.table.table-striped
    %thead
      %tr
        %th Aspiration
        %th Last Reviewed
        %th Last Check-In by #{employee_name}
        %th Last Check-In by #{manager_name}
    %tbody
      - @aspiration_rows.each do |row|
        - history = @aspiration_histories[row[:aspiration_id]]
        - fin = history[:latest_finalized]
        - opn = history[:open_check_in]
        %tr
          %td
            = link_to row[:aspiration].name, organization_teammate_aspiration_path(organization, @teammate, row[:aspiration]), class: 'text-decoration-none'
            %div.mt-1
              = render 'shared/last_finalized_pill', latest_finalized: fin, popover_content: last_finalized_check_in_popover_content(fin, employee_name, :aspiration)
          %td
            - if fin.present?
              .small{style: "white-space: pre-line;"}= aspiration_review_most_recent_last_reviewed_line(fin, employee_name)
            - elsif !opn&.ready_for_finalization?
              %span.text-muted No completed check-in yet.
            = render 'review_most_recent_joint_review', open_check_in: opn, employee_name: employee_name, manager_name: manager_name, organization: organization, teammate: @teammate
          %td
            = render 'review_most_recent_aspiration_side_column', finalized_check_in: fin, open_check_in: opn, employee_name: employee_name, manager_name: manager_name, side: :employee
          %td
            = render 'review_most_recent_aspiration_side_column', finalized_check_in: fin, open_check_in: opn, employee_name: employee_name, manager_name: manager_name, side: :manager

= render 'shared/section_header',
         title: 'Assignments/Outcomes',
         icon: 'bi-clipboard-check',
         description: 'Compare latest reviewed and latest completion by each side'

.table-responsive
  %table.table.table-striped
    %thead
      %tr
        %th Assignment
        %th Last Reviewed
        %th Last Check-In by #{employee_name}
        %th Last Check-In by #{manager_name}
    %tbody
      - @assignment_rows.each do |row|
        - history = @assignment_histories[row[:assignment_id]]
        - fin = history[:latest_finalized]
        - opn = history[:open_check_in]
        %tr
          %td
            = link_to row[:assignment].title, organization_teammate_assignment_path(organization, @teammate, row[:assignment]), class: 'text-decoration-none'
            %div.mt-1
              = render 'shared/last_finalized_pill', latest_finalized: fin, popover_content: last_finalized_check_in_popover_content(fin, employee_name, :assignment)
            - if row[:assignment].archived?
              %div.mt-1
                %span.badge.bg-danger Archived
            - elsif row[:assignment_tenure]&.active?
              %div.mt-1
                %span.badge.bg-success
                  Active Assignment - #{row[:assignment_tenure].anticipated_energy_percentage}%
          %td
            - if fin.present?
              .small{style: "white-space: pre-line;"}= assignment_review_most_recent_last_reviewed_line(fin, employee_name)
            - elsif !opn&.ready_for_finalization?
              %span.text-muted No completed check-in yet.
            = render 'review_most_recent_joint_review', open_check_in: opn, employee_name: employee_name, manager_name: manager_name, organization: organization, teammate: @teammate
          %td
            = render 'review_most_recent_assignment_side_column', finalized_check_in: fin, open_check_in: opn, employee_name: employee_name, manager_name: manager_name, side: :employee
          %td
            = render 'review_most_recent_assignment_side_column', finalized_check_in: fin, open_check_in: opn, employee_name: employee_name, manager_name: manager_name, side: :manager

= render 'shared/section_header',
         title: 'Position/Overall',
         icon: 'bi-briefcase',
         description: 'Compare latest reviewed and latest completion by each side'

- if @position_check_in.present?
  - ph = @position_history
  - fin = ph[:latest_finalized]
  - opn = ph[:open_check_in]
  .table-responsive
    %table.table.table-striped
      %thead
        %tr
          %th Position
          %th Last Reviewed
          %th Last Check-In by #{employee_name}
          %th Last Check-In by #{manager_name}
      %tbody
        %tr
          %td
            = link_to @position_check_in.employment_tenure.position.display_name, position_check_in_organization_teammate_path(organization, @teammate), class: 'text-decoration-none'
            %div.mt-1
              = render 'shared/last_finalized_pill', latest_finalized: fin, popover_content: last_finalized_check_in_popover_content(fin, employee_name, :position)
          %td
            - if fin.present?
              .small{style: "white-space: pre-line;"}= position_review_most_recent_last_reviewed_line(fin, employee_name)
            - elsif !opn&.ready_for_finalization?
              %span.text-muted No completed check-in yet.
            = render 'review_most_recent_joint_review', open_check_in: opn, employee_name: employee_name, manager_name: manager_name, organization: organization, teammate: @teammate
          %td
            = render 'review_most_recent_position_side_column', finalized_check_in: fin, open_check_in: opn, employee_name: employee_name, manager_name: manager_name, side: :employee
          %td
            = render 'review_most_recent_position_side_column', finalized_check_in: fin, open_check_in: opn, employee_name: employee_name, manager_name: manager_name, side: :manager
- else
  .alert.alert-info
    %i.bi.bi-info-circle.me-2
    No position available for this teammate.
