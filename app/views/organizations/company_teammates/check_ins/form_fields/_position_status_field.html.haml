- status_role = local_assigns[:view_mode] == :manager ? :manager : :employee
- position_latest_finalized = local_assigns[:latest_finalized].presence || PositionCheckIn.latest_finalized_for(check_in.teammate)
- needs_attention = single_item_check_in_make_changes_needs_attention?(check_in, position_latest_finalized, status_role)
- make_changes_btn_class = needs_attention ? 'btn btn-outline-warning' : 'btn btn-outline-secondary'
- make_changes_label = needs_attention ? 'Not Ready' : 'Make Changes'
.btn-group-vertical{role: "group", "aria-label": "Status selection"}
  = form.radio_button :status, 'draft',
                      checked: (check_in.status == 'draft' || check_in.status.nil?),
                      class: 'btn-check',
                      id: "position_status_draft_#{check_in.id}"
  = form.label :status_draft, make_changes_label, class: make_changes_btn_class, for: "position_status_draft_#{check_in.id}"
  = form.radio_button :status, 'complete',
                      checked: check_in.status == 'complete',
                      class: 'btn-check',
                      id: "position_status_complete_#{check_in.id}"
  = form.label :status_complete, 'Ready', class: 'btn btn-outline-primary', for: "position_status_complete_#{check_in.id}"





