- content_for :title, teammate_context_page_title(@selected_teammate, @up_next_page_title)
- up_next_page_help_id = 'upNextPageHelp'

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups,
               path_for_teammate: ->(tm) { up_next_organization_company_teammate_check_ins_path(organization, tm) },
               switch_aria_label: switch_teammate_for_clarity_hub_label
      %span= " - #{@up_next_page_title}"
      = render 'shared/page_help/header_info_button',
               collapse_id: up_next_page_help_id,
               tooltip: 'How 1-by-1 check-in queues are ordered for employee and manager. Click for details.'

- content_for :header_action do
  = render "people/view_switcher"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: clarity_hub_label, url: hub_organization_company_teammate_check_ins_path(organization, @teammate) }, { label: @up_next_page_title, url: nil }])

.collapse.mb-4{id: up_next_page_help_id}
  = render 'organizations/company_teammates/check_ins/up_next_page_help',
           organization: organization,
           teammate: @teammate,
           employee_name: @employee_name,
           manager_name: @manager_name

%p.text-muted.mb-3
  Two live lists sorted by Gruuv Health urgency—one from #{@employee_name}'s perspective, one from #{@manager_name}'s.

%p.text-muted.small.mb-4
  - refreshed_at_label = @engagement_health_computed_at ? format_time_in_user_timezone(@engagement_health_computed_at) : "not yet computed"
  If something doesn't look right, first
  = link_to "click here to refresh",
    refresh_engagement_health_organization_company_teammate_check_ins_path(organization, @teammate),
    class: "text-muted text-decoration-underline",
    data: { turbo_method: :post }
  (last refreshed at: #{refreshed_at_label})

= render "organizations/company_teammates/check_ins/up_next_actions_spotlight",
         actions_needed: @up_next_actions_needed,
         actions_total: @up_next_actions_total,
         label: "Overall clarity actions"

.row.g-4
  .col-12.col-lg-6
    .card.h-100
      .card-header
        %h5.mb-2= "#{@employee_name} perspective"
        = render "organizations/company_teammates/check_ins/up_next_actions_spotlight",
                 actions_needed: @employee_up_next_actions_needed,
                 actions_total: @employee_up_next_actions_total,
                 compact: true
      .card-body
        = render "organizations/company_teammates/check_ins/up_next_perspective_list",
                 items: @employee_up_next_items,
                 employee_name: @employee_name,
                 manager_name: @manager_name,
                 hidden_list_id: "upNextEmployeeHiddenItems"

  .col-12.col-lg-6
    .card.h-100
      .card-header
        %h5.mb-2= "#{@manager_name} perspective"
        = render "organizations/company_teammates/check_ins/up_next_actions_spotlight",
                 actions_needed: @manager_up_next_actions_needed,
                 actions_total: @manager_up_next_actions_total,
                 compact: true
      .card-body
        = render "organizations/company_teammates/check_ins/up_next_perspective_list",
                 items: @manager_up_next_items,
                 employee_name: @employee_name,
                 manager_name: @manager_name,
                 hidden_list_id: "upNextManagerHiddenItems"

.row.mt-4
  .col-12.col-sm-10.offset-sm-1
    = link_to assignment_selection_organization_company_teammate_path(organization, @teammate),
              class: "btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1 text-muted text-start w-100 w-sm-auto" do
      %span Don't see an Assignment that you are ready to start / do a check-in on?
      %i.bi.bi-box-arrow-up-right.flex-shrink-0{aria: {hidden: true}}
