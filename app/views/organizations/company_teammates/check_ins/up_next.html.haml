- content_for :title, teammate_context_page_title(@selected_teammate, @up_next_page_title)

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      = render "shared/teammate_context/title_dropdown",
               organization: organization,
               selected_teammate: @selected_teammate,
               viewable_teammate_groups: @viewable_teammate_groups,
               path_for_teammate: ->(tm) { up_next_organization_company_teammate_check_ins_path(organization, tm) },
               switch_aria_label: switch_teammate_for_clarity_hub_label
      %span= " - #{@up_next_page_title}"
    %button.btn.btn-outline-info.btn-sm.rounded-circle.p-0.d-inline-flex.align-items-center.justify-content-center{
      type: "button",
      style: "width: 28px; height: 28px;",
      "data-bs-toggle" => "collapse",
      "data-bs-target" => "#up-next-help",
      "aria-expanded" => "false",
      "aria-controls" => "up-next-help",
      title: "How this ordering works. Click for details."
    }
      %i.bi.bi-info-lg

- content_for :header_action do
  = render "people/view_switcher"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: clarity_hub_label, url: hub_organization_company_teammate_check_ins_path(organization, @teammate) }, { label: @up_next_page_title, url: nil }])

#up-next-help.alert.alert-info.collapse.mb-3{ role: "region", "aria-label" => "How up-next ordering works" }
  %p.mb-2
    The goal of this page is to explain why each 1-by-1 check-in appears where it does in the queue for each perspective.
  %p.mb-2
    Example: an item where your side has never been completed ranks above one you completed recently, because this queue is based on your side's completion timing.
  %ul.mb-0
    %li First, items where your side is not completed yet (never completed on this open check-in).
    %li Then, items where your side is completed, ordered oldest completion to newest.
    %li Ties break by type (aspiration, assignment, position), then alphabetical name.

%p.text-muted.mb-3
  Two live lists of 1-by-1 check-ins sorted by urgency: one from the employee perspective, one from the manager perspective.

.row.g-4
  .col-12.col-lg-6
    .card.h-100
      .card-header
        %h5.mb-0= "#{@employee_name} perspective"
      .card-body
        %ol.ps-3.mb-0
          - @employee_up_next_items.each do |row|
            %li.mb-3
              = link_to "#{row[:rank]}. #{row.dig(:item, :name)}", row[:url], class: "fw-semibold text-decoration-none"
              %ul.mb-0
                %li= row[:finalized_line]
                %li= row[:current_open_line]
                %li= row[:therefore_line]
                %li= row[:required_line]

  .col-12.col-lg-6
    .card.h-100
      .card-header
        %h5.mb-0= "#{@manager_name} perspective"
      .card-body
        %ol.ps-3.mb-0
          - @manager_up_next_items.each do |row|
            %li.mb-3
              = link_to "#{row[:rank]}. #{row.dig(:item, :name)}", row[:url], class: "fw-semibold text-decoration-none"
              %ul.mb-0
                %li= row[:finalized_line]
                %li= row[:current_open_line]
                %li= row[:therefore_line]
                %li= row[:required_line]
