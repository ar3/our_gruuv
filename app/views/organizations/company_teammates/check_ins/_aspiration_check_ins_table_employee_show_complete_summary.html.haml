-# Aspiration Check-Ins Table View - Employee Show Complete Summary
%td{style: "display: none;"}
  = form.hidden_field :aspiration_id, value: check_in.aspiration_id
%td
  = aspiration_rating_display(check_in.employee_rating)
%td
  = simple_format(check_in.employee_private_notes)
%td
  - other_mode = check_in.other_participant_display_mode(:employee)
  - partial_name = "aspiration_check_ins_table_employee_#{other_mode}"
  = render partial_name, check_in: check_in
%td
  -# Hidden fields to preserve existing values when form is submitted
  = form.hidden_field :employee_rating, value: check_in.employee_rating
  = form.hidden_field :employee_private_notes, value: check_in.employee_private_notes
  = form.hidden_field :aspiration_id, value: check_in.aspiration_id
  
  - needs_attention = single_item_check_in_make_changes_needs_attention?(check_in, local_assigns[:latest_finalized], :employee)
  - make_changes_btn_class = needs_attention ? 'btn btn-outline-warning' : 'btn btn-outline-secondary'
  - make_changes_label = needs_attention ? 'Not Ready' : 'Make Changes'
  .btn-group-vertical{role: "group", "aria-label": "Status selection"}
    = form.radio_button :status, 'draft', checked: !check_in.employee_completed?, class: 'btn-check', id: "aspiration_table_employee_status_draft_#{check_in.id}"
    = form.label :status_draft, make_changes_label, class: make_changes_btn_class, for: "aspiration_table_employee_status_draft_#{check_in.id}"
    = form.radio_button :status, 'complete', checked: check_in.employee_completed?, class: 'btn-check', id: "aspiration_table_employee_status_complete_#{check_in.id}"
    = form.label :status_complete, 'Ready for Manager', class: 'btn btn-outline-primary', for: "aspiration_table_employee_status_complete_#{check_in.id}"

  .small.text-muted.mt-1
    Select "Make Changes" to edit your assessment and notes

