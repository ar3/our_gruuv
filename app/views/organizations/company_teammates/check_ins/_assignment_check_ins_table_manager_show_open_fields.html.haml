-# Assignment Check-Ins Table View - Manager Show Open Fields
- hide_fresh_fields = hide_fresh_open_check_in_fields?(check_in, local_assigns[:latest_finalized], view_mode: :manager)
- toggle_target = ".fresh-assignment-toggle-#{check_in.id}"
%td{style: "display: none;"}
  = render 'organizations/company_teammates/check_ins/form_fields/assignment_id_field', form: form, check_in: check_in
%td
  - if hide_fresh_fields
    %div{class: "collapse show fresh-assignment-toggle-#{check_in.id}"}
      .alert.alert-success.py-2.mb-0.small
        %i.bi.bi-check-circle-fill{style: "font-size: 1.15rem;"}
    %div{class: "collapse fresh-assignment-toggle-#{check_in.id}"}
      = render 'organizations/company_teammates/check_ins/form_fields/assignment_manager_rating_field', form: form, check_in: check_in, css_class: 'form-control form-control-sm'
  - else
    = render 'organizations/company_teammates/check_ins/form_fields/assignment_manager_rating_field', form: form, check_in: check_in, css_class: 'form-control form-control-sm'
%td
  - if hide_fresh_fields
    %div{class: "collapse show fresh-assignment-toggle-#{check_in.id}"}
      .alert.alert-success.py-2.mb-0.small
        %i.bi.bi-check-circle-fill{style: "font-size: 1.15rem;"}
    %div{class: "collapse fresh-assignment-toggle-#{check_in.id}"}
      = render 'organizations/company_teammates/check_ins/form_fields/assignment_manager_private_notes_field', form: form, main_form: main_form, check_in: check_in, css_class: 'form-control form-control-sm'
  - else
    = render 'organizations/company_teammates/check_ins/form_fields/assignment_manager_private_notes_field', form: form, main_form: main_form, check_in: check_in, css_class: 'form-control form-control-sm'
%td
  - if hide_fresh_fields
    %div{class: "collapse show fresh-assignment-toggle-#{check_in.id}"}
      .alert.alert-success.py-2.mb-0.small
        %i.bi.bi-check-circle-fill{style: "font-size: 1.15rem;"}
    %div{class: "collapse fresh-assignment-toggle-#{check_in.id}"}
      - other_mode = check_in.other_participant_display_mode(:manager)
      - partial_name = "assignment_check_ins_table_manager_#{other_mode}"
      = render partial_name, check_in: check_in
  - else
    - other_mode = check_in.other_participant_display_mode(:manager)
    - partial_name = "assignment_check_ins_table_manager_#{other_mode}"
    = render partial_name, check_in: check_in
%td
  - if hide_fresh_fields
    %div{class: "collapse show fresh-assignment-toggle-#{check_in.id}"}
      .alert.alert-success.py-2.mb-0.small
        %a{href: "#", "data-bs-toggle" => "collapse", "data-bs-target" => toggle_target, "aria-expanded" => "false"} I want to check-in early
        .mt-1
          %span ...or add a
          = main_form.submit "win/challenge",
                             class: "btn btn-link text-muted text-decoration-none small p-0 border-0 bg-transparent align-baseline",
                             name: "save_and_add_quick_note_assignment_#{check_in.assignment.id}"
    %div{class: "collapse fresh-assignment-toggle-#{check_in.id}"}
      = render 'organizations/company_teammates/check_ins/form_fields/assignment_status_field', form: form, check_in: check_in, latest_finalized: local_assigns[:latest_finalized], view_mode: local_assigns[:view_mode]
  - else
    = render 'organizations/company_teammates/check_ins/form_fields/assignment_status_field', form: form, check_in: check_in, latest_finalized: local_assigns[:latest_finalized], view_mode: local_assigns[:view_mode]

