- content_for :title, teammate_context_page_title(@selected_teammate, bulk_clarity_check_in_label)
- bulk_check_in_page_help_id = 'bulkClarityCheckInPageHelp'

- content_for :header do
  .d-flex.flex-column.gap-1
    .d-flex.align-items-center.gap-2.flex-wrap
      %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
        = render "shared/teammate_context/title_dropdown",
                 organization: organization,
                 selected_teammate: @selected_teammate,
                 viewable_teammate_groups: @viewable_teammate_groups,
                 path_for_teammate: ->(tm) { organization_company_teammate_check_ins_path(organization, tm) },
                 switch_aria_label: switch_teammate_bulk_clarity_check_ins_label
        %span= " - #{bulk_clarity_check_in_label}"
        = render 'shared/page_help/header_info_button',
                 collapse_id: bulk_check_in_page_help_id,
                 tooltip: 'Bulk clarity check-in purpose and MAAP flow. Click for details.'
    %p.text-muted.mb-0= "View Mode: #{@view_mode.to_s.titleize}"

- content_for :header_action do
  .d-flex.align-items-center.gap-2
    = render 'people/view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: clarity_hub_label, url: hub_organization_company_teammate_check_ins_path(organization, @teammate) }, { label: bulk_clarity_check_in_label, url: nil }])

.collapse.mb-4{id: bulk_check_in_page_help_id}
  = render 'organizations/company_teammates/check_ins/bulk_check_in_page_help',
           organization: organization,
           teammate: @teammate

= render 'shared/check_in_wizard_header', organization: organization, teammate: @teammate, current_step: 1

- if @check_ins_fresh_banner&.show_banner
  = render 'organizations/company_teammates/check_ins/all_fresh_banner',
           banner: @check_ins_fresh_banner,
           teammate: @teammate

-# Authorization Debug Section
- if params[:debug] == 'true' && @debug_data
  .alert.alert-secondary.mt-3
    %h5.mb-3
      %i.bi.bi-bug.me-2
      Authorization Debug
    .row
      .col-md-6
        %strong Logged-in Teammate:
        %br
        - if current_company_teammate
          - teammate = current_company_teammate
          ID: #{teammate.id}
          %br
          Person: #{teammate.person.display_name} (ID: #{teammate.person.id})
          %br
          Organization: #{teammate.organization.name} (ID: #{teammate.organization.id})
          %br
          - if teammate.person.og_admin?
            %span.badge.bg-danger Admin
        - else
          %span.text-muted Not logged in
      .col-md-6
        %strong Policy Information:
        %br
        Policy Class: #{@debug_data[:policy_class]}
        %br
        Policy Record: #{@debug_data[:policy_record].display_name} (ID: #{@debug_data[:policy_record].id})
        %br
        Policy Action: #{@debug_data[:policy_action]}
    %hr
    %strong Policy Conditions Breakdown (audit? method):
    %br
    %small.text-muted Each condition is checked in order. The first true condition grants access.
    .mt-2
      - conditions = @debug_data[:conditions]
      -# Condition 1: admin_bypass?
      - admin_bypass = conditions[:admin_bypass]
      .mb-2
        - if admin_bypass[:result]
          %span.text-success
            %i.bi.bi-check-circle-fill.me-1
        - else
          %span.text-muted
            %i.bi.bi-circle.me-1
        %code= admin_bypass[:description]
        - if admin_bypass[:result]
          %span.text-success (PASS - Admin bypass granted)
        - else
          %span.text-muted (FAIL - #{admin_bypass[:details]})
      -# Condition 2: viewing_teammate && record
      - both_exist = conditions[:viewing_teammate_and_record]
      .mb-2
        - if both_exist[:result]
          %span.text-success
            %i.bi.bi-check-circle-fill.me-1
        - else
          %span.text-danger
            %i.bi.bi-x-circle-fill.me-1
        %code= both_exist[:description]
        - if both_exist[:result]
          %span.text-success (PASS)
        - else
          %span.text-danger (FAIL - #{both_exist[:details]})
      -# Condition 3: viewing_teammate.terminated?
      - not_terminated = conditions[:not_terminated]
      - if not_terminated[:result] != nil
        .mb-2
          - if not_terminated[:result]
            %span.text-success
              %i.bi.bi-check-circle-fill.me-1
          - else
            %span.text-danger
              %i.bi.bi-x-circle-fill.me-1
          %code= not_terminated[:description]
          - if not_terminated[:result]
            %span.text-success (PASS - #{not_terminated[:details]})
          - else
            %span.text-danger (FAIL - #{not_terminated[:details]})
      -# Condition 4: viewing_teammate.person == record
      - own_profile = conditions[:own_profile]
      - if own_profile[:result] != nil
        .mb-2
          - if own_profile[:result]
            %span.text-success
              %i.bi.bi-check-circle-fill.me-1
          - else
            %span.text-muted
              %i.bi.bi-circle.me-1
          %code= own_profile[:description]
          - if own_profile[:result]
            %span.text-success (PASS - #{own_profile[:details]})
          - else
            %span.text-muted (FAIL - #{own_profile[:details]})
      -# Condition 5: viewing_teammate.has_active_employment_tenure?
      - has_active_tenure = conditions[:has_active_employment_tenure]
      - if has_active_tenure[:result] != nil
        .mb-2
          - if has_active_tenure[:result]
            %span.text-success
              %i.bi.bi-check-circle-fill.me-1
          - else
            %span.text-danger
              %i.bi.bi-x-circle-fill.me-1
          %code= has_active_tenure[:description]
          - if has_active_tenure[:result]
            %span.text-success (PASS - #{has_active_tenure[:details]})
          - else
            %span.text-danger (FAIL - #{has_active_tenure[:details]})
      -# Condition 6: viewing_teammate.can_manage_employment?
      - can_manage = conditions[:can_manage_employment]
      - if can_manage[:result] != nil
        .mb-2
          - if can_manage[:result]
            %span.text-success
              %i.bi.bi-check-circle-fill.me-1
          - else
            %span.text-muted
              %i.bi.bi-circle.me-1
          %code= can_manage[:description]
          - if can_manage[:result]
            %span.text-success (PASS - #{can_manage[:details]})
          - else
            %span.text-muted (FAIL - #{can_manage[:details]})
      -# Condition 7: viewing_teammate.person.in_managerial_hierarchy_of?(record, viewing_teammate.organization)
      - in_hierarchy = conditions[:in_managerial_hierarchy]
      - if in_hierarchy[:result] != nil
        .mb-2
          - if in_hierarchy[:result]
            %span.text-success
              %i.bi.bi-check-circle-fill.me-1
          - else
            %span.text-muted
              %i.bi.bi-circle.me-1
          %code= in_hierarchy[:description]
          - if in_hierarchy[:result]
            %span.text-success (PASS - #{in_hierarchy[:details]})
          - else
            %span.text-muted (FAIL - #{in_hierarchy[:details]})
    %hr
    %strong Final Result:
    - final_result = @debug_data[:final_result]
    - if final_result
      %span.badge.bg-success.fs-6
        %i.bi.bi-check-circle-fill.me-1
        #{@debug_data[:policy_action]} = TRUE (Access Granted)
    - else
      %span.badge.bg-danger.fs-6
        %i.bi.bi-x-circle-fill.me-1
        #{@debug_data[:policy_action]} = FALSE (Access Denied)

.row.g-3.mb-3
  .col-12.col-lg-6
    .alert.alert-info.mb-0
      %i.bi.bi-info-circle.me-2
      = bulk_page_intro
  .col-12.col-lg-6.d-flex.flex-column.justify-content-center
    = link_to review_most_recent_organization_company_teammate_check_ins_path(organization, @teammate), class: "btn btn-outline-primary w-100" do
      = go_to_clarity_check_in_status_page_label
    %small.text-muted.mt-2
      = bulk_status_page_table_hint

= form_with url: organization_company_teammate_check_ins_path(organization, @teammate), method: :patch, scope: :check_ins, local: true,
            data: { turbo: false,
                    controller: "check-in-autosave",
                    check_in_autosave_debounce_ms_value: 2500,
                    action: "input->check-in-autosave#markDirty change->check-in-autosave#markDirty submit->check-in-autosave#handleSubmit" } do |f|
  = render "shared/check_in_autosave_status"
  -# Aspiration Section
  = render 'shared/section_header', 
           title: 'Aspirational Values', 
           icon: 'bi-star', 
           description: 'Track progress toward personal goals'

  = render 'aspiration_check_ins_table',
           aspiration_check_ins: @aspiration_check_ins,
           form: f,
           view_mode: @view_mode
  
  .row.mt-4
    .col-12
      .d-flex.gap-2
        = f.submit 'Save All & Continue Editing', name: 'save_and_continue_editing', class: 'btn btn-outline-primary btn-lg'
        = f.submit save_all_proceed_review_clarity_check_ins_label, class: 'btn btn-primary btn-lg'

  -# Assignment Section
  - employee_energy_allocation = @view_mode == :employee && @assignment_energy_allocation
  - allocation_colors_json = employee_energy_allocation ? @assignment_energy_allocation.color_by_assignment_id.to_json : nil
  - allocation_planned_json = employee_energy_allocation ? @assignment_energy_allocation.planned_by_assignment_id.to_json : nil
  - allocation_metadata_json = employee_energy_allocation ? @assignment_energy_allocation.assignment_metadata_by_id.to_json : nil
  %div#bulk-assignment-check-in-energy-section{
    class: (employee_energy_allocation ? 'bulk-assignment-check-in-energy-section' : nil),
    data: (employee_energy_allocation ? {
      controller: 'assignment-energy-allocation',
      assignment_energy_allocation_colors_value: allocation_colors_json,
      assignment_energy_allocation_planned_by_assignment_value: allocation_planned_json,
      assignment_energy_allocation_assignments_value: allocation_metadata_json
    } : {})
  }
    = render 'shared/section_header',
             title: 'Assignments/Outcomes',
             icon: 'bi-clipboard-check',
             description: 'Evaluate project contributions and energy',
             action_link: { url: assignment_selection_organization_company_teammate_path(organization, @teammate), icon: 'bi-plus-circle', text: '', title: 'Manage assignments' }

    - if employee_energy_allocation
      .assignment-energy-allocation-sticky-wrap
        = render 'organizations/company_teammates/check_ins/assignment_energy_allocation_panel_bulk',
                 summary: @assignment_energy_allocation,
                 employee_name: @teammate.person.casual_name,
                 manager_name: (@teammate.current_manager&.casual_name.presence || 'your manager')

    = render 'assignment_check_ins_table',
             assignment_check_ins: @active_assignment_check_ins,
             form: f,
             view_mode: @view_mode

    -# Recently added assignments (non-active, non-required, added within last 7 days) — outside Unique-to-You
    - if @recently_added_assignment_check_ins&.any?
      .card.mb-4.mt-4
        .card-header
          %h5.mb-0
            %i.bi.bi-clock-history.me-2
            Recently added assignments (check-in in progress)
          %p.text-muted.caption-text.mb-0 Added in the last 7 days and not yet active; kept here so you can check in on them.
        .card-body
          = render 'assignment_check_ins_table',
                   assignment_check_ins: @recently_added_assignment_check_ins,
                   form: f,
                   view_mode: @view_mode

    -# Collapsible section for Unique-to-You assignments (non-active, required or added more than 7 days ago)
    - if @non_active_assignment_check_ins&.any?
      .card.mb-4.mt-4
        .card-header
          %button.btn.btn-link.text-start.w-100.p-0.text-decoration-none{type: "button", "data-bs-toggle" => "collapse", "data-bs-target" => "#nonActiveAssignmentsSection", "aria-expanded" => "false", "aria-controls" => "nonActiveAssignmentsSection"}
            %h5.mb-0
              %i.bi.bi-chevron-down.me-2
              Check-in on "Unique-to-You" Assignments #{@teammate.person.casual_name} may be starting/started
              %p.text-muted.caption-text (assignments added more than 7 days ago, or required for position but not yet active, or ones they used to have active)
        .collapse#nonActiveAssignmentsSection
          .card-body
            = render 'assignment_check_ins_table',
                     assignment_check_ins: @non_active_assignment_check_ins,
                     form: f,
                     view_mode: @view_mode
  
  .row.mt-4
    .col-12
      .d-flex.gap-2
        = f.submit 'Save All & Continue Editing', name: 'save_and_continue_editing', class: 'btn btn-outline-primary btn-lg'
        = f.submit save_all_proceed_review_clarity_check_ins_label, class: 'btn btn-primary btn-lg'
  
  -# Position Section
  = render 'shared/section_header', 
           title: 'Position/Overall', 
           icon: 'bi-briefcase', 
           description: 'Assess role performance and growth'
  
  = render 'position_check_ins_table',
           position_check_in: @position_check_in,
           form: f,
           view_mode: @view_mode
  .row.mt-4
    .col-12
      .d-flex.gap-2
        = f.submit 'Save All & Continue Editing', name: 'save_and_continue_editing', class: 'btn btn-outline-primary btn-lg'
        = f.submit save_all_proceed_review_clarity_check_ins_label, class: 'btn btn-primary btn-lg'



  -# Abilities Section
  = render 'shared/section_header', 
           title: 'Abilities/Skills/Knowledge', 
           icon: 'bi-briefcase', 
           description: 'View abilities relevant to your role and assignments',
           collapsible: true,
           collapse_target: 'abilities-section'
  
  .collapse#abilities-section
    = render 'abilities_table',
             relevant_abilities: @relevant_abilities,
             ability_goal_counts_by_id: @ability_goal_counts_by_id,
             view_mode: @view_mode,
             person: @person,
             teammate: @teammate,
             main_form: f

