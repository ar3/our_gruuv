- casual = @selected_teammate.person.casual_name.strip
- content_for :title, "#{casual}'s True Day-to-Day"

- content_for :header do
  .d-flex.flex-column.gap-1
    .d-flex.align-items-center.flex-wrap.gap-2
      %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
        = render "shared/teammate_context/title_dropdown",
                 organization: organization,
                 selected_teammate: @selected_teammate,
                 viewable_teammate_groups: @viewable_teammate_groups,
                 path_for_teammate: ->(tm) { complete_picture_organization_company_teammate_path(organization, tm) },
                 switch_aria_label: "Switch teammate for True Day-to-Day"
        %span= "'s True Day-to-Day"
    %p.text-muted.mb-0.small= "#{casual}'s real job description"

- content_for :header_action do
  = render 'people/view_switcher'

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: @current_organization, crumbs: [{ label: "Teammates", url: organization_employees_path(@current_organization) }, { label: "True Day-to-Day", url: nil }])

/ Position + spotlight: two cards side by side
- if @current_employment&.position
  - pos = @current_employment.position
  - dept = pos.title&.department
  .row.g-4.mb-4.align-items-stretch
    .col-lg-8
      .card.h-100{ role: "region", "aria-labelledby": "position-section" }
        .card-header
          %h5.mb-0{ id: "position-section" }
            %i.bi.bi-briefcase.me-2
            Current Position
        .card-body
          %h4.mb-3
            = link_to pos.display_name, organization_position_path(@current_organization, pos), class: "text-decoration-none"
          %p
            %strong Department:
            - if dept
              = link_to dept.display_name, organization_department_path(@current_organization, dept), class: "text-decoration-none"
            - else
              %span.text-muted —
          %p
            %strong Manager:
            - mgr = @current_employment.manager_teammate
            - if mgr && policy(mgr).internal?
              = link_to mgr.person.casual_name, internal_organization_company_teammate_path(@current_organization, mgr), class: "text-decoration-none"
            - elsif mgr
              = mgr.person.casual_name
            - else
              %span.text-muted —
          .mt-3
            %h6.mb-2
              %i.bi.bi-star.me-2
              Position Level
            = render "organizations/positions/position_level_display", position: pos
          - if pos.position_summary.present?
            .mt-3
              %h6 Summary:
              %p= pos.position_summary
          - position_direct_abilities = pos.position_abilities.includes(:ability)
          - if position_direct_abilities.any?
            .mt-3
              %h6 Direct Milestone Requirements:
              %ul.mb-0
                - position_direct_abilities.each do |position_ability|
                  %li= "#{position_ability.ability.name} - Level #{position_ability.milestone_level}"
    .col-lg-4
      .card.border.h-100{ role: "region", "aria-labelledby": "position-spotlight-section" }
        .card-header.bg-light
          %h6.mb-0.text-uppercase.text-muted{ id: "position-spotlight-section" } Spotlight
        .card-body
          %p.mb-3
            %strong Next check-in:
            = link_to @complete_picture_check_ins_url, class: "text-decoration-none ms-1" do
              = @complete_picture_next_check_in_word
          %p.mb-3
            = link_to @complete_picture_my_growth_goals_url, class: "text-decoration-none" do
              %i.bi.bi-graph-up-arrow.me-1
              Growth:
              = pluralize(@complete_picture_goals_active_count, 'active goal')
              %span.text-muted
                (#{goals_health_status_copy(@complete_picture_goals_health_status)})
          %p.mb-2
            = link_to @complete_picture_seats_management_url, class: "text-decoration-none" do
              = pluralize(@complete_picture_distinct_position_count, 'total position')
            held at #{@current_organization.display_name}.
          - if @complete_picture_earliest_start_date.present?
            %p.mb-1
              %strong Earliest start day:
              = format_date_in_user_timezone(@complete_picture_earliest_start_date, format: '%b %d, %Y')
          - if @complete_picture_in_position_since_date.present?
            %p.mb-0
              %strong In this position since:
              = format_date_in_user_timezone(@complete_picture_in_position_since_date, format: '%b %d, %Y')
- else
  .card.mb-4{ role: "region", "aria-labelledby": "position-section" }
    .card-header
      %h5.mb-0{ id: "position-section" }
        %i.bi.bi-briefcase.me-2
        Current Position
    .card-body
      .alert.alert-warning.mb-0
        %h6.mb-2
          %i.bi.bi-exclamation-triangle.me-2
          No Current Position
        %p.mb-0 This person does not have an active employment tenure with a position.

/ Active Assignment Tenures Section
- if @assignment_tenures.any?
  .card.mb-4{ role: "region", "aria-labelledby": "assignments-section" }
    .card-header
      %h5.mb-0{ id: "assignments-section" }
        %i.bi.bi-list-task.me-2
        Active Assignments
        %a.text-decoration-none.ms-3{"data-bs-toggle" => "collapse", "data-bs-target" => "#assignmentsCollapse", "aria-expanded" => "true", "aria-controls" => "assignmentsCollapse"}
          %span#assignmentsExpandIcon.not-collapsed
            %i.bi.bi-chevron-up
            %small.text-muted (Hide assignments)
          %span#assignmentsCollapseText.collapsed
            %i.bi.bi-chevron-down
            %small.text-muted="(Show #{pluralize(@assignment_tenures.count, 'assignment')})"
    .card-body
      .collapse.show#assignmentsCollapse
        %p.text-muted.mb-3
          %em These are the specific assignments this person is currently working on for #{@current_organization.display_name}.
        
        - @assignment_tenures.each_with_index do |tenure, index|
          - if index > 0
            %hr.my-4
          
          .card.my-growth-experience-day-to-day-stack.mb-3.border.p-0.overflow-hidden.d-flex.flex-column
            .card-header
              .d-flex.justify-content-between.align-items-center
                .d-flex.align-items-center.flex-grow-1
                  %h6.mb-0.me-3
                    %i.bi.bi-clipboard-check.me-2
                    %a.text-decoration-none.text-body{ href: "#assignment-#{tenure.id}", role: "button", "data-bs-toggle" => "collapse", "data-bs-target" => "#assignment-#{tenure.id}", "aria-expanded" => "false", "aria-controls" => "assignment-#{tenure.id}" }
                      = tenure.assignment.title
                  
                  / Current Energy Allocation
                  - if tenure.anticipated_energy_percentage.present?
                    .me-3
                      %span.badge.bg-info.me-1= "#{tenure.anticipated_energy_percentage}%"
                      %small.text-muted= "for #{distance_of_time_in_words(tenure.started_at, Date.current)}"
                  
                  / Last finalized check-in: official rating + personal alignment (+ popover with three sentences)
                  = render 'organizations/company_teammates/assignment_latest_check_in_badges',
                    latest_finalized: @latest_finalized_assignment_check_ins_by_assignment_id[tenure.assignment_id],
                    tenure: tenure,
                    teammate: @teammate
                
                / Expand/Collapse Button
                %a.text-decoration-none{"data-bs-toggle" => "collapse", "data-bs-target" => "#assignment-#{tenure.id}", "aria-expanded" => "false", "aria-controls" => "assignment-#{tenure.id}"}
                  %span.not-collapsed{"id" => "assignmentExpandIcon-#{tenure.id}"}
                    %i.bi.bi-chevron-up
                    %small.text-muted (Hide details)
                  %span.collapsed{"id" => "assignmentCollapseText-#{tenure.id}"}
                    %i.bi.bi-chevron-down
                    %small.text-muted (Show details)
            .card-body.d-flex.flex-column.flex-grow-1
              .collapse{"id" => "assignment-#{tenure.id}"}
                .row
                  .col-md-8
                    / Assignment-Specific Information
                    %h6.mb-3 Assignment Details
                    %p
                      %strong Assignment:
                      = link_to tenure.assignment.title, organization_teammate_assignment_path(@current_organization, @teammate, tenure.assignment), class: "text-decoration-none"
                    
                    - if tenure.assignment.tagline.present?
                      %p
                        %strong Tagline:
                        = tenure.assignment.tagline
                    
                    - if tenure.assignment.required_activities.present?
                      %p
                        %strong Required Activities:
                        = tenure.assignment.required_activities
                    
                    / Assignment Outcomes
                    - outcomes = tenure.assignment.assignment_outcomes
                    - if outcomes.any?
                      .mt-3
                        %h6 Outcomes:
                        %ul.mb-0
                          - outcomes.each do |outcome|
                            %li= outcome.description
                    
                    / Assignment Abilities
                    - abilities = tenure.assignment.assignment_abilities.sort_by { |aa| aa.ability.name.downcase }
                    - if abilities.any?
                      - milestone_by_ability = @complete_picture_teammate_milestone_level_by_ability_id || {}
                      - earned_subject = @teammate.person.casual_name
                      .mt-3
                        %h6 Required abilities
                        .list-group.list-group-flush.rounded.border.overflow-hidden.shadow-sm
                          - abilities.each do |assignment_ability|
                            - ability = assignment_ability.ability
                            - required_level = assignment_ability.milestone_level
                            - earned_level = milestone_by_ability[ability.id].to_i
                            - milestone_met = earned_level >= required_level
                            = link_to organization_teammate_ability_path(@current_organization, @teammate, ability), class: "list-group-item list-group-item-action py-3 px-3" do
                              .fw-semibold.fs-6.text-body.mb-2= ability.name
                              .d-flex.flex-wrap.justify-content-between.align-items-baseline.column-gap-3.row-gap-1
                                .small
                                  %span.text-muted Required for this assignment
                                  %br
                                  %span.text-body
                                    #{milestone_level_display(required_level)} (Milestone #{required_level})
                                .small.text-end
                                  %span.text-muted
                                    #{earned_subject} has earned
                                  %br
                                  - if earned_level.positive?
                                    %span{class: milestone_met ? "text-success fw-semibold" : "text-danger fw-semibold"}
                                      #{milestone_level_display(earned_level)} (Milestone #{earned_level})
                                  - else
                                    %span.text-danger.fw-semibold None yet
                  
                  .col-md-4.border-start.border-secondary
                    .d-grid.gap-2
                      / Tenure Information
                      .mb-3
                        %h6.mb-2
                          %i.bi.bi-clock-history.me-2
                          Tenure Details
                        %p.mb-1
                          %strong Started:
                          = format_date_in_user_timezone(tenure.started_at, format: '%b %d, %Y')
                        
                        %p.mb-1
                          %strong Duration:
                          = distance_of_time_in_words(tenure.started_at, Date.current)
                        
                        - if tenure.anticipated_energy_percentage.present?
                          %p.mb-1
                            %strong Forecasted Energy:
                            = "#{tenure.anticipated_energy_percentage}%"
                        
                        / Energy Comparison
                        - position_assignment = @current_employment&.position&.position_assignments&.find_by(assignment: tenure.assignment)
                        - if position_assignment&.min_estimated_energy.present? || position_assignment&.max_estimated_energy.present?
                          %p.mb-1
                            %strong Expected Range:
                            = position_assignment.energy_range_display
                          
                          - if tenure.anticipated_energy_percentage.present?
                            - min_energy = position_assignment.min_estimated_energy || 0
                            - max_energy = position_assignment.max_estimated_energy || 100
                            - if tenure.anticipated_energy_percentage < min_energy
                              .alert.alert-warning.mt-2.p-2
                                %i.bi.bi-exclamation-triangle.me-2
                                %strong Below Expected Range
                                %br
                                %small Anticipated energy (#{tenure.anticipated_energy_percentage}%) is below the minimum expected (#{min_energy}%)
                            - elsif tenure.anticipated_energy_percentage > max_energy
                              .alert.alert-warning.mt-2.p-2
                                %i.bi.bi-exclamation-triangle.me-2
                                %strong Above Expected Range
                                %br
                                %small Anticipated energy (#{tenure.anticipated_energy_percentage}%) exceeds the maximum expected (#{max_energy}%)
                            - else
                              .alert.alert-success.mt-2.p-2
                                %i.bi.bi-check-circle.me-2
                                %strong Within Expected Range
                                %br
                                %small Anticipated energy (#{tenure.anticipated_energy_percentage}%) is within the expected range (#{min_energy}%-#{max_energy}%)
                      
                      / Check-in Information
                      - latest_check_in = @latest_finalized_assignment_check_ins_by_assignment_id[tenure.assignment_id] || AssignmentCheckIn.where(company_teammate: @teammate, assignment: tenure.assignment).recent.first
                      - if latest_check_in
                        - emp_name = @teammate.person.casual_name
                        - check_in_finalized = latest_check_in.official_check_in_completed_at.present?
                        - finalizer_name = latest_check_in.finalized_by_teammate&.person&.casual_name.presence || latest_check_in.manager_completed_by_teammate&.person&.casual_name.presence || 'their manager'
                        - mgr_name = latest_check_in.manager_completed_by_teammate&.person&.casual_name.presence || latest_check_in.finalized_by_teammate&.person&.casual_name.presence || 'their manager'
                        - off_rating = latest_check_in.official_rating
                        - off_badge_class = off_rating == 'exceeding' ? 'bg-success' : off_rating == 'meeting' ? 'bg-primary' : off_rating == 'working_to_meet' ? 'bg-warning' : 'bg-secondary'
                        .mb-3
                          %h6.mb-2
                            %i.bi.bi-calendar-check.me-2
                            Latest Check-in
                          %p.mb-1
                            %strong Date:
                            - if check_in_finalized
                              = format_date_in_user_timezone(latest_check_in.official_check_in_completed_at, format: '%b %d, %Y')
                            - else
                              = format_date_in_user_timezone(latest_check_in.check_in_started_on, format: '%b %d, %Y')
                          - if check_in_finalized
                            - if tenure.anticipated_energy_percentage.present?
                              %p.mb-2
                                #{h(emp_name)} and #{h(finalizer_name)} agreed that #{h(emp_name)} will likely spend #{tenure.anticipated_energy_percentage}% of their energy on being
                                %strong= h(tenure.assignment.title)
                                \.
                            - if off_rating.present? && latest_check_in.check_in_started_on.present?
                              %p.mb-2
                                = "#{h(emp_name)} and #{h(mgr_name)} agreed that from ".html_safe
                                %strong= format_date_in_user_timezone(latest_check_in.check_in_started_on, format: '%b %d, %Y')
                                = " to ".html_safe
                                %strong= format_date_in_user_timezone(latest_check_in.official_check_in_completed_at, format: '%b %d, %Y')
                                = ", #{h(emp_name)} was ".html_safe
                                %span.badge{class: off_badge_class}= assignment_rating_display(off_rating)
                                = " expectations.".html_safe
                                - if latest_check_in.employee_personal_alignment.present?
                                  = " #{h(emp_name)} felt ".html_safe
                                  %span.badge.bg-info.text-dark= latest_check_in.employee_personal_alignment.humanize
                                  = " about taking on ".html_safe
                                  %strong= h(tenure.assignment.title)
                                  = " in the future.".html_safe
                          - else
                            - if latest_check_in.actual_energy_percentage.present?
                              %p.mb-1
                                %strong Actual Energy:
                                = "#{latest_check_in.actual_energy_percentage}%"
                            - if latest_check_in.employee_personal_alignment.present?
                              %p.mb-1
                                %strong How they feel about this assignment:
                                %span.badge.bg-info.text-dark= latest_check_in.employee_personal_alignment.humanize
                            - if latest_check_in.manager_rating.present?
                              %p.mb-1
                                %strong Manager rating:
                                %span.badge{class: latest_check_in.manager_rating == 'exceeding' ? 'bg-success' : latest_check_in.manager_rating == 'meeting' ? 'bg-primary' : 'bg-warning'}
                                  = assignment_rating_display(latest_check_in.manager_rating)
                            - if latest_check_in.official_rating.present?
                              %p.mb-1
                                %strong Finalized rating:
                                %span.badge{class: latest_check_in.official_rating == 'exceeding' ? 'bg-success' : latest_check_in.official_rating == 'meeting' ? 'bg-primary' : 'bg-warning'}
                                  = assignment_rating_display(latest_check_in.official_rating)
                      
                      / Statistics
                      .mb-3
                        %h6.mb-2
                          %i.bi.bi-graph-up.me-2
                          Statistics
                        %p.mb-1
                          %strong Total Check-ins:
                          = AssignmentCheckIn.where(company_teammate: @teammate, assignment: tenure.assignment).count
                        
                        %p.mb-1
                          %strong Open Check-ins:
                          = AssignmentCheckIn.where(company_teammate: @teammate, assignment: tenure.assignment).open.count
                      
                      / Actions
                      = link_to organization_teammate_assignment_path(@current_organization, @teammate, tenure.assignment), class: "btn btn-outline-primary" do
                        %i.bi.bi-calendar-check.me-2
                        Assignment check-in

            - cp_footer_counts = (@complete_picture_assignment_goal_counts_by_id || {})[tenure.assignment_id] || { open_associated_goals_count: 0 }
            - cp_casual = @teammate.person.casual_name.presence || 'this teammate'
            - cp_return_url = my_growth_complete_picture_return_url(organization, @teammate)
            = render 'organizations/company_teammates/my_growth/my_growth_catalog_card_action_footer',
              organization: organization,
              teammate: @teammate,
              associable: tenure.assignment,
              casual_name: cp_casual,
              counts: cp_footer_counts,
              return_url: cp_return_url,
              return_text: 'True Day-to-Day'

        - if policy(@teammate).manager? || policy(organization).manage_employment?
          .mt-3
            = link_to assignment_tenure_check_in_bypass_organization_company_teammate_path(organization, @teammate), class: "btn btn-sm btn-outline-secondary" do
              %i.bi.bi-lightning-charge.me-1
              Assignment Tenure Check-in Bypass

/ Earned milestones (directly under active assignments when both exist; also shown when milestones exist without active assignments)
- show_earned_milestones_card = @teammate_milestones.any? || @assignment_tenures.any?
- if show_earned_milestones_card
  .card.mb-4#milestones{ role: "region", "aria-labelledby": "milestones-section" }
    .card-header
      %h5.mb-0{ id: "milestones-section" }
        %i.bi.bi-trophy.me-2
        Earned milestones
        - if @teammate_milestones.any?
          %a.text-decoration-none.ms-3{"data-bs-toggle" => "collapse", "data-bs-target" => "#milestonesCollapse", "aria-expanded" => "true", "aria-controls" => "milestonesCollapse"}
            %span#milestonesExpandIcon.not-collapsed
              %i.bi.bi-chevron-up
              %small.text-muted (Hide milestones)
            %span#milestonesCollapseText.collapsed
              %i.bi.bi-chevron-down
              %small.text-muted="(Show #{pluralize(@teammate_milestones.count, 'milestone')})"
    .card-body
      - if @teammate_milestones.any?
        .collapse.show#milestonesCollapse
          %p.text-muted.mb-3
            %em These are the ability milestones this person has earned for #{@current_organization.display_name}.

          .row
            .col-md-8
              - @teammate_milestones.each_with_index do |milestone, index|
                - if index > 0
                  %hr.my-3

                = link_to organization_teammate_milestone_path(@current_organization, milestone), class: "text-decoration-none d-flex justify-content-between align-items-center py-2" do
                  .flex-grow-1
                    %strong= milestone.ability.name
                    %br
                    %small.text-muted Milestone #{milestone.milestone_level}
                  .text-muted
                    %small= format_date_in_user_timezone(milestone.attained_at, format: '%b %d, %Y')
            .col-md-4.border-start.border-secondary
              .d-grid.gap-2
                = link_to organization_abilities_path(@current_organization), class: "btn btn-outline-primary" do
                  %i.bi.bi-list.me-2
                  View All Abilities
                = link_to new_organization_ability_path(@current_organization), class: "btn btn-outline-primary" do
                  %i.bi.bi-plus-circle.me-2
                  Create New Ability
      - else
        %p.text-muted.mb-0
          %em No milestones earned yet for #{@current_organization.display_name}. Milestones appear here once they are certified for abilities in this organization.

/ No Data State
- if @current_employment&.position&.position_assignments&.empty? && @teammate_milestones.empty? && @assignment_tenures.empty?
  .alert.alert-info
    %h6.mb-2
      %i.bi.bi-info-circle.me-2
      No Growth Data Available
    %p.mb-2 This person has no current assignments, milestones, or assignment tenures to display for #{@current_organization.display_name}.
    = link_to "Edit Position", edit_organization_position_path(@current_organization, @current_employment.position), class: "btn btn-info btn-sm" if @current_employment&.position

/ Observations (scoped to what the viewer may see)
.card.mb-4{ role: "region", "aria-labelledby": "complete-picture-observations" }
  .card-header
    %h5.mb-0{ id: "complete-picture-observations" }
      %i.bi.bi-eye.me-2
      Observations
      %span.text-muted.fw-normal.small.ms-2
        #{@complete_picture_observations_given_count} given, #{@complete_picture_observations_received_count} received
  .card-body
    - if @complete_picture_recent_observations.any?
      .list-group.mb-3
        - @complete_picture_recent_observations.each do |observation|
          = render 'organizations/observations/observation_large_list_item', observation: observation, organization: @current_organization
    - else
      %p.text-muted.mb-3 No observations involving this teammate are visible to you.
    = link_to @complete_picture_observations_index_url, class: "btn btn-outline-primary w-100" do
      %i.bi.bi-list.me-2
      All observations involving this teammate

.mt-5
  %p.text-muted
    %em This complete picture view provides a comprehensive overview of the person's current position, assignments, and earned milestones for #{@current_organization.display_name} for development planning and performance management.
