-# Locals: batch:, search:, messages:, latest_consultation:, observation_type_options:,
-#         teammates_grouped_for_select:, duplicate_observations_by_key:, suggested_rateable_names_by_key:
- batch = local_assigns.fetch(:batch)
- search = local_assigns.fetch(:search)
- messages = local_assigns.fetch(:messages)
- latest_consultation = local_assigns[:latest_consultation]
- observation_type_options = local_assigns.fetch(:observation_type_options)
- teammates_grouped_for_select = local_assigns.fetch(:teammates_grouped_for_select)
- duplicate_observations_by_key = local_assigns.fetch(:duplicate_observations_by_key, {})
- suggested_rateable_names_by_key = local_assigns.fetch(:suggested_rateable_names_by_key, {})
- extraction_status_url = extraction_status_organization_company_teammate_possible_observation_slack_search_batch_path(organization, teammate_route_param(@teammate), search, batch)
- batch_update_path = organization_company_teammate_possible_observation_slack_search_batch_path(organization, teammate_route_param(@teammate), search, batch)
- form_id = "slack-ogo-candidates-form-#{batch.id}"
- messages_collapse_id = "batch-#{batch.id}-messages"

%section.mb-5{id: "consultation-#{batch.position}"}
  .d-flex.flex-wrap.align-items-center.justify-content-between.gap-2.mb-3
    %div
      %h5.mb-1= batch.display_label
      %p.mb-0.small.text-muted
        Status:
        %span.badge.text-bg-secondary= batch.extraction_status
        · #{batch.messages_count} messages
        - if latest_consultation&.model_id.present?
          · Model: #{latest_consultation.model_id}
    .d-flex.flex-wrap.gap-2
      - if policy(batch).extract?
        = button_to extract_organization_company_teammate_possible_observation_slack_search_batch_path(organization, teammate_route_param(@teammate), search, batch),
                    method: :post,
                    class: "btn btn-primary btn-sm",
                    data: { turbo: false } do
          %i.bi.bi-stars.me-1
          = batch.extraction_status == "completed" ? "Consult OG again" : "Consult OG to find potential OGOs"
      - if policy(batch).re_extract_with_stronger_model?
        = button_to re_extract_with_stronger_model_organization_company_teammate_possible_observation_slack_search_batch_path(organization, teammate_route_param(@teammate), search, batch),
                    method: :post,
                    class: "btn btn-outline-primary btn-sm",
                    data: { turbo: false } do
          %i.bi.bi-lightning-charge.me-1
          Re-run with stronger model

  - if batch.extraction_error.present? && batch.extraction_status != "failed"
    .alert.alert-info.mb-3
      %strong Note:
      = batch.extraction_error

  - case batch.extraction_status
  - when "pending", "processing"
    = render "shared/og_consultations/status_banner",
             status_url: extraction_status_url,
             label: "Consultation",
             initial_status: batch.extraction_status,
             wrapper_class: "alert alert-secondary mb-3",
             time_zone: current_person_iana_timezone
    .card.border-0.bg-light.mb-3
      .card-body.placeholder-glow.py-4
        - 3.times do
          .placeholder.col-12.mb-2.rounded{ style: "height: 0.9rem;" }

  - when "failed"
    .alert.alert-danger.mb-3
      Extraction failed#{batch.extraction_error.present? ? ": #{batch.extraction_error}" : '.'}
      - if policy(batch).re_extract?
        = button_to "Try again", re_extract_organization_company_teammate_possible_observation_slack_search_batch_path(organization, teammate_route_param(@teammate), search, batch), method: :post, class: "btn btn-sm btn-outline-primary ms-2", data: { turbo: false }

  - when "completed"
    - items = candidate_items_for_review(batch.extraction_items)
    - if items.empty?
      .alert.alert-warning.mb-3
        No noteworthy OGO candidates were found.
        - if batch.extraction_error.present?
          = batch.extraction_error
    - else
      %h6.mb-3 Review candidate OGOs
      = form_with url: batch_update_path, method: :patch, local: true, html: { id: form_id, data: { turbo: false } } do
        .table-responsive
          %table.table.table-bordered.align-middle
            %thead.table-light
              %tr
                %th Quote
                %th Actions
                %th Status
            %tbody
              - items.each_with_index do |item, idx|
                - included = ActiveModel::Type::Boolean.new.cast(item[:include])
                - responder_selected = item[:responder_company_teammate_id].present?
                - subject_selected = item[:subject_company_teammate_id].present?
                - ready = responder_selected && subject_selected
                - locked = item[:observation_id].present?
                - dismissed = item[:dismissed_at].present?
                - current_state = dismissed ? "dismissed" : (included ? "included" : "needs_processed")
                - dup_key = "#{item[:channel_id]}|#{item[:ts]}"
                - duplicates = duplicate_observations_by_key[dup_key] || []
                - confidence = item[:confidence].to_f
                - rateable_name = item[:suggested_rateable_name]
                - badge_class = if confidence >= 0.75
                  - "text-bg-success"
                - elsif confidence >= 0.5
                  - "text-bg-warning"
                - else
                  - "text-bg-secondary"
                %tr{ data: { slack_candidate_row: true } }
                  %td
                    = hidden_field_tag "items[#{idx}][id]", item[:id]
                    = hidden_field_tag "items[#{idx}][confidence]", item[:confidence]
                    = hidden_field_tag "items[#{idx}][observation_id]", item[:observation_id]
                    - if item[:suggested_rating].present? || item[:suggested_rateable_type].present?
                      - rating_label = { "strongly_agree" => "Exceptional", "agree" => "Solid", "disagree" => "Mis-aligned", "strongly_disagree" => "Concerning" }[item[:suggested_rating].to_s]
                      - rateable_type_label = item[:suggested_rateable_type] == "Aspiration" ? "Value" : item[:suggested_rateable_type]
                      - rateable_key = "#{item[:suggested_rateable_type]}:#{item[:suggested_rateable_id]}"
                      - rateable_name = rateable_name.presence || suggested_rateable_names_by_key[rateable_key]
                      - rateable_path = nil
                      - if item[:suggested_rateable_type] == "Assignment"
                        - rateable_path = organization_teammate_assignment_path(organization, teammate_route_param(@teammate), item[:suggested_rateable_id])
                      - elsif item[:suggested_rateable_type] == "Ability"
                        - rateable_path = organization_teammate_ability_path(organization, teammate_route_param(@teammate), item[:suggested_rateable_id])
                      - elsif item[:suggested_rateable_type] == "Aspiration"
                        - rateable_path = organization_teammate_aspiration_path(organization, teammate_route_param(@teammate), item[:suggested_rateable_id])
                      .mb-2.fs-6
                        %span.badge.me-2{ class: badge_class }= "#{format("%.0f%%", confidence * 100)} confident in this suggestion"
                        The OG Consultation AI Agent is suggesting:
                        %strong= rating_label
                        example of the #{rateable_type_label},
                        - if rateable_path.present? && rateable_name.present?
                          = link_to rateable_name, rateable_path, class: "fw-bold", target: "_blank", rel: "noopener"
                        - else
                          %strong= rateable_name
                        = "."
                    - else
                      .mb-2
                        %span.badge{ class: badge_class }= "#{format("%.0f%%", confidence * 100)} confident in this suggestion"
                    = label_tag "#{form_id}_#{idx}_quote", "Story / quotes", class: "form-label small mb-1"
                    = text_area_tag "items[#{idx}][quote]", item[:quote], class: "form-control form-control-sm", rows: 10, style: "min-width: 420px;", id: "#{form_id}_#{idx}_quote", data: { slack_row_field: true }, disabled: !included || locked
                    - if item[:permalink].present?
                      .mt-1
                        = link_to item[:permalink], target: "_blank", rel: "noopener", class: "small" do
                          %i.bi.bi-box-arrow-up-right.me-1
                          Open in Slack
                    - if duplicates.any?
                      .alert.alert-warning.py-1.px-2.mt-2.mb-0.small
                        %strong Already linked:
                        an OGO may already reference this Slack message.
                        - duplicates.each do |obs|
                          = link_to "##{obs.id}", organization_observation_path(organization, obs), class: "ms-1"
                  %td{ style: "min-width: 240px;" }
                    .mb-2
                      = label_tag nil, "Status", class: "form-label small mb-1 d-block"
                      - if locked
                        = hidden_field_tag "items[#{idx}][state]", "included"
                        %span.badge.text-bg-success Included (draft created)
                      - else
                        .btn-group.btn-group-sm.d-flex{role: "group", "aria-label" => "Candidate status"}
                          = radio_button_tag "items[#{idx}][state]", "needs_processed", current_state == "needs_processed", class: "btn-check", id: "#{form_id}_#{idx}_state_needs", data: { slack_state: true }
                          = label_tag "#{form_id}_#{idx}_state_needs", "Reviewing", class: "btn btn-outline-secondary"
                          = radio_button_tag "items[#{idx}][state]", "included", current_state == "included", class: "btn-check", id: "#{form_id}_#{idx}_state_incl", data: { slack_state: true }
                          = label_tag "#{form_id}_#{idx}_state_incl", "Include", class: "btn btn-outline-success"
                          = radio_button_tag "items[#{idx}][state]", "dismissed", current_state == "dismissed", class: "btn-check", id: "#{form_id}_#{idx}_state_dismiss", data: { slack_state: true }
                          = label_tag "#{form_id}_#{idx}_state_dismiss", "Dismiss", class: "btn btn-outline-danger"
                        .mt-2
                          = button_tag "Dismiss now",
                                       type: "submit",
                                       name: "dismiss_item_id",
                                       value: item[:id],
                                       class: "btn btn-sm btn-link text-decoration-none p-0"
                    %hr.my-2
                    .mb-2
                      = label_tag "#{form_id}_#{idx}_kind_kudos", "Kind", class: "form-label small mb-1"
                      - observation_type_options.each do |label, value|
                        .form-check
                          = radio_button_tag "items[#{idx}][kind]", value, item[:kind].to_s == value, class: "form-check-input", id: "#{form_id}_#{idx}_kind_#{value}", data: { slack_row_field: true }, disabled: !included || locked
                          = label_tag "#{form_id}_#{idx}_kind_#{value}", label, class: "form-check-label"
                    %hr.my-2
                    .mb-2
                      .small.text-muted.mb-1
                        Detected: #{item[:speaker_label]} → #{item[:recipient_label]}
                      = label_tag "#{form_id}_#{idx}_responder", "Observer (speaker)", class: "form-label small mb-0"
                      = select_tag "items[#{idx}][responder_company_teammate_id]", grouped_options_for_select([["—", [["—", ""]]]] + teammates_grouped_for_select, item[:responder_company_teammate_id]), class: "form-select form-select-sm mb-2", id: "#{form_id}_#{idx}_responder", data: { slack_row_field: true }, disabled: !included || locked
                      = label_tag "#{form_id}_#{idx}_subject", "Subject (observee)", class: "form-label small mb-0"
                      = select_tag "items[#{idx}][subject_company_teammate_id]", grouped_options_for_select([["—", [["—", ""]]]] + teammates_grouped_for_select, item[:subject_company_teammate_id]), class: "form-select form-select-sm", id: "#{form_id}_#{idx}_subject", data: { slack_row_field: true }, disabled: !included || locked
                      - unless responder_selected
                        .badge.text-bg-secondary.mt-1 Observer unclear
                      - unless subject_selected
                        .badge.text-bg-secondary.mt-1 Subject unclear
                    = hidden_field_tag "items[#{idx}][observer_unknown]", item[:observer_unknown]
                    = hidden_field_tag "items[#{idx}][observee_unknown]", item[:observee_unknown]
                    = hidden_field_tag "items[#{idx}][speaker_label]", item[:speaker_label]
                    = hidden_field_tag "items[#{idx}][recipient_label]", item[:recipient_label]
                    = hidden_field_tag "items[#{idx}][summary]", item[:summary]
                    = hidden_field_tag "items[#{idx}][short_quote]", item[:short_quote]
                    = hidden_field_tag "items[#{idx}][full_quote]", item[:full_quote]
                    = hidden_field_tag "items[#{idx}][channel_id]", item[:channel_id]
                    = hidden_field_tag "items[#{idx}][ts]", item[:ts]
                    = hidden_field_tag "items[#{idx}][permalink]", item[:permalink]
                    = hidden_field_tag "items[#{idx}][slack_user_id]", item[:slack_user_id]
                    = hidden_field_tag "items[#{idx}][target_is_subject]", item[:target_is_subject]
                    = hidden_field_tag "items[#{idx}][suggested_rateable_type]", item[:suggested_rateable_type]
                    = hidden_field_tag "items[#{idx}][suggested_rateable_id]", item[:suggested_rateable_id]
                    = hidden_field_tag "items[#{idx}][suggested_rateable_name]", rateable_name
                    = hidden_field_tag "items[#{idx}][suggested_rating]", item[:suggested_rating]
                    = hidden_field_tag "items[#{idx}][association_reason]", item[:association_reason]
                    = hidden_field_tag "items[#{idx}][rating_reason]", item[:rating_reason]
                    = hidden_field_tag "items[#{idx}][suggested_goal_id]", item[:suggested_goal_id]
                    = hidden_field_tag "items[#{idx}][dismissed_at]", item[:dismissed_at]
                    = hidden_field_tag "items[#{idx}][dismissed_by_company_teammate_id]", item[:dismissed_by_company_teammate_id]
                  %td
                    - if dismissed
                      %span.badge.text-bg-secondary Dismissed
                    - elsif locked
                      = link_to "Open draft OGO", organization_observation_path(organization, item[:observation_id]), class: "btn btn-sm btn-outline-primary"
                    - elsif !ready
                      %span.text-warning Needs IDs
                    - elsif confidence < 0.75
                      %span.text-muted Low confidence
                    - else
                      %span.text-muted Reviewing
        .d-flex.flex-wrap.gap-2.mt-2
          = submit_tag "Save all", name: "commit", value: "Save all", class: "btn btn-primary"
      %p.mt-3.mb-0.text-muted.small
        Each candidate is either #{content_tag(:strong, "Reviewing")}, #{content_tag(:strong, "Include")}, or #{content_tag(:strong, "Dismiss")}.
        Save all actualizes every row: included candidates become draft OGOs (Slack speaker is the observer; you are the creator),
        dismissed candidates are hidden from 1-by-1 check-ins, and the rest stay as potential OGOs.
        Include is pre-selected only for high-confidence candidates (≥75%). Use Dismiss now to dismiss a single row immediately.

  - else
    %p.mb-3.text-muted
      When ready, use
      %strong Consult OG to find potential OGOs
      to extract noteworthy moments from these messages.

  .mt-3
    %a.d-inline-flex.align-items-center.gap-1.text-decoration-none.small{href: "##{messages_collapse_id}", "data-bs-toggle" => "collapse", role: "button", "aria-expanded" => "false", "aria-controls" => messages_collapse_id}
      %i.bi.bi-chevron-down
      %span Messages in this consultation (#{messages.size})
    .collapse.mt-2{id: messages_collapse_id}
      = render "organizations/company_teammates/possible_observation_slack_searches/batch_messages_preview", messages: messages
