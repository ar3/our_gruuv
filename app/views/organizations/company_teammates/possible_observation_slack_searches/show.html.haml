- content_for :title, teammate_context_page_title(@selected_teammate, "Slack search about #{@casual_name}")
- search_status_url = search_status_organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search)
- extraction_status_url = extraction_status_organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search)

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      %i.bi.bi-slack.me-2
      Slack search about #{@casual_name}
      %span.badge.text-bg-warning
        %i.bi.bi-flask.me-1
        Beta

- content_for :header_action do
  = render "people/view_switcher"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Teammates", url: organization_employees_path(organization) }, { label: "#{@casual_name}'s OGOs", url: ogos_source_from_slack_organization_company_teammate_path(organization, teammate_route_param(@teammate)) }, { label: "Slack search", url: nil }])

.d-flex.flex-wrap.align-items-center.gap-2.mb-3
  = link_to ogos_source_from_slack_organization_company_teammate_path(organization, teammate_route_param(@teammate)), class: "btn btn-outline-secondary" do
    %i.bi.bi-arrow-left.me-1
    Back to Source from Slack
  - if @search.search_status == "completed" && policy(@search).extract? && %w[ready failed completed].include?(@search.extraction_status)
    = button_to extract_organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search),
                method: :post,
                class: "btn btn-primary",
                data: { turbo: false } do
      %i.bi.bi-stars.me-1
      = @search.extraction_status == "completed" ? "Re-find OGO candidates" : "Find OGO candidates"
  - if policy(@search).destroy?
    = button_to organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search),
                method: :delete,
                class: "btn btn-outline-danger",
                data: { turbo: false, confirm: "Delete this Slack search?" } do
      %i.bi.bi-trash.me-1
      Delete search

.card.border-0.shadow-sm.mb-4
  .card-body
    %p.mb-1
      %strong= @search.display_name
    %p.mb-1.text-muted
      Search:
      %span.badge.text-bg-secondary= @search.search_status
      · Extraction:
      %span.badge.text-bg-secondary= @search.extraction_status
      · Window: last #{@search.window_days} days
      · Run by #{@search.creator_company_teammate.person.casual_name}
    - if @search.query.present?
      %p.mb-0.small
        %span.text-muted Query:
        %code= @search.query
    - if @search.search_status == "failed" && @search.search_error.present?
      .alert.alert-danger.mt-3.mb-0= @search.search_error
    - if @search.extraction_error.present? && @search.extraction_status != "failed"
      .alert.alert-info.mt-3.mb-0
        %strong Note:
        = @search.extraction_error

- case @search.search_status
- when "pending", "processing"
  .alert.alert-secondary.mb-0#slack-search-status-banner{ data: { status_url: search_status_url } }
    %i.bi.bi-hourglass-split.me-2
    %span#slack-search-status-text
      Search is #{@search.search_status}…
    %span.ms-1.text-muted#slack-search-elapsed
    %span.ms-1.text-warning.d-none#slack-search-slow-warning
      Taking longer than expected.
    .small.text-muted.mt-1#slack-search-last-checked
      Last checked: just now
  .card.mt-3.border-0.bg-light
    .card-body.placeholder-glow.py-4
      - 4.times do
        .placeholder.col-12.mb-2.rounded{ style: "height: 0.9rem;" }
        .placeholder.col-10.mb-3.rounded{ style: "height: 0.9rem;" }

- when "failed"
  .alert.alert-danger.mb-0
    Search failed. Delete and try again, or reconnect Slack (search).

- when "completed"
  - case @search.extraction_status
  - when "pending", "processing"
    .alert.alert-secondary.mb-0#slack-extraction-status-banner{ data: { status_url: extraction_status_url } }
      %i.bi.bi-hourglass-split.me-2
      %span#slack-extraction-status-text
        Extraction is #{@search.extraction_status}…
      %span.ms-1.text-muted#slack-extraction-elapsed
      %span.ms-1.text-warning.d-none#slack-extraction-slow-warning
        Taking longer than expected.
      .small.text-muted.mt-1#slack-extraction-last-checked
        Last checked: just now
    .card.mt-3.border-0.bg-light
      .card-body.placeholder-glow.py-4
        - 4.times do
          .placeholder.col-12.mb-2.rounded{ style: "height: 0.9rem;" }
          .placeholder.col-10.mb-3.rounded{ style: "height: 0.9rem;" }

  - when "failed"
    .alert.alert-danger.mb-3
      Extraction failed#{@search.extraction_error.present? ? ": #{@search.extraction_error}" : '.'}
      - if policy(@search).re_extract?
        = button_to "Try again", re_extract_organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search), method: :post, class: "btn btn-sm btn-outline-primary ms-2", data: { turbo: false }

  - when "completed"
    - items = @search.extraction_items
    - if items.empty?
      .alert.alert-warning.mb-3
        No noteworthy OGO candidates were found.
        - if @search.extraction_error.present?
          = @search.extraction_error
      = render "raw_messages", messages: @messages, search: @search
    - else
      %h5.mb-3 Review candidate OGOs
      = form_with url: organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search), method: :patch, local: true do
        .table-responsive
          %table.table.table-bordered.align-middle
            %thead.table-light
              %tr
                %th Include
                %th Kind
                %th Confidence
                %th Quote
                %th Observer → subject
                %th Status
            %tbody
              - items.each_with_index do |item, idx|
                - responder_selected = item[:responder_company_teammate_id].present?
                - subject_selected = item[:subject_company_teammate_id].present?
                - ready = responder_selected && subject_selected
                - dup_key = "#{item[:channel_id]}|#{item[:ts]}"
                - duplicates = @duplicate_observations_by_key&.[](dup_key) || []
                - confidence = item[:confidence].to_f
                %tr
                  %td
                    = hidden_field_tag "items[#{idx}][id]", item[:id]
                    = check_box_tag "items[#{idx}][include]", "1", ActiveModel::Type::Boolean.new.cast(item[:include]), class: "form-check-input"
                  %td
                    - @observation_type_options.each do |label, value|
                      .form-check.form-check-inline
                        = radio_button_tag "items[#{idx}][kind]", value, item[:kind].to_s == value, class: "form-check-input", id: "items_#{idx}_kind_#{value}"
                        = label_tag "items_#{idx}_kind_#{value}", label, class: "form-check-label"
                  %td
                    - badge_class = if confidence >= 0.75
                      - "text-bg-success"
                    - elsif confidence >= 0.6
                      - "text-bg-warning"
                    - else
                      - "text-bg-secondary"
                    %span.badge{ class: badge_class }= format("%.0f%%", confidence * 100)
                    = hidden_field_tag "items[#{idx}][confidence]", item[:confidence]
                  %td
                    - rateable_name = item[:suggested_rateable_name]
                    - if item[:suggested_rating].present? || item[:suggested_rateable_type].present?
                      - rating_label = { "strongly_agree" => "Exceptional", "agree" => "Solid", "disagree" => "Mis-aligned", "strongly_disagree" => "Concerning" }[item[:suggested_rating].to_s]
                      - rateable_type_label = item[:suggested_rateable_type] == "Aspiration" ? "Value" : item[:suggested_rateable_type]
                      - rateable_key = "#{item[:suggested_rateable_type]}:#{item[:suggested_rateable_id]}"
                      - rateable_name = rateable_name.presence || @suggested_rateable_names_by_key&.[](rateable_key)
                      - rateable_path = nil
                      - if item[:suggested_rateable_type] == "Assignment"
                        - rateable_path = organization_teammate_assignment_path(organization, teammate_route_param(@teammate), item[:suggested_rateable_id])
                      - elsif item[:suggested_rateable_type] == "Ability"
                        - rateable_path = organization_teammate_ability_path(organization, teammate_route_param(@teammate), item[:suggested_rateable_id])
                      - elsif item[:suggested_rateable_type] == "Aspiration"
                        - rateable_path = organization_teammate_aspiration_path(organization, teammate_route_param(@teammate), item[:suggested_rateable_id])
                      .mb-2.fs-6
                        The OG Consultation AI Agent is suggesting:
                        %strong= rating_label
                        example of the #{rateable_type_label},
                        - if rateable_path.present? && rateable_name.present?
                          = link_to rateable_name, rateable_path, class: "fw-bold", target: "_blank", rel: "noopener"
                        - else
                          %strong= rateable_name
                        = "."
                    = text_area_tag "items[#{idx}][quote]", item[:quote], class: "form-control form-control-sm", rows: 14, style: "min-width: 520px;"
                    - if item[:permalink].present?
                      .mt-1
                        = link_to item[:permalink], target: "_blank", rel: "noopener", class: "small" do
                          %i.bi.bi-box-arrow-up-right.me-1
                          Open in Slack
                    - if duplicates.any?
                      .alert.alert-warning.py-1.px-2.mt-2.mb-0.small
                        %strong Already linked:
                        an OGO may already reference this Slack message.
                        - duplicates.each do |obs|
                          = link_to "##{obs.id}", organization_observation_path(organization, obs), class: "ms-1"
                  %td
                    .small.text-muted.mb-1
                      #{item[:speaker_label]} → #{item[:recipient_label]}
                    .row.g-1
                      .col-12
                        = label_tag "items_#{idx}_responder", "Observer (speaker)", class: "form-label small mb-0"
                        = select_tag "items[#{idx}][responder_company_teammate_id]", grouped_options_for_select([["—", [["—", ""]]]] + @teammates_grouped_for_select, item[:responder_company_teammate_id]), class: "form-select form-select-sm", id: "items_#{idx}_responder"
                      .col-12
                        = label_tag "items_#{idx}_subject", "Subject (observee)", class: "form-label small mb-0"
                        = select_tag "items[#{idx}][subject_company_teammate_id]", grouped_options_for_select([["—", [["—", ""]]]] + @teammates_grouped_for_select, item[:subject_company_teammate_id]), class: "form-select form-select-sm", id: "items_#{idx}_subject"
                    - unless responder_selected
                      .badge.text-bg-secondary.mt-1 Observer unclear
                    - unless subject_selected
                      .badge.text-bg-secondary.mt-1 Subject unclear
                    = hidden_field_tag "items[#{idx}][observer_unknown]", item[:observer_unknown]
                    = hidden_field_tag "items[#{idx}][observee_unknown]", item[:observee_unknown]
                    = hidden_field_tag "items[#{idx}][speaker_label]", item[:speaker_label]
                    = hidden_field_tag "items[#{idx}][recipient_label]", item[:recipient_label]
                    = hidden_field_tag "items[#{idx}][summary]", item[:summary]
                    = hidden_field_tag "items[#{idx}][short_quote]", item[:short_quote]
                    = hidden_field_tag "items[#{idx}][full_quote]", item[:full_quote]
                    = hidden_field_tag "items[#{idx}][channel_id]", item[:channel_id]
                    = hidden_field_tag "items[#{idx}][ts]", item[:ts]
                    = hidden_field_tag "items[#{idx}][permalink]", item[:permalink]
                    = hidden_field_tag "items[#{idx}][slack_user_id]", item[:slack_user_id]
                    = hidden_field_tag "items[#{idx}][target_is_subject]", item[:target_is_subject]
                    = hidden_field_tag "items[#{idx}][suggested_rateable_type]", item[:suggested_rateable_type]
                    = hidden_field_tag "items[#{idx}][suggested_rateable_id]", item[:suggested_rateable_id]
                    = hidden_field_tag "items[#{idx}][suggested_rateable_name]", rateable_name
                    = hidden_field_tag "items[#{idx}][suggested_rating]", item[:suggested_rating]
                    = hidden_field_tag "items[#{idx}][association_reason]", item[:association_reason]
                    = hidden_field_tag "items[#{idx}][rating_reason]", item[:rating_reason]
                    = hidden_field_tag "items[#{idx}][suggested_goal_id]", item[:suggested_goal_id]
                  %td
                    - if !ready
                      %span.text-warning Needs IDs
                    - elsif confidence < 0.75
                      %span.text-muted Low confidence
                    - else
                      %span.text-muted Reviewing
        = submit_tag "Save candidates", class: "btn btn-primary mt-2"
      %p.mt-3.mb-0.text-muted.small
        Creating draft OGOs from included candidates comes in a later step.
        Include is pre-checked only for high-confidence candidates (≥75%).

  - else
    = render "raw_messages", messages: @messages, search: @search
    %p.mt-3.mb-0.text-muted
      When ready, use
      %strong Find OGO candidates
      to extract noteworthy moments from these messages.

- if %w[pending processing].include?(@search.search_status)
  = render "status_poll_script", banner_id: "slack-search-status", label: "Search"
- elsif @search.search_status == "completed" && %w[pending processing].include?(@search.extraction_status)
  = render "status_poll_script", banner_id: "slack-extraction-status", label: "Extraction"
