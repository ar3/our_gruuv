- content_for :title, teammate_context_page_title(@selected_teammate, "Slack search about #{@casual_name}")
- search_status_url = search_status_organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search)
- page_help_id = "slackSearchPageHelp"

- content_for :header do
  .d-flex.align-items-center.gap-2.flex-wrap
    %h1.mb-0.d-flex.align-items-center.flex-wrap.gap-2
      %i.bi.bi-slack.me-2
      Slack search about #{@casual_name}
      %span.badge.text-bg-warning
        %i.bi.bi-flask.me-1
        Beta
      = render "shared/page_help/header_info_button",
               collapse_id: page_help_id,
               tooltip: "How Slack search consultations work on this page. Click for details."

- content_for :header_action do
  = render "people/view_switcher"

- content_for :go_back_link do
  = nav_hierarchy_with_previous(organization: organization, crumbs: [{ label: "Teammates", url: organization_employees_path(organization) }, { label: "#{@casual_name}'s OGOs", url: ogos_source_from_slack_organization_company_teammate_path(organization, teammate_route_param(@teammate)) }, { label: "Slack search", url: nil }])

.collapse.mb-4{id: page_help_id}
  = render "page_help", casual_name: @casual_name

.d-flex.flex-wrap.align-items-center.gap-2.mb-3
  = link_to ogos_source_from_slack_organization_company_teammate_path(organization, teammate_route_param(@teammate)), class: "btn btn-outline-secondary" do
    %i.bi.bi-arrow-left.me-1
    Back to Source from Slack
  - if @search.search_status == "completed" && @search.raw_results_file.attached?
    = link_to download_raw_results_organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search), class: "btn btn-outline-secondary" do
      %i.bi.bi-download.me-1
      Download messages
  - if policy(@search).destroy?
    = button_to organization_company_teammate_possible_observation_slack_search_path(organization, teammate_route_param(@teammate), @search),
                method: :delete,
                class: "btn btn-outline-danger",
                data: { turbo: false, confirm: "Delete this Slack search?" } do
      %i.bi.bi-trash.me-1
      Delete search

.card.border-0.shadow-sm.mb-4
  .card-body
    %p.mb-1
      %strong= @search.display_name
    %p.mb-1.text-muted
      Search:
      %span.badge.text-bg-secondary= @search.search_status
      · Window: last #{@search.window_days} days
      · Run by #{@search.creator_company_teammate.person.casual_name}
      - if @search.search_status == "completed"
        · #{@search.messages_count_summary}
    - if @search.query.present? || @search.search_queries.any?
      .small.mb-0
        %span.text-muted Queries:
        - @search.search_queries.each do |entry|
          .mt-1
            %span.badge.text-bg-light.me-1= entry["kind"].presence || entry[:kind] || "query"
            %code= entry["query"].presence || entry[:query]
    - if @search.search_status == "failed" && @search.search_error.present?
      .alert.alert-danger.mt-3.mb-0= @search.search_error

- case @search.search_status
- when "pending", "processing"
  = render "shared/og_consultations/status_banner",
           status_url: search_status_url,
           label: "Search",
           initial_status: @search.search_status,
           wrapper_class: "alert alert-secondary mb-0",
           time_zone: current_person_iana_timezone
  .card.mt-3.border-0.bg-light
    .card-body.placeholder-glow.py-4
      - 4.times do
        .placeholder.col-12.mb-2.rounded{ style: "height: 0.9rem;" }
        .placeholder.col-10.mb-3.rounded{ style: "height: 0.9rem;" }

- when "failed"
  .alert.alert-danger.mb-0
    Search failed. Delete and try again, or reconnect Slack (search).

- when "completed"
  - if @batches.any?
    - if @batches.size > 1
      .slack-consultation-sticky-nav.sticky-top.bg-body.border.rounded.px-3.py-2.mb-4{style: "z-index: 1020; top: 0.5rem;"}
        .small.text-muted.mb-1 Jump to consultation
        .d-flex.flex-wrap.gap-2
          - @batches.each do |batch|
            = link_to "Consultation #{batch.position} of #{@batches.size}",
                      "#consultation-#{batch.position}",
                      class: "btn btn-sm btn-outline-secondary",
                      title: batch.display_label

    - @batches.each do |batch|
      = render "consultation_section",
               batch: batch,
               search: @search,
               messages: batch.messages,
               latest_consultation: @latest_consultation_by_batch_id[batch.id],
               observation_type_options: @observation_type_options || [],
               teammates_grouped_for_select: @teammates_grouped_for_select || [],
               duplicate_observations_by_key: @duplicate_observations_by_batch_id[batch.id] || {},
               suggested_rateable_names_by_key: @suggested_rateable_names_by_batch_id[batch.id] || {}

    :javascript
      (function() {
        document.querySelectorAll("[id^='slack-ogo-candidates-form-']").forEach(function(form) {
          function syncRow(row) {
            var include = row.querySelector("[data-slack-include]");
            if (!include) return;
            var enabled = include.checked;
            row.querySelectorAll("[data-slack-row-field]").forEach(function(field) {
              field.disabled = !enabled;
            });
          }

          form.querySelectorAll("[data-slack-candidate-row]").forEach(function(row) {
            syncRow(row);
            var include = row.querySelector("[data-slack-include]");
            if (include) {
              include.addEventListener("change", function() { syncRow(row); });
            }
          });

          form.addEventListener("submit", function() {
            form.querySelectorAll("[data-slack-row-field]").forEach(function(field) {
              field.disabled = false;
            });
          });
        });
      })();
  - else
    %p.text-muted.mb-0
      No messages met the minimum length for consultation after filtering.
      - if @search.raw_results_file.attached?
        You can still download the raw search messages above.
