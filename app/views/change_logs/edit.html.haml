- content_for :title, "Edit Change Log"

- content_for :header do
  %h1.mb-0
    %i.bi.bi-pencil.me-2
    Edit Change Log

- content_for :go_back_link do
  = nav_return_back(url: change_log_path(@change_log), text: "Change log")

.card
  .card-header
    %h5.mb-0
      %i.bi.bi-clock-history.me-2
      Update Change Log
  .card-body
    = render 'form'

