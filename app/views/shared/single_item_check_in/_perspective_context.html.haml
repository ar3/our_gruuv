- start_on = check_in.check_in_started_on
- start_phrase = start_on.present? ? start_on.strftime("%B %d, %Y") : "the start of this check-in"
- counterparty_clause = single_item_check_in_counterparty_ready_review_clause(check_in, teammate, current_person)
.check-in-perspective-notes.mb-3{ role: "note" }
  %p.mb-2.small.text-body
    This is your perspective on #{teammate.person.casual_name} and #{object_name} from #{start_phrase} until now. #{counterparty_clause}
  %p.mb-0.small.text-body
    Your check-in on #{teammate.person.casual_name} and #{object_name} is currently:
    - if is_complete
      %span.badge.bg-success.rounded-pill.me-1 ready for review
      %span.text-body ... click the blue button below to save and keep it ready for review
    - else
      %span.badge.bg-warning.text-dark.rounded-pill.me-1 draft
      %span.text-body ... click the blue button below to mark it ready for review
