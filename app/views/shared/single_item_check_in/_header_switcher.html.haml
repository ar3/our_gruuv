-# Expects: @teammate, @organization, @single_item_name, @latest_finalized_for_pill, @engagement_health_records
-# Optional: @single_item_type for finalized pill
- return unless @teammate && @organization

.d-flex.flex-column.gap-2
  .d-flex.align-items-center.justify-content-between.flex-wrap.gap-2
    .d-flex.align-items-center.gap-3
      .flex-shrink-0
        = teammate_profile_image(@teammate, size: 48)
      .d-flex.flex-column
        %span.fw-bold= @teammate.person.casual_name
        %span.text-muted.small
          = link_to one_by_one_clarity_check_in_label, up_next_organization_company_teammate_check_ins_path(@organization, @teammate), class: "text-muted"
          = " on #{@single_item_name}"
    .d-flex.align-items-center.gap-2
      - if current_person == @teammate.person
        %span.badge.bg-secondary Employee View
      - else
        %span.badge.bg-secondary Manager View

  %hr.my-1.py-0.opacity-25

  .d-flex.align-items-center.justify-content-between.flex-wrap.gap-2
    .d-flex.align-items-center
      - popover_content = last_finalized_check_in_popover_content(@latest_finalized_for_pill, @teammate.person.casual_name, @single_item_type || :position)
      = render "shared/last_finalized_pill", latest_finalized: @latest_finalized_for_pill, popover_content: popover_content
    - action_breakdown = EngagementHealth::ClarityActionMetrics.for_records(@engagement_health_records)
    - names = teammate_and_manager_short_names(@teammate, @organization)
    - action_popover_html = check_ins_health_action_popover_html(records: @engagement_health_records, employee_name: names[:employee], manager_name: names[:manager])
    .d-flex.flex-column.align-items-end
      = render "shared/clarity_action_slots/summary",
               breakdown: action_breakdown,
               popover_html: action_popover_html,
               url: up_next_organization_company_teammate_check_ins_path(@organization, @teammate),
               show_bar: false
