:css
  .single-item-check-in-nav .nav-link.active {
    background-color: #0d6efd !important;
    color: white !important;
    border-radius: 0.375rem;
  }

  .single-item-check-in-nav .nav-link:hover {
    background-color: #f8f9fa;
    border-radius: 0.375rem;
  }

  .single-item-check-in-nav .nav-link {
    transition: all 0.2s ease-in-out;
  }

  .single-item-check-in-nav .nav-link.nav-link--sublink {
    font-size: 0.875rem;
    padding-left: 2rem;
  }

  .single-item-check-in-page section[id] {
    scroll-margin-top: 5.5rem;
  }

  @media (min-width: 768px) {
    .single-item-check-in-page section[id] {
      scroll-margin-top: 2rem;
    }
  }

  .single-item-check-in-mobile-nav {
    top: 0;
    z-index: 1020;
    background: var(--bs-body-bg);
    border-bottom: 1px solid var(--bs-border-color);
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }

  .single-item-check-in-mobile-nav__scroll {
    display: flex;
    gap: 0.35rem;
    overflow-x: auto;
    flex-wrap: nowrap;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .single-item-check-in-mobile-nav__scroll::-webkit-scrollbar {
    display: none;
  }

  .single-item-check-in-mobile-nav .nav-link {
    white-space: nowrap;
    flex-shrink: 0;
    font-size: 0.8125rem;
    padding: 0.35rem 0.65rem;
  }
