-# Locals: open_check_in, start_check_in_path, object_name — yields form body when open_check_in present
%section#check-in.mb-5
  .card
    .card-header
      %h5.mb-0 Your check-in
    .card-body
      - if open_check_in
        = yield
      - else
        .text-center.py-4
          %p.text-muted.mb-3
            No open check-in for
            = object_name
            yet.
          = button_to "No open check-in — start one?", start_check_in_path, method: :post, class: "btn btn-primary"
