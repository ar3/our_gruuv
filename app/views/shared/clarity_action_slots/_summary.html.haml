-# Locals: breakdown, popover_html (optional), height_px (optional — defaults to 10px)
- breakdown = local_assigns[:breakdown]
- popover_html = local_assigns[:popover_html]
- height_px = local_assigns[:height_px].presence || check_ins_health_action_slots_summary_bar_height_px
- segments = check_ins_health_action_slots_bar_segments(breakdown)
- if breakdown.blank? || breakdown.total_slots.zero?
  %small.text-muted —
- else
  .clarity-action-slots-summary.d-flex.align-items-center.gap-2{
    "data-bs-toggle" => (popover_html.present? ? "popover" : nil),
    "data-bs-trigger" => (popover_html.present? ? "hover" : nil),
    "data-bs-placement" => (popover_html.present? ? "top" : nil),
    "data-bs-html" => (popover_html.present? ? "true" : nil),
    "data-bs-content" => (popover_html.present? ? popover_html : nil),
    style: (popover_html.present? ? "cursor: help;" : nil)
  }
    %small.text-info.flex-shrink-0.mb-0
      = "#{breakdown.ok_percentage.round(1)}% ok"
    .clarity-action-slots-summary__bar.rounded.overflow-hidden{
      style: "height: #{height_px}px;",
      role: "img",
      aria: { label: "Clarity action slots: #{breakdown.ok_percentage.round(1)}% ok" }
    }
      - segments.each do |segment|
        %span.clarity-action-slots-summary__segment{
          class: segment[:css],
          style: "flex: #{segment[:percentage]} 0 0;",
          title: segment[:label],
          aria: { label: segment[:label] }
        }
