- goal = local_assigns[:goal]
- indent_level = local_assigns.fetch(:indent_level, 0)
- all_descendant_goal_ids = local_assigns[:all_descendant_goal_ids]
- linked_goal_check_ins = local_assigns[:linked_goal_check_ins] || {}
- organization = local_assigns[:organization]
- association_record = local_assigns[:association_record]
- disassociate_return_url = local_assigns[:disassociate_return_url]
- for_company_teammate_id = local_assigns[:for_company_teammate_id]
- link_goal_titles = local_assigns.fetch(:link_goal_titles, false)
- show_goal_progress_link = local_assigns.fetch(:show_goal_progress_link, false)
- goal_weekly_update_return_url = local_assigns[:goal_weekly_update_return_url]
- weekly_update_return_text = local_assigns[:weekly_update_return_text]

- most_recent_check_in = linked_goal_check_ins[goal.id]
- indent_px = indent_level * 30
- status_icon = goal_status_icon(goal)
- is_struck_through = goal_should_be_struck_through?(goal)
- title_class = is_struck_through ? 'text-decoration-line-through' : ''

%li.mb-2{style: indent_level > 0 ? "margin-left: #{indent_px}px;" : ""}
  .d-flex.align-items-start.justify-content-between.gap-2
    .flex-grow-1
      - if indent_level > 0
        %i.bi.bi-arrow-90deg-down.rotate-270{style: "margin-right: 0.5rem;"}
      %i.bi{class: status_icon, style: "margin-right: 0.5rem;"}
      - if link_goal_titles && organization.present? && policy(goal).show?
        = link_to organization_goal_path(organization, goal), class: "fw-bold text-body text-decoration-none #{title_class}" do
          = goal.title
      - else
        %strong{class: title_class}= goal.title
      - if goal.calculated_target_date.present?
        %span.text-muted.ms-1
          by #{goal.calculated_target_date.strftime('%b %d, %Y')}
      - if show_goal_progress_link && goal_weekly_update_return_url.present? && organization.present? && policy(goal).show? && !goal_is_completed?(goal)
        %span.text-muted.ms-1
          = link_to 'Update progress', weekly_update_organization_goal_path(organization, goal, return_url: goal_weekly_update_return_url, return_text: weekly_update_return_text.presence || 'Goal'), class: 'text-muted text-decoration-underline'
      - if most_recent_check_in.present?
        %small.text-muted.d-block.mt-1
          = render 'organizations/goals/goal_check_in_sentence', check_in: most_recent_check_in, goal: goal
    - if association_record.present? && organization && policy(association_record).destroy?
      = button_to goal_external_association_destroy_path(organization, association_record, return_url: disassociate_return_url, for_company_teammate_id: for_company_teammate_id), method: :delete, class: 'btn btn-sm btn-outline-danger flex-shrink-0', form: { class: 'd-inline', data: { turbo_confirm: 'Remove this goal association?' } } do
        %i.bi.bi-trash
  %br
  - child_goals = goal.outgoing_links.includes(:child).map(&:child).compact.select { |g| all_descendant_goal_ids.include?(g.id) && g.deleted_at.nil? }
  - if child_goals.any?
    %ul.list-unstyled.mt-2
      - child_goals.each do |child_goal|
        = render 'shared/goals/goal_hierarchy_item', goal: child_goal, indent_level: indent_level + 1, all_descendant_goal_ids: all_descendant_goal_ids, linked_goal_check_ins: linked_goal_check_ins, organization: organization, association_record: nil, disassociate_return_url: disassociate_return_url, for_company_teammate_id: for_company_teammate_id, link_goal_titles: link_goal_titles, show_goal_progress_link: show_goal_progress_link, goal_weekly_update_return_url: goal_weekly_update_return_url, weekly_update_return_text: weekly_update_return_text
