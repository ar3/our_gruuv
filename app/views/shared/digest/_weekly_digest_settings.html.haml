-# locals: organization, teammate, return_url, return_text, editable:, anchor_key:
- anchor_key = local_assigns.fetch(:anchor_key, 'one_on_one')
- digest_prefs = UserPreference.for_person(teammate.person)
- weekly_day = digest_prefs.preference(:about_me_weekly_day).presence || 'off'
- about_me_digest_on = digest_prefs.preference(:about_me_digest_enabled) == 'on'
- one_on_one_digest_on = digest_prefs.preference(:one_on_one_digest_enabled) == 'on'
- editable = local_assigns.fetch(:editable, false)
- has_slack = teammate.has_slack_identity?
- has_phone = teammate.person.unique_textable_phone_number.present?
- effective_slack = digest_prefs.effective_digest_slack(teammate)
- effective_sms = digest_prefs.effective_digest_sms(teammate.person)
- weekly_digest_form_id = "weekly-digest-prefs-form-#{teammate.id}"
- any_digest_selected = one_on_one_digest_on || about_me_digest_on
- reminder_configured = weekly_reminder_configured?(one_on_one_on: one_on_one_digest_on, about_me_on: about_me_digest_on, weekly_day: weekly_day)
- summary_sentence = weekly_digest_summary_sentence(one_on_one_on: one_on_one_digest_on, about_me_on: about_me_digest_on, weekly_day: weekly_day)
- collapse_id = "weekly-digest-#{anchor_key}-#{teammate.id}"
- settings_region_id = "weekly-digest-settings-#{anchor_key}"
- settings_heading_id = "#{settings_region_id}-heading"
- digest_settings_url = edit_organization_digest_path(organization, return_url: return_url, return_text: return_text)
- send_now_tooltip = 'Select at least one weekly digest (1:1 guide or About Me reminder) to send now.'

:css
  .weekly-digest-configure-toggle[aria-expanded="true"] .weekly-digest-chevron {
    transform: rotate(180deg);
  }
  .weekly-digest-chevron {
    display: inline-block;
    transition: transform 0.2s ease-in-out;
  }

.card.mb-4{id: settings_region_id, role: "region", "aria-labelledby": settings_heading_id}
  - if reminder_configured
    .card-body.py-3
      .d-flex.flex-wrap.align-items-center.justify-content-between.gap-2
        %span.fw-semibold{id: settings_heading_id}= summary_sentence
        - if editable
          %button.btn.btn-link.btn-sm.text-decoration-none.p-0.weekly-digest-configure-toggle{
            type: "button",
            "data-bs-toggle": "collapse",
            "data-bs-target": "##{collapse_id}",
            "aria-expanded": "false",
            "aria-controls": collapse_id
          }
            Configure
            %i.bi.bi-chevron-down.ms-1.weekly-digest-chevron
        - else
          %span.text-muted.small Read-only
  - else
    .card-header
      %h5.mb-0{id: settings_heading_id}
        %i.bi.bi-bell.me-2
        Weekly Slack reminders

  .collapse{class: (reminder_configured ? nil : 'show'), id: collapse_id}
    .card-body{class: (reminder_configured ? 'pt-0 border-top' : nil)}
      - unless reminder_configured
        %p.text-muted.small.mb-3
          Both digests use the same weekday and send at 8:00 AM in #{teammate.person.casual_name}'s timezone to a group DM with them and their manager (when Slack is enabled).

      - if editable
        = form_with url: organization_digest_path(organization), method: :patch, local: true, id: weekly_digest_form_id do
          = hidden_field_tag :digest_teammate_id, teammate.id
          = hidden_field_tag :return_url, return_url
          = hidden_field_tag :return_text, return_text

        .row.g-3.align-items-start
          .col-md-4
            .small.fw-semibold.mb-2 Which digests to send
            = hidden_field_tag :one_on_one_digest_enabled, 'off', form: weekly_digest_form_id
            .form-check.mb-2
              = check_box_tag :one_on_one_digest_enabled, 'on', one_on_one_digest_on, class: 'form-check-input', id: "one_on_one_digest_enabled_#{teammate.id}", form: weekly_digest_form_id, onchange: 'this.form.submit()'
              = label_tag "one_on_one_digest_enabled_#{teammate.id}", class: 'form-check-label d-inline-flex align-items-center gap-1' do
                %span 1:1 guide digest
                %i.bi.bi-info-circle.text-muted.ms-1{role: 'button', tabindex: '0', style: 'cursor: help;', data: digest_popover_data_attributes(one_on_one_digest_popover_content)}
            = hidden_field_tag :about_me_digest_enabled, 'off', form: weekly_digest_form_id
            .form-check.mb-0
              = check_box_tag :about_me_digest_enabled, 'on', about_me_digest_on, class: 'form-check-input', id: "about_me_digest_enabled_#{teammate.id}", form: weekly_digest_form_id, onchange: 'this.form.submit()'
              = label_tag "about_me_digest_enabled_#{teammate.id}", class: 'form-check-label d-inline-flex align-items-center gap-1' do
                %span About Me reminder digest
                %i.bi.bi-info-circle.text-muted.ms-1{role: 'button', tabindex: '0', style: 'cursor: help;', data: digest_popover_data_attributes(about_me_digest_popover_content)}

          .col-md-8
            - if any_digest_selected
              = button_to send_weekly_digests_now_organization_digest_path(organization),
                          method: :post,
                          form: { class: 'd-grid' },
                          class: 'btn btn-outline-primary',
                          params: { teammate_id: teammate.id, return_url: return_url, return_text: return_text } do
                %i.bi.bi-send.me-2
                Send now
            - else
              %span.d-inline-block.w-100{data: { bs_toggle: 'tooltip', bs_placement: 'top' }, title: send_now_tooltip}
                %button.btn.btn-outline-primary.w-100{type: 'button', disabled: true, aria: { disabled: true }}
                  %i.bi.bi-exclamation-triangle.me-2
                  Send now
            .mt-2
              = link_to digest_settings_url, class: 'small' do
                %i.bi.bi-sliders.me-1
                Digest configuration page

        .row.g-3.align-items-start
          .col-md-4
            .small.fw-semibold.mb-2 Delivery mediums
            .d-flex.flex-wrap.gap-3
              .form-check
                = check_box_tag :digest_slack, 'on', effective_slack == 'on', class: 'form-check-input', id: "weekly_digest_slack_#{teammate.id}", form: weekly_digest_form_id, disabled: !has_slack, onchange: 'this.form.submit()'
                = label_tag "weekly_digest_slack_#{teammate.id}", 'Slack', class: 'form-check-label'
              .form-check
                = check_box_tag :digest_sms, 'on', effective_sms == 'on', class: 'form-check-input', id: "weekly_digest_sms_#{teammate.id}", form: weekly_digest_form_id, disabled: !has_phone, onchange: 'this.form.submit()'
                = label_tag "weekly_digest_sms_#{teammate.id}", 'SMS', class: 'form-check-label'
            - unless has_slack
              %p.text-muted.small.mb-0.mt-1 Connect Slack in profile settings to enable Slack reminders.
            - unless has_phone
              %p.text-muted.small.mb-0.mt-1
                Add a phone number in
                = link_to 'profile', about_me_organization_company_teammate_path(organization, teammate_route_param(teammate)), class: 'small'
                to enable SMS.

          .col-md-8
            .small.fw-semibold.mb-2 Weekly reminder day
            = render 'shared/digest/weekly_reminder_day_button_group', teammate_id: teammate.id, weekly_day: weekly_day, form_id: weekly_digest_form_id

      - else
        %p.text-muted.small.mb-0
          You can view these settings but cannot change them for #{teammate.person.casual_name}.
