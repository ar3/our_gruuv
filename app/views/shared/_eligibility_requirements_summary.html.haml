-# Optional locals: eligibility_requirements_sentences (array of strings), ability_milestone_requirements (array of { ability:, minimum_milestone_level: }),
-# source_caption_text, source_link_text, source_link_path, collapsible (default true)
- sentences = local_assigns[:eligibility_requirements_sentences] || []
- ability_milestone_requirements = local_assigns[:ability_milestone_requirements] || []
- source_caption_text = local_assigns[:source_caption_text]
- source_link_text = local_assigns[:source_link_text]
- source_link_path = local_assigns[:source_link_path]
- collapsible = local_assigns.fetch(:collapsible, true)

.card.mb-4.mt-3
  .card-body
    %h5.mb-0
      %i.bi.bi-check2-circle.me-2
      Eligibility requirements
    - if source_caption_text.present?
      .caption.small.text-muted.mt-1
        = source_caption_text
        - if source_link_text.present? && source_link_path.present?
          = link_to source_link_text, source_link_path, class: "ms-1"
    - if collapsible
      %a.d-flex.align-items-center.gap-2.text-secondary.text-decoration-none.mt-2{ "data-bs-toggle" => "collapse", "data-bs-target" => "#eligibilityRequirementsSummary", "aria-expanded" => "false", "aria-controls" => "eligibilityRequirementsSummary", href: "#", style: "cursor: pointer;" }
        %i.bi.bi-chevron-down
        %span Summary
      .collapse.mt-3#eligibilityRequirementsSummary
        - if sentences.present?
          %p.fw-semibold.mb-2 All eligibility requirements
          %ul.mb-4
            - sentences.each do |sentence|
              %li.mb-1= sentence
        - if ability_milestone_requirements.present?
          %p.fw-semibold.mb-2 Abilities and required Ability Milestones
          %ul.mb-0
            - ability_milestone_requirements.each do |item|
              %li= eligibility_ability_milestone_requirement_sentence(item[:ability], item[:minimum_milestone_level])
        - if sentences.blank? && ability_milestone_requirements.blank?
          %p.text-muted.mb-0 No eligibility requirements configured for this position.
    - else
      .mt-3
        - if sentences.present?
          %p.fw-semibold.mb-2 All eligibility requirements
          %ul.mb-4
            - sentences.each do |sentence|
              %li.mb-1= sentence
        - if ability_milestone_requirements.present?
          %p.fw-semibold.mb-2 Abilities and required Ability Milestones
          %ul.mb-0
            - ability_milestone_requirements.each do |item|
              %li= eligibility_ability_milestone_requirement_sentence(item[:ability], item[:minimum_milestone_level])
        - if sentences.blank? && ability_milestone_requirements.blank?
          %p.text-muted.mb-0 No eligibility requirements configured for this position.
