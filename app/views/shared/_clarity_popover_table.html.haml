-# Locals: table_data — hash with :position, :assignments, :aspirations; each has :employee, :manager, :together (0–100)
- return if table_data.blank?

%table.table.table-sm.mb-0.small
  %thead
    %tr
      %th
      %th.text-end Employee
      %th.text-end Manager
      %th.text-end Together
  %tbody
    %tr
      %td Position
      %td.text-end= "#{table_data.dig(:position, :employee) || 0}%"
      %td.text-end= "#{table_data.dig(:position, :manager) || 0}%"
      %td.text-end= "#{table_data.dig(:position, :together) || 0}%"
    %tr
      %td Assignments
      %td.text-end= "#{table_data.dig(:assignments, :employee) || 0}%"
      %td.text-end= "#{table_data.dig(:assignments, :manager) || 0}%"
      %td.text-end= "#{table_data.dig(:assignments, :together) || 0}%"
    %tr
      %td Values
      %td.text-end= "#{table_data.dig(:aspirations, :employee) || 0}%"
      %td.text-end= "#{table_data.dig(:aspirations, :manager) || 0}%"
      %td.text-end= "#{table_data.dig(:aspirations, :together) || 0}%"
  %tfoot
    %tr
      %td.text-muted.small.pt-2{colspan: 4}
        = check_in_health_clarity_popover_caption
